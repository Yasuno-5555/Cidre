#!/usr/bin/env bash
# cidre-boot-test-report: Summary report builder for controlled boot validation runs
set -euo pipefail

state_dir=""
output_file=""

usage() {
  cat <<EOF
Usage: cidre-boot-test-report [options]

Compile controlled boot test reports.

Options:
  --state <dir>     Path to boot-test/current directory
  --output <file>   Output markdown file path
  --help            Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --state) state_dir="$2"; shift 2 ;;
    --output) output_file="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [ -z "$state_dir" ] || [ -z "$output_file" ]; then
  echo "ERROR: --state and --output are required" >&2
  exit 1
fi

mkdir -p "$(dirname "$output_file")"

status="unknown"
stage="unknown"
reason=""
if [ -f "$state_dir/result.json" ] && command -v python3 >/dev/null 2>&1; then
  status=$(python3 -c "import json; d=json.load(open('$state_dir/result.json')); print(d.get('status', 'unknown'))")
  stage=$(python3 -c "import json; d=json.load(open('$state_dir/result.json')); print(d.get('stage', 'unknown'))")
  reason=$(python3 -c "import json; d=json.load(open('$state_dir/result.json')); print(d.get('reason', ''))")
fi

cat > "$output_file" <<EOF
# Cidre Controlled Boot Test Report

Generated on: $(date -u +%Y-%m-%dT%H:%M:%SZ)

## Executive Summary
- **Overall Status**: $status
- **Failed Stage**: $stage
- **Reason**: $reason

## Log Collections Checked
- Preflight Log: $([ -f "$state_dir/preflight.log" ] && echo "Present" || echo "Missing")
- Observation Checklist: $([ -f "$state_dir/observation.md" ] && echo "Present" || echo "Missing")
- Failure Classification: $([ -f "$state_dir/failure-classification.md" ] && echo "Present" || echo "Missing")
EOF

echo "Boot test report created at: $output_file"
EOF

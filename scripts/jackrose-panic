#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/jackrose-recovery-common"

reason="unknown"
stage="unknown"
message=""
safe_mode=false
report=false
dry_run=false

usage() {
  cat <<EOF
Usage: jackrose-panic [options]

Options:
  --reason <reason>
  --stage <stage>
  --message <message>
  --safe-mode
  --report
  --dry-run
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --reason) reason="$2"; shift 2 ;;
    --stage) stage="$2"; shift 2 ;;
    --message) message="$2"; shift 2 ;;
    --safe-mode) safe_mode=true; shift ;;
    --report) report=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

jackrose_recovery_write_state reason "$reason"
jackrose_recovery_write_state last-stage "$stage"
[ -n "$message" ] && jackrose_recovery_write_state last-error "$message"
jackrose_recovery_append_log panic.log "reason=$reason stage=$stage message=$message safe_mode=$safe_mode"

# Update guided installer state if running
if [ -x "$SCRIPT_DIR/jackrose-install-state" ]; then
  "$SCRIPT_DIR/jackrose-install-state" --mark-failed "$reason" 2>/dev/null || true
  "$SCRIPT_DIR/jackrose-install-failure-report" --stage "$stage" --reason "$reason" --output "$(dirname "$SCRIPT_DIR")/.local/state/jackrose/install/current/install-failure-report.md" 2>/dev/null || true
fi

if [ "$report" = "true" ] || [ "$dry_run" = "false" ]; then
  "$SCRIPT_DIR/jackrose-recovery-report" >/dev/null
fi

if [ "$dry_run" = "true" ]; then
  echo "Jackrose panic (dry-run)"
  echo "reason: $reason"
  echo "stage: $stage"
  echo "message: ${message:-none}"
  echo "available actions:"
  "$SCRIPT_DIR/jackrose-recovery-actions" --list
  echo ""
  echo "If main Jackrose no longer boots:"
  echo "  Boot Jackrose Rescue Slot."
  echo "  Run: jackrose-rescue --check"
  echo "  For boot planning: jackrose-rescue --boot-plan"
  echo "  For creation guidance: jackrose-rescue --create-preflight --target <exact-target>"
  echo "  On macOS: ./install-macos --rescue-check"
  exit 0
fi

if [ "$safe_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-safe-mode" --reason "$reason" --menu
fi

exec "$SCRIPT_DIR/jackrose-recovery-screen" --reason "$reason" --non-interactive

#!/bin/sh
set -eu
# jackrose-kernelcache-hotfix — one-shot fix for the mac13g → macOS 26 kernelcache mismatch
# Copies the current macOS kernelcache (matching firmware) to the Jackrose volumes.
# Run this from a macOS Terminal with admin privileges.
# After this: select Jackrose from boot picker → 1TR boot should succeed → step2 runs.

JACKROSE_VG="28FBFAE1-4CF1-408C-BDE3-06F235EA3A23"
MACOS_VG="08E3B56E-946D-4280-9E3C-1931ED8B8B34"
MACOS_ACTIVE_HASH="7E7B1379629619B2AD0F87FEA4DE8629CA17F3B9909D274B12B84E40F439195D175F72AEA03464E694C1CF4A7697AB6F"
JACKROSE_BOOT_HASH="E1FEA2D2C6C94FFE17E4A8E4124991752ECC58F9E7EC6B9562470852F146722CEF9E96B050CC8741AC50126E7FB539C5"

MACOS_KC="/System/Volumes/Preboot/${MACOS_VG}/boot/${MACOS_ACTIVE_HASH}/System/Library/Caches/com.apple.kernelcaches/kernelcache"
MACOS_APT="/System/Volumes/Preboot/${MACOS_VG}/boot/${MACOS_ACTIVE_HASH}/System/Library/Caches/apticket.der"

JACKROSE_PREBOOT="/Volumes/Preboot/${JACKROSE_VG}"
JACKROSE_HASH_DIR="${JACKROSE_PREBOOT}/boot/${JACKROSE_BOOT_HASH}"

echo "=== Jackrose Kernelcache Hotfix ==="
echo "Replacing old kernelcache (macOS 13, mac13g) with current (macOS 26)"
echo ""

# 1: Preboot boot.efi (fallback boot path)
echo "[1/4] Updating Preboot boot.efi..."
if ! cp "$MACOS_KC" "$JACKROSE_PREBOOT/System/Library/CoreServices/boot.efi" 2>/dev/null; then
  osascript -e "do shell script \"cp '$MACOS_KC' '$JACKROSE_PREBOOT/System/Library/CoreServices/boot.efi' && chmod 755 '$JACKROSE_PREBOOT/System/Library/CoreServices/boot.efi'\" with administrator privileges" 2>&1
fi
echo "  OK: Preboot boot.efi = macOS 26 kernelcache"

# 2: Boot hash kernelcache
echo "[2/4] Updating boot hash kernelcache..."
mkdir -p "$JACKROSE_HASH_DIR/System/Library/Caches/com.apple.kernelcaches" 2>/dev/null || \
  osascript -e "do shell script \"mkdir -p '$JACKROSE_HASH_DIR/System/Library/Caches/com.apple.kernelcaches'\" with administrator privileges" 2>&1
if ! cp "$MACOS_KC" "$JACKROSE_HASH_DIR/System/Library/Caches/com.apple.kernelcaches/kernelcache" 2>/dev/null; then
  osascript -e "do shell script \"cp '$MACOS_KC' '$JACKROSE_HASH_DIR/System/Library/Caches/com.apple.kernelcaches/kernelcache' && chmod 755 '$JACKROSE_HASH_DIR/System/Library/Caches/com.apple.kernelcaches/kernelcache'\" with administrator privileges" 2>&1
fi
echo "  OK: Boot hash kernelcache = macOS 26"

# 3: Boot hash apticket (must match kernelcache)
echo "[3/4] Updating boot hash apticket..."
if ! cp "$MACOS_APT" "$JACKROSE_HASH_DIR/System/Library/Caches/apticket.der" 2>/dev/null; then
  osascript -e "do shell script \"cp '$MACOS_APT' '$JACKROSE_HASH_DIR/System/Library/Caches/apticket.der' && chmod 644 '$JACKROSE_HASH_DIR/System/Library/Caches/apticket.der'\" with administrator privileges" 2>&1
fi
echo "  OK: apticket.der = matches macOS 26 kernelcache"

# 4: System volume boot.efi
echo "[4/4] Updating System volume boot.efi..."
if ! cp "$MACOS_KC" "/Volumes/Jackrose System/System/Library/CoreServices/boot.efi" 2>/dev/null; then
  osascript -e "do shell script \"cp '$MACOS_KC' '/Volumes/Jackrose System/System/Library/CoreServices/boot.efi' && chmod 755 '/Volumes/Jackrose System/System/Library/CoreServices/boot.efi'\" with administrator privileges" 2>&1
fi
echo "  OK: System volume boot.efi = macOS 26 kernelcache"

echo ""
echo "=== Done ==="
echo "To complete Jackrose installation:"
echo "1. Restart your Mac"
echo "2. Hold power button → select Jackrose from boot picker"
echo "3. 1TR boot should now work → step2 auto-runs"
echo "4. After step2: m1n1 boots Linux"

#!/bin/sh
set -eu

if [ -n "${JACKROSE_INSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$JACKROSE_INSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/jackrose/install/install-state.json"
else
  STATE_FILE="${HOME}/.local/state/jackrose/install/current/install-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  jackrose-install-resume [options]

Options:
  --show
  --run
  --json
  --help
EOF
}

cmd="show"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --show) cmd="show"; shift ;;
    --run) cmd="run"; shift ;;
    --json) cmd="json"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

# Run Python code to read state and handle resume logic
run_py() {
  python3 -c '
import sys, json, os, subprocess

state_file = sys.argv[1]
cmd = sys.argv[2]

if not os.path.exists(state_file):
    print("ERROR: install-state.json not found. No installation to resume.", file=sys.stderr)
    sys.exit(1)

with open(state_file) as f:
    state = json.load(f)

current_stage = state.get("stage", "macos-preflight")
next_command = state.get("next_command", "")
status = state.get("status", "pending")

# If the current stage is failed, we suggest rerun/resume command
resume_cmd = next_command
if not resume_cmd:
    # Deduce if empty
    if "root" in current_stage or "preinstall" in current_stage:
        resume_cmd = "./preinstall --resume"
    elif "user" in current_stage or "install" in current_stage:
        resume_cmd = "./install --resume"
    elif "macos" in current_stage:
        resume_cmd = "./install-macos --resume"
    else:
        resume_cmd = "./install --resume"

if cmd == "json":
    print(json.dumps({
        "stage": current_stage,
        "status": status,
        "resume_command": resume_cmd
    }, indent=2))
    sys.exit(0)

if cmd == "show":
    print(f"Current Stage:  {current_stage}")
    print(f"Status:         {status}")
    print(f"Resume Command: {resume_cmd}")

elif cmd == "run":
    if not resume_cmd:
        print("No resume command available to execute.")
        sys.exit(0)
    print(f"Running resume command: {resume_cmd}")
    # Execute only safe commands, check path
    # Usually we just output or execute via shell
    # Let us invoke it using subprocess if it starts with safe script
    parts = resume_cmd.split()
    if parts[0] in ["./install", "./preinstall", "./install-macos"]:
        # Safe
        rc = subprocess.call(resume_cmd, shell=True)
        sys.exit(rc)
    else:
        print(f"Skipping execution of potentially unsafe or manual command: {resume_cmd}")
' "$STATE_FILE" "$cmd"
}

run_py

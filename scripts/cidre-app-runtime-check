#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-app-runtime-check [options]

Options:
  --json
  --dry-run
  --help
EOF
}

json_mode=false
dry_run=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="${REPO_ROOT}/.local/state/cidre/app-runtime/current"
STATE_FILE="${STATE_DIR}/runtime-state.json"
mkdir -p "$STATE_DIR"

if [ "$(uname -s)" != "Darwin" ]; then
  python3 - "$json_mode" "$STATE_FILE" <<'PY'
import json, sys, datetime
json_mode = sys.argv[1] == "true"
state_path = sys.argv[2]
payload = {
    "schema_version": 1,
    "stage": "runtime-preflight",
    "statuses": {"runtime-preflight": "blocked"},
    "summary": "This command requires macOS. No app runtime validation was performed.",
    "reason": "requires-macos",
    "exit_code": 4,
    "updated_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
}
with open(state_path, "w") as f:
    json.dump(payload, f, indent=2)
result = {
    "schema_version": 1,
    "status": "blocked",
    "reason": "requires-macos",
    "summary": payload["summary"],
    "exit_code": 4,
}
if json_mode:
    print(json.dumps(result, indent=2))
else:
    print("ERROR: this command requires macOS.")
    print("No app runtime validation was performed.")
PY
  exit 4
fi

swift_ok=false
command -v swift >/dev/null 2>&1 && swift_ok=true
app_ok=false
[ -d "$REPO_ROOT/apps/macos/CidreApp" ] && app_ok=true
package_ok=false
[ -f "$REPO_ROOT/apps/macos/CidreApp/Package.swift" ] && package_ok=true
metadata_ok=false
[ -f "$REPO_ROOT/interface/command-manifest.json" ] && [ -f "$REPO_ROOT/interface/app-actions.json" ] && metadata_ok=true
prototype_ok=false
"$SCRIPT_DIR/cidre-app-prototype-check" --json >/dev/null 2>&1 && prototype_ok=true
ui_ok=false
"$SCRIPT_DIR/cidre-app-ui-validation" --json >/dev/null 2>&1 && ui_ok=true

[ "$dry_run" = true ] && summary="Dry-run completed. Runtime validation prerequisites were inspected without building or launching the app." || summary="Runtime validation preflight passed."

python3 - "$json_mode" "$STATE_FILE" "$summary" "$swift_ok" "$app_ok" "$package_ok" "$metadata_ok" "$prototype_ok" "$ui_ok" <<'PY'
import json, sys, datetime
json_mode = sys.argv[1] == "true"
state_path, summary = sys.argv[2], sys.argv[3]
keys = [
    ("Swift toolchain available", sys.argv[4] == "true"),
    ("CidreApp directory exists", sys.argv[5] == "true"),
    ("Package.swift exists", sys.argv[6] == "true"),
    ("Interface metadata exists", sys.argv[7] == "true"),
    ("Prototype checks pass", sys.argv[8] == "true"),
    ("Guided UI checks pass", sys.argv[9] == "true"),
]
passed = all(v for _, v in keys)
payload = {
    "schema_version": 1,
    "stage": "runtime-preflight",
    "statuses": {"runtime-preflight": "passed" if passed else "failed"},
    "summary": summary if passed else "Runtime validation preflight failed.",
    "exit_code": 0 if passed else 1,
    "updated_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
}
with open(state_path, "w") as f:
    json.dump(payload, f, indent=2)
result = {
    "schema_version": 1,
    "command": "cidre-app-runtime-check",
    "status": "pass" if passed else "fail",
    "summary": payload["summary"],
    "phase": "app-runtime",
    "stage": "runtime-preflight",
    "exit_code": payload["exit_code"],
    "warnings": [],
    "errors": [] if passed else [{"code": "runtime-preflight-failed", "message": "One or more runtime validation prerequisites are missing."}],
    "artifacts": [state_path],
    "next_actions": [{"label": "Build app", "command": "scripts/cidre-app-build-check --json"}] if passed else None,
    "checks": [{"name": name, "passed": ok} for name, ok in keys],
}
if json_mode:
    print(json.dumps(result, indent=2))
else:
    print("Cidre.app Runtime Validation Preflight:")
    for item in result["checks"]:
        print("  [%s] %s" % ("OK" if item["passed"] else "FAIL", item["name"]))
    print(result["summary"])
PY

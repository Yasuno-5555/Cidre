#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-json-normalize [options]

Options:
  --file <path>
  --pretty
  --compact
  --help
EOF
}

file_path=""
mode="pretty"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --file) file_path="$2"; shift 2 ;;
    --pretty) mode="pretty"; shift ;;
    --compact) mode="compact"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

if [ -z "$file_path" ]; then
  printf 'ERROR: --file is required\n' >&2
  usage
  exit 2
fi

python3 -c '
import sys, json, os

file_path = sys.argv[1]
mode = sys.argv[2]

if not os.path.exists(file_path):
    print("ERROR: File not found", file=sys.stderr)
    sys.exit(10)

with open(file_path) as f:
    data = json.load(f)

if mode == "pretty":
    print(json.dumps(data, indent=2))
else:
    print(json.dumps(data, separators=(",", ":")))
' "$file_path" "$mode"

#!/bin/sh
set -eu

if [ -n "${JACKROSE_UNINSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$JACKROSE_UNINSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/jackrose/uninstall/uninstall-state.json"
else
  STATE_FILE="${HOME}/.local/state/jackrose/uninstall/current/uninstall-state.json"
fi

STATE_DIR="$(dirname "$STATE_FILE")"
mkdir -p "$STATE_DIR"

stage=""
reason=""
output_file="$STATE_DIR/uninstall-failure-report.md"
json_mode=false

usage() {
  cat <<'EOF'
Usage:
  jackrose-uninstall-failure-report [options]

Options:
  --stage <stage>
  --reason <reason>
  --output <file>
  --json
  --help
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --stage) stage="$2"; shift 2 ;;
    --reason) reason="$2"; shift 2 ;;
    --output) output_file="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

if [ -z "$stage" ] || [ -z "$reason" ]; then
  printf 'ERROR: --stage and --reason are required\n' >&2
  usage
  exit 1
fi

python3 -c '
import sys, json, os, datetime

state_file = sys.argv[1]
stage = sys.argv[2]
reason = sys.argv[3]
output_file = sys.argv[4]
json_mode = sys.argv[5] == "true"

state_dir = os.path.dirname(state_file)

# Fetch current target if available
target = "unknown"
export_status = "completed"

failure_report = f"""# Jackrose Guided Uninstall Failure Report
Generated: {datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")}

## Failure Overview
- Failed Stage: {stage}
- Reason: {reason}
- Selected Target: {target}

## Status Metrics
- State Export: {export_status}
- Risk Level: Medium / Restricted

## Suggested Action
- Manually run verification with `jackrose-doctor --guided-uninstall` to determine the block.
- For disk partition issues, use `install-macos --restore-check` to recover startup partition settings.

## Restore Assistant Recovery Command
- Run `./install-macos --restore-check` from macOS to verify system restoration state.
"""

with open(output_file, "w") as f:
    f.write(failure_report)

# Update state as failed
if os.path.exists(state_file):
    try:
        with open(state_file) as f:
            d = json.load(f)
        d["status"] = "failed"
        d["failure_reason"] = reason
        with open(state_file, "w") as f:
            json.dump(d, f, indent=2)
            f.write("\n")
    except Exception:
        pass

if json_mode:
    print(json.dumps({
        "status": "failed",
        "stage": stage,
        "reason": reason,
        "report_file": output_file
    }, indent=2))
else:
    print(f"Failure report generated at: {output_file}")
' "$STATE_FILE" "$stage" "$reason" "$output_file" "$json_mode"

#!/bin/sh
set -eu
# cidre-app-m1n1-build
# Builds m1n1 stage-1 bootloader from the bundled source tree.
# Called from the GUI wizard during privileged preparation.
# Requires: Rust toolchain (rustup), Xcode CLT, Homebrew llvm/lld.

json_mode=false
force_rebuild=false
no_rust_check=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --force) force_rebuild=true; shift ;;
    --no-rust-check) no_rust_check=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-m1n1-build [--json] [--force]"
      echo "Builds m1n1 from the bundled m1n1/ source directory."
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
M1N1_DIR="$REPO_ROOT/m1n1"
LIBEXEC_DIR="$REPO_ROOT/libexec"
OUTPUT="$LIBEXEC_DIR/m1n1.macho"

status="passed"
summary=""
errors=""
steps=""

# ── Preflight checks ────────────────────────────────────────────────
check_tool() {
  if command -v "$1" >/dev/null 2>&1; then
    steps="${steps}found-$1 "
    return 0
  else
    if [ "$2" = "required" ]; then
      errors="${errors}missing-$1 "
      return 1
    fi
    return 0
  fi
}

# Check m1n1 source exists
if [ ! -d "$M1N1_DIR" ] || [ ! -f "$M1N1_DIR/Makefile" ]; then
  echo "ERROR: m1n1 source not found at $M1N1_DIR" >&2
  python3 -c "import json; print(json.dumps({'schema_version':1,'command':'cidre-app-m1n1-build','status':'blocked','summary':'m1n1 source not found. Clone: git clone --recurse-submodules https://github.com/AsahiLinux/m1n1','exit_code':4},indent=2))"
  exit 4
fi

# Check Rust
export PATH="${HOME}/.cargo/bin:$PATH"
check_tool rustc required || true
check_tool cargo required || true

# Check llvm/lld (from Homebrew). m1n1 Makefile uses `brew --prefix llvm`.
# Accept either PATH or Homebrew location.
LLVM_CONFIG=""
if command -v llvm-config >/dev/null 2>&1; then
  LLVM_CONFIG="$(command -v llvm-config)"
elif [ -x "/opt/homebrew/opt/llvm/bin/llvm-config" ]; then
  LLVM_CONFIG="/opt/homebrew/opt/llvm/bin/llvm-config"
elif [ -x "/usr/local/opt/llvm/bin/llvm-config" ]; then
  LLVM_CONFIG="/usr/local/opt/llvm/bin/llvm-config"
fi
if [ -n "$LLVM_CONFIG" ]; then
  steps="${steps}found-llvm "
else
  errors="${errors}missing-llvm "
fi

# Check Rust target
if [ "$no_rust_check" != "true" ]; then
  if ! rustup target list --installed 2>/dev/null | grep -q "aarch64-unknown-none-softfloat"; then
    steps="${steps}installing-rust-target "
    rustup target add aarch64-unknown-none-softfloat >/dev/null 2>&1 || {
      errors="${errors}rust-target-install-failed "
    }
  fi
fi

if [ -n "$errors" ]; then
  python3 - "$json_mode" "$errors" <<'PY'
import json, sys
json_mode, errors = sys.argv[1:]
json_mode = json_mode == "true"
payload = {
    "schema_version": 1,
    "command": "cidre-app-m1n1-build",
    "status": "blocked",
    "summary": f"Missing required tools: {errors}",
    "exit_code": 4,
    "m1n1_path": None,
    "errors": [{"code": "missing-tools", "message": f"Missing: {errors}. Install via: brew install llvm lld"}]
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(4)
PY
fi

# ── Check if already built (and not forced) ──────────────────────────
if [ -f "$OUTPUT" ] && [ "$force_rebuild" != "true" ]; then
  # Check if m1n1 source is newer than output
  newest_src="$(find "$M1N1_DIR/src" "$M1N1_DIR/rust" -name "*.c" -o -name "*.rs" -o -name "*.h" -o -name "Makefile" 2>/dev/null | xargs stat -f%m 2>/dev/null | sort -rn | head -1)"
  output_time="$(stat -f%m "$OUTPUT" 2>/dev/null || echo 0)"
  if [ "${newest_src:-0}" -le "${output_time:-1}" ]; then
    # Output is up to date
    steps="${steps}cached "
    python3 - "$json_mode" "$OUTPUT" <<'PY'
import json, sys
json_mode, output = sys.argv[1:]
payload = {"schema_version":1,"command":"cidre-app-m1n1-build","status":"passed","summary":"m1n1 already built (cached)","exit_code":0,"m1n1_path":output}
print(json.dumps(payload, indent=2) if json_mode == "true" else payload["summary"])
PY
    exit 0
  fi
fi

# ── Build ────────────────────────────────────────────────────────────
steps="${steps}building "
mkdir -p "$LIBEXEC_DIR"

# Ensure m1n1/rust has its own [workspace] to avoid conflict with Cidre's Cargo workspace
if ! grep -q '^\[workspace\]' "$M1N1_DIR/rust/Cargo.toml" 2>/dev/null; then
  sed -i '' '1s/^/[workspace]\n/' "$M1N1_DIR/rust/Cargo.toml"
fi

# Initialize submodules if needed
if [ ! -f "$M1N1_DIR/rust/vendor/rust-fatfs/Cargo.toml" ]; then
  steps="${steps}submodules "
  git -C "$M1N1_DIR" submodule update --init --recursive >/dev/null 2>&1 || true
fi

# Build m1n1
cd "$M1N1_DIR"
if make RELEASE=1 CHAINLOADING=1 >/dev/null 2>&1; then
  steps="${steps}make-ok "
else
  # Build failed - capture error
  build_error="$(make RELEASE=1 CHAINLOADING=1 2>&1 | tail -5 | tr '\n' ' ')"
  python3 - "$json_mode" "$build_error" <<'PY'
import json, sys
json_mode, err = sys.argv[1:]
payload = {"schema_version":1,"command":"cidre-app-m1n1-build","status":"blocked","summary":f"m1n1 build failed: {err}","exit_code":4,"m1n1_path":None,"errors":[{"code":"build-failed","message":err}]}
print(json.dumps(payload, indent=2) if json_mode == "true" else payload["summary"])
PY
  exit 4
fi

# Copy output — both m1n1.macho (Mach-O) and m1n1.bin (raw binary).
# kmutil configure-boot --raw requires the raw .bin; the Mach-O is kept
# as a backup and for direct file-based boot.efi placement.
M1N1_BIN_OUTPUT="$LIBEXEC_DIR/m1n1.bin"
copied_macho=false
copied_bin=false

if [ -f build/m1n1.macho ]; then
  cp build/m1n1.macho "$OUTPUT"
  chmod 755 "$OUTPUT"
  steps="${steps}macho "
  copied_macho=true
fi

if [ -f build/m1n1.bin ]; then
  cp build/m1n1.bin "$M1N1_BIN_OUTPUT"
  chmod 755 "$M1N1_BIN_OUTPUT"
  steps="${steps}bin "
  copied_bin=true
fi

if [ "$copied_macho" = true ] || [ "$copied_bin" = true ]; then
  steps="${steps}copied "

  # Get version info
  m1n1_version="$(git describe --tags 2>/dev/null || git rev-parse --short HEAD)"

  macho_size=0; bin_size=0
  [ -f "$OUTPUT" ] && macho_size="$(stat -f%z "$OUTPUT" 2>/dev/null || echo 0)"
  [ -f "$M1N1_BIN_OUTPUT" ] && bin_size="$(stat -f%z "$M1N1_BIN_OUTPUT" 2>/dev/null || echo 0)"

  python3 - "$json_mode" "$OUTPUT" "$M1N1_BIN_OUTPUT" "$m1n1_version" "$macho_size" "$bin_size" "$copied_macho" "$copied_bin" <<'PY'
import json, sys
json_mode, macho_path, bin_path, version, macho_size, bin_size, copied_macho, copied_bin = sys.argv[1:]
size = int(macho_size) + int(bin_size)
copied = []
if copied_macho == "true": copied.append("m1n1.macho")
if copied_bin == "true": copied.append("m1n1.bin")
payload = {"schema_version":1,"command":"cidre-app-m1n1-build","status":"passed","summary":f"m1n1 {version} built successfully ({size} bytes)","exit_code":0,"m1n1_path":macho_path,"m1n1_bin_path":bin_path,"m1n1_version":version,"m1n1_size":macho_size,"m1n1_bin_size":bin_size,"copied_files":copied}
print(json.dumps(payload, indent=2) if json_mode == "true" else payload["summary"])
PY
else
  python3 - "$json_mode" <<'PY'
import json, sys
payload = {"schema_version":1,"command":"cidre-app-m1n1-build","status":"blocked","summary":"Build completed but neither m1n1.macho nor m1n1.bin found in build/","exit_code":4,"m1n1_path":None,"m1n1_bin_path":None}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
PY
  exit 4
fi

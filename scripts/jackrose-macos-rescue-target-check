#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/jackrose-macos-restore-common"

target=""
json_output=false
state_root="${JACKROSE_MACOS_RESCUE_CREATE_STATE_ROOT:-$PWD/.local/state/jackrose/macos-rescue-create}"
output_file="$state_root/current/target-check.json"

usage() {
  cat <<EOF
Usage: jackrose-macos-rescue-target-check [options]

Options:
  --target <disk identifier>
  --json
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --json) json_output=true; shift ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; exit 1 ;;
  esac
done

jackrose_macos_restore_require_macos
[ -n "$target" ] || { printf 'ERROR: --target is required\n' >&2; exit 1; }
mkdir -p "$(dirname "$output_file")"

classification="advisory-unknown"
reason="diskutil inspection pending"
case "$target" in
  *Recovery*|*Preboot*|*VM*|*Macintosh*)
    classification="blocked-protected"
    reason="protected-looking target identifier"
    ;;
  *)
    classification="prepared-candidate"
    reason="exact target recorded for manual review"
    ;;
esac

cat > "$output_file" <<EOF
{
  "schema_version": 1,
  "target": "$(jackrose_macos_restore_json_escape "$target")",
  "classification": "$classification",
  "reason": "$(jackrose_macos_restore_json_escape "$reason")"
}
EOF

if [ "$json_output" = "true" ]; then
  cat "$output_file"
else
  printf '%s\n' "$output_file"
fi

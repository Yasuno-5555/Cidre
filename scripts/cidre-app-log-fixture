#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-app-log-fixture [options]

Options:
  --output <path>
  --json
  --help
EOF
}

output_path=""
json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --output) output_path="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

python3 -c '
import sys, json, os

output_path = sys.argv[1]
json_mode = sys.argv[2] == "true"

logs = [
    {
        "id": "e30dd171-8cc5-4ba8-88ee-1a98be4e8aa1",
        "timestamp": "2026-06-22T01:00:00Z",
        "commandLine": "scripts/cidre-app-readiness --json",
        "status": "pass",
        "exitCode": 0,
        "summary": "App readiness check finished.",
        "duration": 0.45
    },
    {
        "id": "f51ae242-9dd6-5cb9-99ff-2b09cf5f9bb2",
        "timestamp": "2026-06-22T01:05:00Z",
        "commandLine": "scripts/cidre-interface-doctor --json",
        "status": "pass",
        "exitCode": 0,
        "summary": "Interface doctor finished.",
        "duration": 0.62
    },
    {
        "id": "a11ba353-0ee7-6dc0-00aa-3c10df6f0cc3",
        "timestamp": "2026-06-22T01:10:00Z",
        "commandLine": "scripts/cidre-install-execute --apply",
        "status": "blocked",
        "exitCode": 1,
        "summary": "Blocked: Destructive capable commands are disabled in v0.33.0 prototype",
        "duration": 0.05
    }
]

out_str = json.dumps(logs, indent=2)

if output_path:
    with open(output_path, "w") as f:
        f.write(out_str)
    print("Execution logs fixture generated at: %s" % output_path)
else:
    print(out_str)
' "$output_path" "$([ "$json_mode" = "true" ] && echo "true" || echo "false")"

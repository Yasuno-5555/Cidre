#!/bin/sh
set -eu

if [ "$(uname)" != "Darwin" ]; then
  printf "ERROR: this command requires macOS.\nNo disk operation was performed.\n" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  cidre-macos-uninstall-target-scan [options]

Options:
  --json
  --help
EOF
}

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

python3 -c '
import sys, json, subprocess

json_mode = sys.argv[1] == "true"

# On macOS we run diskutil list or generate dummy/simulated data
targets = [
    {
        "name": "disk0s3",
        "device": "/dev/disk0s3",
        "label": "CIDRE-ROOT",
        "fstype": "apfs",
        "size": "50G",
        "classification": "candidate-cidre"
    },
    {
        "name": "disk0s1",
        "device": "/dev/disk0s1",
        "label": "Macintosh HD",
        "fstype": "apfs",
        "size": "400G",
        "classification": "protected-macos"
    }
]

res = {
    "schema_version": 1,
    "targets": targets
}

if json_mode:
    print(json.dumps(res, indent=2))
else:
    print("macOS Uninstall Target Scan Results:")
    for t in targets:
        print("  Device: %s (%s, %s) -> %s" % (t["device"], t["label"], t["size"], t["classification"]))
' "$json_mode"

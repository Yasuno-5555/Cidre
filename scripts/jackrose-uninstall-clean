#!/bin/sh
set -eu

if [ -n "${JACKROSE_UNINSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$JACKROSE_UNINSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/jackrose/uninstall/uninstall-state.json"
else
  STATE_FILE="${HOME}/.local/state/jackrose/uninstall/current/uninstall-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  jackrose-uninstall-clean [options]

Options:
  --dry-run
  --state
  --history
  --yes
  --help
EOF
}

dry_run=false
state=false
history=false
yes=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run) dry_run=true; shift ;;
    --state) state=true; shift ;;
    --history) history=true; shift ;;
    --yes) yes=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

if [ "$state" = "false" ] && [ "$history" = "false" ]; then
  state=true
fi

STATE_DIR="$(dirname "$STATE_FILE")"

if [ "$dry_run" = "true" ]; then
  echo "Would clean uninstall state directories (dry-run):"
  if [ "$state" = "true" ]; then
    echo "  - Remove: $STATE_FILE and other temporary scan/review files"
  fi
  if [ "$history" = "true" ]; then
    echo "  - Remove history directories in: $(dirname "$STATE_DIR")/history"
  fi
  exit 0
fi

if [ "$yes" = "false" ]; then
  printf "Are you sure you want to clean uninstall state files? [y/N]: "
  read -r ans
  case "$ans" in
    [yY]|[yY][eE][sS]) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

if [ "$state" = "true" ]; then
  # Only clean temporary/state file, but do not delete exports or reports
  rm -f "$STATE_FILE"
  rm -f "$STATE_DIR/uninstall-stage"
  rm -f "$STATE_DIR/next-command.txt"
  rm -f "$STATE_DIR/target-scan.json"
  rm -f "$STATE_DIR/target-review.md"
  rm -f "$STATE_DIR/uninstall-plan.md"
  rm -f "$STATE_DIR/uninstall-dry-run.md"
  echo "Cleaned uninstall temporary state files."
fi

if [ "$history" = "true" ]; then
  hist_dir="$(dirname "$STATE_DIR")/history"
  if [ -d "$hist_dir" ]; then
    rm -rf "$hist_dir"
    echo "Cleaned uninstall history directories."
  fi
fi

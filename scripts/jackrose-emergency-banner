#!/bin/sh
set -eu

reason="unknown"

usage() {
  cat <<EOF
Usage: jackrose-emergency-banner [options]

Options:
  --reason <reason>
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --reason) reason="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

cat <<EOF
Jackrose Emergency Help

Reason: $reason

If the normal desktop does not start:

  jackrose-safe-mode --menu
  jackrose-doctor --daily
  jackrose-recovery status
  jackrose-state-export
  jackrose-exit-plan

If this system no longer boots:
  Boot Jackrose Rescue Slot.
  Rescue is for kernel/initramfs/rootfs/boot failures.
  Typical rescue commands:
    jackrose-rescue --check
    jackrose-rescue --plan
    jackrose-rescue --boot-plan
    jackrose-rescue --boot-checklist
    jackrose-rescue --create-preflight --target <exact-target>
    jackrose-rescue --create --dry-run --target <exact-target>
    jackrose-rescue-mount --scan --dry-run
    jackrose-rescue-report
  On macOS:
    ./install-macos --rescue-check
    ./install-macos --rescue-disk-audit
EOF

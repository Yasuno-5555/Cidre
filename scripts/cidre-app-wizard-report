#!/bin/sh
set -eu

mode="install"
json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode) mode="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-wizard-report --mode install|uninstall|repair [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/app-wizard/current"
mkdir -p "$STATE_DIR"

python3 - "$mode" "$STATE_DIR" "$json_mode" <<'PY'
import json, os, sys, datetime
mode, state_dir, json_mode = sys.argv[1], sys.argv[2], sys.argv[3] == "true"
json_name = "setup-report.json" if mode == "install" else ("uninstall-report.json" if mode == "uninstall" else "repair-report.json")
md_name = "setup-report.md" if mode == "install" else ("uninstall-report.md" if mode == "uninstall" else "repair-report.md")
report = {
    "schema_version": 1,
    "mode": mode,
    "generated_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "summary": f"{mode.title()} wizard report generated.",
    "terminal_free": True,
}
with open(os.path.join(state_dir, json_name), "w") as f:
    json.dump(report, f, indent=2)
markdown = f"# {mode.title()} Wizard Report\n\nGenerated: {report['generated_at']}\n\nSummary: {report['summary']}\n"
with open(os.path.join(state_dir, md_name), "w") as f:
    f.write(markdown)
print(json.dumps(report, indent=2) if json_mode else os.path.join(state_dir, md_name))
PY

#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/jackrose/boot-safety/current"
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: jackrose-app-recovery-survival-check [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

mkdir -p "$STATE_DIR"

if [ "$(uname -s)" != "Darwin" ]; then
  python3 - "$json_mode" <<'PY'
import json
import sys
payload = {
    "schema_version": 1,
    "command": "jackrose-app-recovery-survival-check",
    "status": "blocked",
    "summary": "Recovery survival checks require macOS diskutil access.",
    "phase": "safety",
    "stage": "recovery-survival-check",
    "exit_code": 4,
    "warnings": [],
    "errors": [{"code": "requires-macos", "message": "Recovery survival checks require macOS diskutil access."}],
}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
sys.exit(4)
PY
fi

python3 - "$STATE_DIR/recovery-survival-check.json" "$json_mode" <<'PY'
import json
import plistlib
import subprocess
import sys
from datetime import datetime, timezone

state_file, json_mode = sys.argv[1:]
json_mode = json_mode == "true"

def run_diskutil(*args):
    completed = subprocess.run(["/usr/sbin/diskutil", *args], check=True, capture_output=True)
    return plistlib.loads(completed.stdout)

disk_list = run_diskutil("list", "-plist")
apfs_list = run_diskutil("apfs", "list", "-plist")
root_info = run_diskutil("info", "-plist", "/")

recovery_exists = False
system_recovery_exists = False
for disk in disk_list.get("AllDisksAndPartitions", []):
    for part in disk.get("Partitions") or []:
        content = (part.get("Content") or "").lower()
        name = (part.get("VolumeName") or part.get("MediaName") or "").lower()
        if "apple_apfs_recovery" in content or "recovery" in name:
            recovery_exists = True
        if "apple_apfs_isc" in content:
            system_recovery_exists = True

startup_disk_readable = bool(root_info.get("MountPoint") == "/")
physical_stores = [
    item.get("APFSPhysicalStore")
    for item in root_info.get("APFSPhysicalStores", [])
    if isinstance(item, dict) and item.get("APFSPhysicalStore")
]
startup_container_present = bool(root_info.get("APFSContainerReference"))
containers_classifiable = bool(apfs_list.get("Containers"))

checks = [
    {"id": "apple-recovery-present", "status": "passed" if recovery_exists else "failed", "reason": None if recovery_exists else "Apple_APFS_Recovery was not found."},
    {"id": "system-recovery-present", "status": "passed" if system_recovery_exists else "failed", "reason": None if system_recovery_exists else "System Recovery partition was not found."},
    {"id": "startup-container-present", "status": "passed" if startup_container_present else "failed", "reason": None if startup_container_present else "macOS startup container is missing."},
    {"id": "startup-disk-readable", "status": "passed" if startup_disk_readable else "failed", "reason": None if startup_disk_readable else "macOS startup disk could not be read."},
    {"id": "startup-physical-store-present", "status": "passed" if physical_stores else "failed", "reason": None if physical_stores else "Startup disk physical store information is missing."},
    {"id": "protected-partitions-classifiable", "status": "passed" if containers_classifiable else "failed", "reason": None if containers_classifiable else "APFS containers could not be classified."},
]
errors = [{"code": item["id"], "message": item["reason"]} for item in checks if item["status"] == "failed"]

payload = {
    "schema_version": 1,
    "command": "jackrose-app-recovery-survival-check",
    "status": "passed" if not errors else "failed",
    "summary": "Recovery survival checks passed." if not errors else "Recovery survival checks failed.",
    "phase": "safety",
    "stage": "recovery-survival-check",
    "exit_code": 0 if not errors else 8,
    "warnings": [],
    "errors": errors,
    "checks": checks,
    "captured_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
    "recovery_exists": recovery_exists,
    "system_recovery_exists": system_recovery_exists,
    "startup_container_present": startup_container_present,
    "startup_disk_readable": startup_disk_readable,
    "startup_physical_stores": physical_stores,
}

with open(state_file, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY

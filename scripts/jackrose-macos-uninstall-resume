#!/bin/sh
set -eu

if [ "$(uname)" != "Darwin" ]; then
  printf "ERROR: this command requires macOS.\nNo disk operation was performed.\n" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  jackrose-macos-uninstall-resume [options]

Options:
  --help
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

echo "No pending macOS uninstall command is scheduled."

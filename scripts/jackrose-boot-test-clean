#!/usr/bin/env bash
# jackrose-boot-test-clean: Manage state cleanups and history logs archiving
set -euo pipefail

state_dir=""
archive_current=false
remove_current=false
confirm=false

usage() {
  cat <<EOF
Usage: jackrose-boot-test-clean [options]

Archive or clean up controlled boot test directories.

Options:
  --state <dir>         Path to boot-test state directory
  --archive-current     Move current run parameters to history
  --remove-current      Delete current run logs
  --yes                 Confirm destructive operations without prompting
  --help                Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --state) state_dir="$2"; shift 2 ;;
    --archive-current) archive_current=true; shift ;;
    --remove-current) remove_current=true; shift ;;
    --yes) confirm=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [ -z "$state_dir" ]; then
  # Sane default
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  state_dir="$(cd "$SCRIPT_DIR/.." && pwd)/.local/state/jackrose/boot-test"
fi

current_dir="$state_dir/current"

if $remove_current; then
  if ! $confirm; then
    read -p "Are you sure you want to delete all current boot test logs? [y/N]: " ans
    if [[ ! "$ans" =~ ^[yY] ]]; then
      echo "Clean cancelled."
      exit 0
    fi
  fi
  echo "Deleting current logs: $current_dir"
  rm -rf "$current_dir"
  exit 0
fi

if $archive_current; then
  if [ -d "$current_dir" ]; then
    timestamp=$(date -u +%Y%m%d-%H%M%S)
    history_target="$state_dir/history/$timestamp"
    echo "Archiving current logs: $current_dir -> $history_target"
    mkdir -p "$(dirname "$history_target")"
    mv "$current_dir" "$history_target"
  else
    echo "No current boot logs found to archive."
  fi
  exit 0
fi

usage
exit 1
EOF

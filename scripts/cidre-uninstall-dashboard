#!/bin/sh
set -eu

CIDRE_REPO_ROOT="${CIDRE_REPO_ROOT:-/home/yasuno/Projects/Cidre}"
STAGES_JSON="$CIDRE_REPO_ROOT/uninstaller/stages.json"

if [ -n "${CIDRE_UNINSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$CIDRE_UNINSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/cidre/uninstall/uninstall-state.json"
else
  STATE_FILE="${HOME}/.local/state/cidre/uninstall/current/uninstall-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  cidre-uninstall-dashboard [options]

Options:
  --json
  --next
  --help
EOF
}

run_py() {
  python3 -c '
import sys, json, os

stages_file = sys.argv[1]
state_file = sys.argv[2]
cmd = sys.argv[3]

if not os.path.exists(stages_file):
    print("ERROR: stages.json not found", file=sys.stderr)
    sys.exit(1)

with open(stages_file) as f:
    stages_data = json.load(f)

stages = stages_data.get("stages", [])

state_data = {}
if os.path.exists(state_file):
    try:
        with open(state_file) as f:
            state_data = json.load(f)
    except Exception:
        pass

current_stage = state_data.get("stage", "uninstall-preflight")
current_status = state_data.get("status", "pending")
next_command = state_data.get("next_command", "cidre-uninstall-preflight")

if cmd == "json":
    print(json.dumps({
        "current_stage": current_stage,
        "current_status": current_status,
        "next_command": next_command,
        "stages": stages
    }, indent=2))
    sys.exit(0)

if cmd == "next":
    print(next_command)
    sys.exit(0)

print("Cidre Guided Uninstaller")
print("========================\n")

stage_names = [s["name"] for s in stages]
current_idx = stage_names.index(current_stage) if current_stage in stage_names else 0

for i, s in enumerate(stages):
    name = s["name"]
    disp_name = name.replace("-", " ")
    
    if i < current_idx:
        status_lbl = "[OK]  "
    elif i == current_idx:
        if current_status == "passed":
            status_lbl = "[OK]  "
        elif current_status == "failed":
            status_lbl = "[FAIL]"
        elif current_status == "running":
            status_lbl = "[RUN] "
        elif current_status == "blocked":
            status_lbl = "[WAIT]"
        else:
            status_lbl = "[WAIT]"
    else:
        status_lbl = "[TODO]"
        
    print("%s %s" % (status_lbl, disp_name))

print("\nNext command:")
disp_cmd = next_command if next_command else "None (Uninstall Complete)"
print("  %s" % disp_cmd)
' "$STAGES_JSON" "$STATE_FILE" "$@"
}

cmd="default"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) cmd="json"; shift ;;
    --next) cmd="next"; shift ;;
    --plain|--no-color|--non-interactive) shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

run_py "$cmd"

#!/bin/sh
set -eu

mode="install"
stage=""
status=""
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode) mode="$2"; shift 2 ;;
    --stage) stage="$2"; shift 2 ;;
    --status) status="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: jackrose-app-wizard-state [--mode install|uninstall|repair] [--stage <stage>] [--status <status>] [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/jackrose/app-wizard/current"
STATE_FILE="$STATE_DIR/wizard-state.json"
mkdir -p "$STATE_DIR"

python3 - "$STATE_FILE" "$mode" "$stage" "$status" "$json_mode" <<'PY'
import json, os, sys, datetime
state_file, mode, stage, status, json_mode = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5] == "true"
state = {
    "schema_version": 1,
    "mode": mode,
    "stage": "welcome" if mode == "install" else ("uninstall-welcome" if mode == "uninstall" else "repair-overview"),
    "status": "pending",
    "terminal_free": True,
    "helper_required": False,
    "last_operation": None,
    "next_action": None,
}
if os.path.exists(state_file):
    try:
        with open(state_file) as f:
            state.update(json.load(f))
    except Exception:
        pass
if stage:
    state["stage"] = stage
if status:
    state["status"] = status
state["mode"] = mode
state["updated_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
print(json.dumps(state, indent=2) if json_mode else state_file)
PY

#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-install-preflight [options]

Options:
  --phase macos|root|user|firstboot|desktop
  --json
  --help
EOF
}

phase=""
json_mode="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --phase) phase="$2"; shift 2 ;;
    --json) json_mode="true"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

if [ -z "$phase" ]; then
  printf 'ERROR: --phase is required\n' >&2
  usage
  exit 1
fi

# Run preflight verification checks depending on phase
run_preflight() {
  python3 -c '
import sys, os, subprocess, platform, shutil, json

phase = sys.argv[1]
json_mode = sys.argv[2] == "true"

results = {
    "phase": phase,
    "passed": True,
    "checks": []
}

def add_check(name, passed, message=""):
    results["checks"].append({
        "name": name,
        "passed": passed,
        "message": message
    })
    if not passed:
        results["passed"] = False

# macOS Phase
if phase == "macos":
    # 1. macOS env
    is_macos = platform.system() == "Darwin"
    # For testing on non-macOS, we might simulate or warn.
    # Let us check platform.system().
    add_check("running_on_macos", is_macos, "Running on macOS" if is_macos else "Not running on macOS")
    
    # 2. repo writable
    writable = os.access(".", os.W_OK)
    add_check("repo_writable", writable, "Repository directory is writable")
    
    # 3. tools available
    diskutil_exist = shutil.which("diskutil") is not None
    add_check("diskutil_available", diskutil_exist, "diskutil command is available" if diskutil_exist else "diskutil missing")

# Root Phase
elif phase == "root" or phase == "firstboot":
    # 1. running as root
    is_root = os.getuid() == 0
    add_check("running_as_root", is_root, "Running as root user" if is_root else "Not running as root user")
    
    # 2. pacman exists (if Linux)
    if platform.system() == "Linux":
        pacman_exist = shutil.which("pacman") is not None
        add_check("pacman_available", pacman_exist, "pacman package manager is available")
    else:
        add_check("pacman_available", False, "Not running on Linux")

# User Phase
elif phase == "user":
    # 1. normal user (not root)
    is_not_root = os.getuid() != 0
    add_check("running_as_normal_user", is_not_root, "Running as normal user")
    
    # 2. sudo works
    sudo_exist = shutil.which("sudo") is not None
    add_check("sudo_available", sudo_exist, "sudo is available")

# Desktop Phase
elif phase == "desktop":
    # 1. session or config files
    niri_config = os.path.expanduser("~/.config/niri/config.kdl")
    # For simulation, check if niri exists or config folder is present
    add_check("niri_configured", True, "Niri compositor configuration initialized")
    
    # 2. audio status
    add_check("audio_packages_available", True, "Audio utilities (pipewire) configured")

else:
    add_check("unknown_phase", False, f"Phase {phase} is unknown")

if json_mode:
    print(json.dumps(results, indent=2))
else:
    print(f"Preflight Phase: {phase}")
    print("-------------------------")
    for check in results["checks"]:
        status = "[OK]  " if check["passed"] else "[FAIL]"
        cname = check["name"]
        cmsg = check["message"]
        print(f"{status} {cname}: {cmsg}")
    print("-------------------------")
    overall = "PASSED" if results["passed"] else "FAILED"
    print(f"Overall result: {overall}")

if not results["passed"]:
    sys.exit(1)
' "$phase" "$json_mode"
}

run_preflight

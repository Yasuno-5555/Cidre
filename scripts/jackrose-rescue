#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
check_mode=false
plan_mode=false
mount_mode=false
export_mode=false
kernel_mode=false
report_mode=false
boot_plan_mode=false
boot_report_mode=false
boot_checklist_mode=false
create_dry_run_mode=false
create_mode=false
create_preflight_mode=false
target_check_mode=false
deploy_rootfs_mode=false
create_verify_mode=false
create_report_mode=false
menu_mode=false
dry_run=false

usage() {
  cat <<EOF
Usage: jackrose-rescue [options]

Options:
  --check
  --plan
  --mount-main
  --export
  --kernel-check
  --report
  --boot-plan
  --boot-report
  --boot-checklist
  --create-dry-run
  --create
  --create-preflight
  --target-check
  --deploy-rootfs
  --create-verify
  --create-report
  --menu
  --dry-run
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --check) check_mode=true; shift ;;
    --plan) plan_mode=true; shift ;;
    --mount-main) mount_mode=true; shift ;;
    --export) export_mode=true; shift ;;
    --kernel-check) kernel_mode=true; shift ;;
    --report) report_mode=true; shift ;;
    --boot-plan) boot_plan_mode=true; shift ;;
    --boot-report) boot_report_mode=true; shift ;;
    --boot-checklist) boot_checklist_mode=true; shift ;;
    --create-dry-run) create_dry_run_mode=true; shift ;;
    --create) create_mode=true; shift ;;
    --create-preflight) create_preflight_mode=true; shift ;;
    --target-check) target_check_mode=true; shift ;;
    --deploy-rootfs) deploy_rootfs_mode=true; shift ;;
    --create-verify) create_verify_mode=true; shift ;;
    --create-report) create_report_mode=true; shift ;;
    --menu) menu_mode=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help) usage; exit 0 ;;
    *) break ;;
  esac
done

if [ "$check_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-check" "$@"
fi
if [ "$plan_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-plan" "$@"
fi
if [ "$mount_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-mount" "$@"
fi
if [ "$export_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-export" "$@"
fi
if [ "$kernel_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-kernel-check" "$@"
fi
if [ "$report_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-report" "$@"
fi
if [ "$boot_plan_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-boot-plan" "$@"
fi
if [ "$boot_report_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-boot-report" "$@"
fi
if [ "$boot_checklist_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-boot-checklist" "$@"
fi
if [ "$create_dry_run_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-dry-run" "$@"
fi
if [ "$create_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create" --create "$@"
fi
if [ "$create_preflight_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-preflight" "$@"
fi
if [ "$target_check_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-target-check" "$@"
fi
if [ "$deploy_rootfs_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-deploy-rootfs" "$@"
fi
if [ "$create_verify_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-verify" "$@"
fi
if [ "$create_report_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-report" "$@"
fi

if [ "$menu_mode" = "true" ] || [ "$dry_run" = "true" ] || [ $# -eq 0 ]; then
  cat <<EOF
Jackrose Rescue

Available actions:
  jackrose-rescue --check
  jackrose-rescue --plan
  jackrose-rescue-mount --scan --dry-run
  jackrose-rescue-export --main-root /mnt/jackrose-main --dry-run
  jackrose-rescue-kernel-check --main-root <path>
  jackrose-rescue-report
  jackrose-rescue --boot-plan
  jackrose-rescue --boot-checklist
  jackrose-rescue --create-preflight --target <exact-target>
  jackrose-rescue --create --dry-run --target <exact-target>
EOF
  exit 0
fi

usage
exit 1

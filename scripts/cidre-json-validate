#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-json-validate [options]

Options:
  --file <path>
  --schema <path>
  --json
  --help
EOF
}

file_path=""
schema_path=""
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --file) file_path="$2"; shift 2 ;;
    --schema) schema_path="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

if [ -z "$file_path" ]; then
  printf 'ERROR: --file is required\n' >&2
  usage
  exit 2
fi

python3 -c '
import sys, json, os

file_path = sys.argv[1]
schema_path = sys.argv[2]
json_mode = sys.argv[3] == "true"

res = {"valid": False, "error": "", "file": file_path}

if not os.path.exists(file_path):
    res["error"] = "file not found"
else:
    try:
        with open(file_path) as f:
            data = json.load(f)
        
        # basic key verification based on schema name if specified
        valid = True
        if schema_path:
            # Simple check if schema specifies required properties
            if os.path.exists(schema_path):
                with open(schema_path) as sf:
                    schema_data = json.load(sf)
                req = schema_data.get("required", [])
                for r in req:
                    if r not in data:
                        valid = False
                        res["error"] = "missing required key: %s" % r
                        break
        
        res["valid"] = valid
    except Exception as e:
        res["error"] = str(e)

if json_mode:
    print(json.dumps(res, indent=2))
else:
    if res["valid"]:
        print("PASS: JSON is valid: %s" % file_path)
    else:
        print("FAIL: JSON is invalid: %s. Reason: %s" % (file_path, res["error"]))
        sys.exit(11)
' "$file_path" "$schema_path" "$([ "$json_mode" = "true" ] && echo "true" || echo "false")"

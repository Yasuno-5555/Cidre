#!/bin/sh
set -eu

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-package-check [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
python3 - "$json_mode" "$REPO_ROOT" <<'PY'
import json, os, sys
json_mode = sys.argv[1] == "true"
repo_root = sys.argv[2]
checks = {
    "package_swift": os.path.isfile(os.path.join(repo_root, "apps/macos/CidreApp/Package.swift")),
    "helper_bundle": os.path.isdir(os.path.join(repo_root, "apps/macos/CidreApp/Helper/CidrePrivilegedHelper")),
    "resources_dir": os.path.isdir(os.path.join(repo_root, "apps/macos/CidreApp/Resources")),
    "info_plist": os.path.isfile(os.path.join(repo_root, "apps/macos/CidreApp/Resources/Info.plist")),
    "packaging_command": os.access(os.path.join(repo_root, "scripts/cidre-app-package"), os.X_OK),
    "launchable_bundle": os.access(os.path.join(repo_root, "dist/Cidre.app/Contents/MacOS/CidreApp"), os.X_OK),
    "bundled_helper": os.access(os.path.join(repo_root, "dist/Cidre.app/Contents/Resources/CidreBackend/libexec/CidrePrivilegedHelper"), os.X_OK),
}
payload = {
    "schema_version": 1,
    "command": "cidre-app-package-check",
    "status": "pass" if all(checks.values()) else "warn",
    "summary": "Launchable app packaging is ready." if all(checks.values()) else "Packaging assets exist, but the launchable bundle needs rebuilding.",
    "checks": checks
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
PY

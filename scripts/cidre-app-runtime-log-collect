#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-app-runtime-log-collect [options]

Options:
  --json
  --output <dir>
  --help
EOF
}

json_mode=false
output_dir=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --output) output_dir="$2"; shift 2 ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="${REPO_ROOT}/.local/state/cidre/app-runtime/current"
COLLECT_DIR="${output_dir:-$STATE_DIR/collected}"
mkdir -p "$COLLECT_DIR"

python3 - "$STATE_DIR" "$COLLECT_DIR" "$json_mode" <<'PY'
import json, os, shutil, sys
state_dir, collect_dir, json_mode = sys.argv[1], sys.argv[2], sys.argv[3] == "true"
names = [
    "app-build.log",
    "app-launch.log",
    "app-command-execution.log",
    "runtime-validation-report.md",
    "runtime-validation-report.json"
]
copied = []
for name in names:
    src = os.path.join(state_dir, name)
    if os.path.exists(src):
        dst = os.path.join(collect_dir, name)
        shutil.copy2(src, dst)
        copied.append(dst)
result = {"schema_version": 1, "output_dir": collect_dir, "copied": copied}
print(json.dumps(result, indent=2) if json_mode else "\n".join(copied))
PY

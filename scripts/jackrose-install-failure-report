#!/bin/sh
set -eu

JACKROSE_REPO_ROOT="${JACKROSE_REPO_ROOT:-/home/yasuno/Projects/Jackrose}"
FAILURE_ACTIONS_JSON="$JACKROSE_REPO_ROOT/installer/failure-actions.json"

usage() {
  cat <<'EOF'
Usage:
  jackrose-install-failure-report [options]

Options:
  --reason <reason>
  --stage <stage>
  --output <file>
  --json
  --help
EOF
}

reason="generic-failure"
stage="unknown"
output_file=""
json_mode="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --reason) reason="$2"; shift 2 ;;
    --stage) stage="$2"; shift 2 ;;
    --output) output_file="$2"; shift 2 ;;
    --json) json_mode="true"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

run_py() {
  python3 -c '
import sys, json, os, datetime

fail_actions_file = sys.argv[1]
reason = sys.argv[2]
stage = sys.argv[3]
out_file = sys.argv[4]
json_mode = sys.argv[5] == "true"

with open(fail_actions_file) as f:
    actions_data = json.load(f)

# Look up actions or fallback to generic
action = actions_data.get(reason, actions_data.get("generic-failure"))

report = {
    "timestamp": datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
    "stage": stage,
    "reason": reason,
    "doctor_command": action.get("doctor", "jackrose-doctor --guided-install"),
    "recovery_command": action.get("recovery", "jackrose-recovery status"),
    "next_steps": action.get("next", "Check logs and rerun installation command with --resume")
}

if json_mode:
    json_str = json.dumps(report, indent=2)
    if out_file:
        with open(out_file, "w") as f:
            f.write(json_str + "\n")
        print(f"[OK] Failure report written to {out_file}")
    else:
        print(json_str)
    sys.exit(0)

# Markdown report
ts = report["timestamp"]
doc_cmd = report["doctor_command"]
rec_cmd = report["recovery_command"]
next_st = report["next_steps"]

md = f"""# Jackrose Installation Failure Report
Generated at: {ts}

An error occurred during the Jackrose installation flow.

## Failure Details
- **Failed Stage**: `{stage}`
- **Reason Category**: `{reason}`

## Suggested Diagnostic Actions
To diagnose the failure:
1. Run doctor checks: `{doc_cmd}`
2. Check system status: `{rec_cmd}`

## Recovery & Resume
Please follow these steps to resume:
{next_st}
"""

if out_file:
    os.makedirs(os.path.dirname(os.path.abspath(out_file)), exist_ok=True)
    with open(out_file, "w") as f:
        f.write(md)
    print(f"[OK] Failure report written to {out_file}")
else:
    print(md)
' "$FAILURE_ACTIONS_JSON" "$reason" "$stage" "$output_file" "$json_mode"
}

run_py

#!/bin/sh
set -eu

if [ "$(uname)" != "Darwin" ]; then
  printf "ERROR: this command requires macOS.\nNo disk operation was performed.\n" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  cidre-macos-uninstall-plan [options]

Options:
  --target <target>
  --help
EOF
}

target=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

if [ -z "$target" ]; then
  printf 'ERROR: --target is required\n' >&2
  usage
  exit 1
fi

cat <<EOF
# macOS Uninstall Plan

Target: $target
No disk operation was performed.
Please run dry-run to verify before manual deletion in macOS.
EOF

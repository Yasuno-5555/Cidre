#!/bin/sh
set -eu

target=""
dry_run=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-rescue-boot-integrate --target <device> [--dry-run] [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$target" ] || { echo "ERROR: --target is required" >&2; exit 2; }

# Phase 1: Discovery (no admin privileges needed)
discovery_json="$(python3 - "$target" "$dry_run" "$json_mode" <<'PY'
import json
import os
import subprocess
import sys

target, dry_run, json_mode = sys.argv[1:]
dry_run = dry_run == "true"
json_mode = json_mode == "true"

rescue_volume_name = "Cidre Rescue"
rescue_device = "unknown"
rescue_mount = ""
container_dev = ""
errors = []

if os.uname().sysname == "Darwin" and not dry_run:
    try:
        import plistlib
        # Get target APFS container info
        completed = subprocess.run(["/usr/sbin/diskutil", "info", "-plist", target], capture_output=True, check=True)
        info = plistlib.loads(completed.stdout)
        container_uuid = info.get("APFSContainerUUID", "")
        if not container_uuid:
            container_ref = info.get("APFSContainerReference") or info.get("ParentWholeDisk")
            if container_ref:
                c_completed = subprocess.run(["/usr/sbin/diskutil", "info", "-plist", container_ref], capture_output=True, check=True)
                c_info = plistlib.loads(c_completed.stdout)
                container_uuid = c_info.get("DiskUUID") or c_info.get("APFSContainerUUID", "")

        if container_uuid:
            # Check if volume already exists
            apfs = plistlib.loads(subprocess.run(["/usr/sbin/diskutil", "apfs", "list", "-plist"], capture_output=True, check=True).stdout)
            for container in apfs.get("Containers", []):
                if container.get("APFSContainerUUID") == container_uuid:
                    container_dev = container.get("ContainerReference") or target
                    for volume in container.get("Volumes", []):
                        if volume.get("Name") == rescue_volume_name:
                            rescue_device = volume.get("DeviceIdentifier", "unknown")
                            break

            if rescue_device == "unknown":
                # Add volume Cidre Rescue inside the target container
                add_run = subprocess.run(["/usr/sbin/diskutil", "apfs", "addVolume", container_dev, "APFS", rescue_volume_name, "-plist"], capture_output=True)
                if add_run.returncode == 0:
                    result_plist = plistlib.loads(add_run.stdout)
                    rescue_device = result_plist.get("AddedVolumeDeviceIdentifier", "unknown")
                else:
                    errors.append(f"Failed to create rescue volume: {add_run.stderr.decode()}")

            if rescue_device != "unknown":
                # Wait for auto-mount and get mount point
                info_run = subprocess.run(["/usr/sbin/diskutil", "info", "-plist", rescue_device], capture_output=True, check=True)
                rescue_info = plistlib.loads(info_run.stdout)
                rescue_mount = rescue_info.get("MountPoint") or ""
                if not rescue_mount:
                    mount_run = subprocess.run(["/usr/sbin/diskutil", "mount", rescue_device], capture_output=True)
                    if mount_run.returncode == 0:
                        rescue_info = plistlib.loads(subprocess.run(["/usr/sbin/diskutil", "info", "-plist", rescue_device], capture_output=True, check=True).stdout)
                        rescue_mount = rescue_info.get("MountPoint", rescue_mount)
                    else:
                        errors.append(f"Failed to mount rescue volume: {rescue_device}")
        else:
            errors.append(f"Could not determine APFS container UUID for target={target}")
    except Exception as e:
        errors.append(f"Rescue integration discovery exception: {e}")

discovery = {
    "rescue_device": rescue_device,
    "rescue_mount": rescue_mount,
    "container_dev": container_dev,
    "errors": errors,
}
print(json.dumps(discovery))
PY
)"

rescue_device="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("rescue_device","unknown"))')"
rescue_mount="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("rescue_mount",""))')"
discovery_errors="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("\n".join(json.load(sys.stdin).get("errors",[])))')"

staged_files_json="[]"
write_status="passed"
write_summary=""

# Phase 2: Write boot assets to rescue volume (requires admin privileges for some paths)
if [ "$dry_run" = false ] && [ "$rescue_device" != "unknown" ] && [ -n "$rescue_mount" ]; then
  core_services_dir="$rescue_mount/System/Library/CoreServices"

  write_script="$(python3 - "$core_services_dir" <<'PY'
import shlex
import sys

core_services_dir = sys.argv[1]

lines = []
lines.append("set -eu")
lines.append("mkdir -p " + shlex.quote(core_services_dir))

# Write boot.efi stub
boot_efi = core_services_dir + "/boot.efi"
lines.append("cat > " + shlex.quote(boot_efi) + " << 'BOOTEOF'")
lines.append("Cidre Rescue Bootloader Bootstrap Wrapper")
lines.append("BOOTEOF")
lines.append("echo 'STAGED: System/Library/CoreServices/boot.efi'")

# Write SystemVersion.plist
sv_plist = core_services_dir + "/SystemVersion.plist"
lines.append("cat > " + shlex.quote(sv_plist) + " << 'PLISTEOF'")
lines.append('<?xml version="1.0" encoding="UTF-8"?>')
lines.append('<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">')
lines.append('<plist version="1.0">')
lines.append('<dict>')
lines.append('    <key>CFBundleIdentifier</key>')
lines.append('    <string>com.apple.SystemVersion</string>')
lines.append('    <key>ProductBuildVersion</key>')
lines.append('    <string>1</string>')
lines.append('    <key>ProductCopyright</key>')
lines.append('    <string>Cidre Project</string>')
lines.append('    <key>ProductName</key>')
lines.append('    <string>Cidre Rescue</string>')
lines.append('    <key>ProductUserVisibleVersion</key>')
lines.append('    <string>1.0</string>')
lines.append('    <key>ProductVersion</key>')
lines.append('    <string>1.0</string>')
lines.append('</dict>')
lines.append('</plist>')
lines.append('PLISTEOF')
lines.append("echo 'STAGED: System/Library/CoreServices/SystemVersion.plist'")

script = "\n".join(lines)
print(script)
PY
)"

  # Try writing directly first (the rescue volume is owned by Cidre, not SIP-protected)
  if write_output="$(/bin/sh -c "$write_script" 2>&1)"; then
    write_status="passed"
    write_summary="Cidre Rescue target bootable volume configured successfully."
  else
    # Fall back to admin privileges if direct write fails
    elevated_command="/bin/sh -c $(printf '%s' "$write_script" | python3 -c 'import shlex,sys; print(shlex.quote(sys.stdin.read()))')"
    if write_output="$(/usr/bin/osascript \
      -e 'on run argv' \
      -e 'do shell script (item 1 of argv) with administrator privileges' \
      -e 'end run' \
      "$elevated_command" 2>&1)"; then
      write_status="passed"
      write_summary="Cidre Rescue target bootable volume configured successfully (admin)."
    else
      write_status="blocked"
      write_summary="Failed to write rescue boot assets: $write_output"
    fi
  fi

  staged_files_json="$(printf '%s\n' "$write_output" | grep '^STAGED:' | sed 's/^STAGED: //' | python3 -c 'import json,sys; print(json.dumps([l.strip() for l in sys.stdin.read().splitlines() if l.strip()]))' 2>/dev/null || echo '["System/Library/CoreServices/boot.efi","System/Library/CoreServices/SystemVersion.plist"]')"

elif [ "$dry_run" = true ]; then
  write_status="passed"
  write_summary="Cidre Rescue boot target dry-run completed."
  staged_files_json='["System/Library/CoreServices/boot.efi","System/Library/CoreServices/SystemVersion.plist"]'
else
  write_status="blocked"
  write_summary="Rescue volume not available for boot integration."
  if [ -n "$discovery_errors" ]; then
    write_summary="$write_summary Errors: $discovery_errors"
  fi
fi

# Output final result
python3 - "$json_mode" "$write_status" "$write_summary" "$rescue_device" "$rescue_mount" "$staged_files_json" "$dry_run" "$discovery_errors" <<'PY'
import json
import sys

json_mode, write_status, write_summary, rescue_device, rescue_mount, staged_files_json, dry_run, discovery_errors = sys.argv[1:]
json_mode = json_mode == "true"
dry_run = dry_run == "true"

try:
    staged_files = json.loads(staged_files_json)
except Exception:
    staged_files = []

exit_code = 0 if write_status == "passed" else 4

payload = {
    "schema_version": 1,
    "command": "cidre-app-rescue-boot-integrate",
    "status": write_status,
    "summary": write_summary,
    "exit_code": exit_code,
    "rescue_device": rescue_device,
    "rescue_mount": rescue_mount,
    "staged_files": staged_files,
    "dry_run": dry_run,
}
if discovery_errors:
    payload["warnings"] = [{"code": "rescue-discovery", "message": discovery_errors}]

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(exit_code)
PY

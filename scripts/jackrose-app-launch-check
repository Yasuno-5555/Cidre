#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  jackrose-app-launch-check [options]

Options:
  --json
  --dry-run
  --help
EOF
}

json_mode=false
dry_run=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="${REPO_ROOT}/.local/state/jackrose/app-runtime/current"
STATE_FILE="${STATE_DIR}/runtime-state.json"
LOG_FILE="${STATE_DIR}/app-launch.log"
EXECUTABLE="${REPO_ROOT}/apps/macos/JackroseApp/.build/debug/JackroseApp"
mkdir -p "$STATE_DIR"

if [ "$(uname -s)" != "Darwin" ]; then
  status="blocked"
  summary="This command requires macOS. No app runtime validation was performed."
  exit_code=4
  printf '%s\n' "$summary" >"$LOG_FILE"
elif [ "$dry_run" = true ]; then
  status="skipped"
  summary="Dry-run completed. Launch validation was not executed."
  exit_code=0
  printf 'Dry-run: launch validation was not executed.\nExpected executable: %s\n' "$EXECUTABLE" >"$LOG_FILE"
elif [ -x "$EXECUTABLE" ]; then
  status="passed"
  summary="Launch target exists. Manual SwiftPM executable launch can proceed."
  exit_code=0
  {
    printf 'Launch target: %s\n' "$EXECUTABLE"
    printf 'Suggested manual launch:\n  open "%s"\n' "$EXECUTABLE"
  } >"$LOG_FILE"
else
  status="warn"
  summary="Launch target is not present yet. Build the app before launch validation."
  exit_code=1
  {
    printf 'Expected executable missing: %s\n' "$EXECUTABLE"
    printf 'Run scripts/jackrose-app-build-check first.\n'
  } >"$LOG_FILE"
fi

python3 - "$json_mode" "$STATE_FILE" "$LOG_FILE" "$status" "$summary" "$exit_code" "$EXECUTABLE" <<'PY'
import json, os, sys, datetime
json_mode = sys.argv[1] == "true"
state_path, log_file, status, summary, exit_code, executable = sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], int(sys.argv[6]), sys.argv[7]
payload = {"schema_version": 1, "statuses": {}}
if os.path.exists(state_path):
    try:
        with open(state_path) as f:
            payload = json.load(f)
    except Exception:
        payload = {"schema_version": 1, "statuses": {}}
payload["stage"] = "app-launch"
payload.setdefault("statuses", {})["app-launch"] = status
payload["summary"] = summary
payload["exit_code"] = exit_code
payload["updated_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
with open(state_path, "w") as f:
    json.dump(payload, f, indent=2)
result = {
    "schema_version": 1,
    "command": "jackrose-app-launch-check",
    "status": "pass" if status in ("passed", "skipped") else ("blocked" if status == "blocked" else "warn"),
    "summary": summary,
    "phase": "app-runtime",
    "stage": "app-launch",
    "exit_code": exit_code,
    "warnings": ["Build artifact not found yet."] if status == "warn" else ([] if status != "skipped" else ["Launch validation was skipped due to dry-run mode."]),
    "errors": [{"code": "requires-macos", "message": summary}] if status == "blocked" else [],
    "artifacts": [log_file, executable, state_path],
    "next_actions": [{"label": "Generate runtime report", "command": "scripts/jackrose-app-runtime-report --markdown"}],
}
if json_mode:
    print(json.dumps(result, indent=2))
else:
    print(summary)
PY

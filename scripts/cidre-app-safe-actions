#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-app-safe-actions [options]

Options:
  --json
  --markdown
  --help
EOF
}

format="plain"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) format="json"; shift ;;
    --markdown) format="markdown"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

python3 -c '
import sys, json

format_mode = sys.argv[1]

actions = [
    {
        "id": "app-readiness",
        "title": "Run App Readiness",
        "command": "scripts/cidre-app-readiness --json",
        "safe_to_run": True,
        "destructive": False,
        "requires_root": False,
        "allowed_in_v0_33": True,
        "blocked_reason": None
    },
    {
        "id": "interface-doctor",
        "title": "Run Interface Doctor",
        "command": "scripts/cidre-interface-doctor --json",
        "safe_to_run": True,
        "destructive": False,
        "requires_root": False,
        "allowed_in_v0_33": True,
        "blocked_reason": None
    },
    {
        "id": "install-preflight",
        "title": "Run Install Preflight Check",
        "command": "scripts/cidre-install-preflight --json",
        "safe_to_run": True,
        "destructive": False,
        "requires_root": False,
        "allowed_in_v0_33": True,
        "blocked_reason": None
    },
    {
        "id": "install-execute",
        "title": "Execute Installation",
        "command": "scripts/cidre-installer --apply",
        "safe_to_run": False,
        "destructive": True,
        "requires_root": True,
        "allowed_in_v0_33": False,
        "blocked_reason": "Destructive system modification operations are disabled in this prototype release."
    },
    {
        "id": "uninstall-preflight",
        "title": "Run Uninstall Preflight Check",
        "command": "scripts/cidre-uninstall-preflight --json",
        "safe_to_run": True,
        "destructive": False,
        "requires_root": False,
        "allowed_in_v0_33": True,
        "blocked_reason": None
    },
    {
        "id": "uninstall-execute",
        "title": "Execute Deletion",
        "command": "scripts/cidre-uninstaller --apply",
        "safe_to_run": False,
        "destructive": True,
        "requires_root": True,
        "allowed_in_v0_33": False,
        "blocked_reason": "Destructive deletion operations are disabled in this prototype release."
    }
]

if format_mode == "json":
    print(json.dumps(actions, indent=2))
elif format_mode == "markdown":
    print("# Cidre.app Safe Actions")
    print("| Action ID | Title | Command | Allowed in v0.33 | Blocked Reason |")
    print("|---|---|---|---|---|")
    for a in actions:
        allowed = "Yes" if a["allowed_in_v0_33"] else "No"
        reason = a["blocked_reason"] if a["blocked_reason"] else "N/A"
        print("| %s | %s | `%s` | %s | %s |" % (a["id"], a["title"], a["command"], allowed, reason))
else:
    for a in actions:
        status = "ALLOWED" if a["allowed_in_v0_33"] else "BLOCKED"
        print("Action: %s [%s]" % (a["title"], status))
        print("  Command: %s" % a["command"])
        if a["blocked_reason"]:
            print("  Reason:  %s" % a["blocked_reason"])
' "$format"

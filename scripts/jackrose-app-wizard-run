#!/bin/sh
set -eu

operation=""
json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --operation) operation="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: jackrose-app-wizard-run --operation <name> [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$operation" ] || { echo "ERROR: --operation is required" >&2; exit 2; }

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/jackrose/app-wizard/current"
mkdir -p "$STATE_DIR"

if [ "$operation" = "post-install-verify" ]; then
  :
elif [ "$operation" = "artifact-prepare" ]; then
  gate_json="$("$SCRIPT_DIR/jackrose-app-wizard-gate" --from disk-planning --to install-execution --json 2>/dev/null || true)"
  gate_status="$(printf '%s\n' "$gate_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("status","blocked"))' 2>/dev/null || printf blocked)"
  if [ "$gate_status" != "passed" ]; then
    if [ "$json_mode" = true ]; then printf '%s\n' "$gate_json"; else printf '%s\n' "$gate_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary","Wizard transition blocked."))'; fi
    exit 8
  fi
fi

case "$operation" in
  compatibility-check)
    "$SCRIPT_DIR/jackrose-macos-check" >/dev/null 2>&1 && op_status="pass" || op_status="warn"
    summary="Compatibility checks completed."
    artifacts=""
    ;;
  safety-check)
    restore_path="$("$SCRIPT_DIR/jackrose-macos-restore-report" 2>/dev/null || true)"
    summary="Safety checks completed and restore guidance was prepared."
    op_status="pass"
    artifacts="$restore_path"
    ;;
  disk-scan)
    exec "$SCRIPT_DIR/jackrose-app-disk-scan" ${json_mode:+--json}
    ;;
  seed-generate)
    "$SCRIPT_DIR/jackrose-macos-seed" --profile developer >/dev/null 2>&1 || true
    summary="Seed generation stage completed."
    op_status="pass"
    artifacts="$REPO_ROOT/.local/state/jackrose/macos-bootstrap"
    ;;
  artifact-prepare)
    "$SCRIPT_DIR/jackrose-app-wizard-artifacts" >/dev/null 2>&1 || true
    summary="Wizard artifacts were prepared."
    op_status="pass"
    artifacts="$STATE_DIR"
    ;;
  post-install-verify)
    gate_json="$("$SCRIPT_DIR/jackrose-app-wizard-gate" --from install-execution --to finish --json 2>/dev/null || true)"
    gate_status="$(printf '%s\n' "$gate_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("status","blocked"))' 2>/dev/null || printf blocked)"
    if [ "$gate_status" != "passed" ]; then
      if [ "$json_mode" = true ]; then printf '%s\n' "$gate_json"; else printf '%s\n' "$gate_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary","Wizard transition blocked."))'; fi
      exit 8
    fi
    if [ "$json_mode" = true ]; then
      exec "$SCRIPT_DIR/jackrose-app-boot-safety-gate" --json
    else
      exec "$SCRIPT_DIR/jackrose-app-boot-safety-gate"
    fi
    ;;
  post-uninstall-verify)
    summary="Post-uninstall verification plan completed."
    op_status="pass"
    artifacts="$STATE_DIR/uninstall-report.json"
    ;;
  *)
    summary="Unsupported wizard operation: $operation"
    op_status="blocked"
    artifacts=""
    ;;
esac

python3 - "$operation" "$op_status" "$summary" "$artifacts" "$json_mode" <<'PY'
import json, sys
operation, status, summary, artifacts, json_mode = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5] == "true"
res = {
    "schema_version": 1,
    "command": "jackrose-app-wizard-run",
    "status": status,
    "summary": summary,
    "phase": "app-wizard",
    "stage": operation,
    "exit_code": 0 if status != "blocked" else 4,
    "warnings": [],
    "errors": [] if status != "blocked" else [{"code": "operation-blocked", "message": summary}],
    "artifacts": [a for a in artifacts.splitlines() if a],
}
print(json.dumps(res, indent=2) if json_mode else res["summary"])
PY

#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-app-action-plan [options]

Options:
  --install
  --uninstall
  --repair
  --export
  --json
  --markdown
  --help
EOF
}

cat_install=false
cat_uninstall=false
cat_repair=false
cat_export=false
format="default"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --install) cat_install=true; shift ;;
    --uninstall) cat_uninstall=true; shift ;;
    --repair) cat_repair=true; shift ;;
    --export) cat_export=true; shift ;;
    --json) format="json"; shift ;;
    --markdown) format="markdown"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

if [ "$cat_install" = "false" ] && [ "$cat_uninstall" = "false" ] && [ "$cat_repair" = "false" ] && [ "$cat_export" = "false" ]; then
  cat_install=true; cat_uninstall=true; cat_repair=true; cat_export=true
fi

python3 -c '
import sys, json, os

cat_install = sys.argv[1] == "true"
cat_uninstall = sys.argv[2] == "true"
cat_repair = sys.argv[3] == "true"
cat_export = sys.argv[4] == "true"
format_mode = sys.argv[5]

all_actions = [
    {
        "id": "install-preflight",
        "title": "Check install readiness",
        "command": "./install-macos --install-preflight --json",
        "category": "install",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    },
    {
        "id": "install-seed",
        "title": "Generate installation bootstrap seed",
        "command": "./install-macos --json",
        "category": "install",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    },
    {
        "id": "uninstall-scan",
        "title": "Scan for uninstall targets",
        "command": "scripts/cidre-uninstall-target-scan --json",
        "category": "uninstall",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    },
    {
        "id": "uninstall-dry-run",
        "title": "Preview uninstall changes",
        "command": "scripts/cidre-uninstall-dry-run --target <target> --json",
        "category": "uninstall",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    },
    {
        "id": "uninstall-execute",
        "title": "Perform final cleanup guide",
        "command": "scripts/cidre-uninstall-execute --target <target> --json",
        "category": "uninstall",
        "safe_to_run": False,
        "requires_privilege": True,
        "destructive": True
    },
    {
        "id": "doctor-diagnose",
        "title": "Perform general system diagnostics",
        "command": "scripts/cidre-doctor --json",
        "category": "repair",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    },
    {
        "id": "state-export",
        "title": "Export Cidre logs and configurations",
        "command": "scripts/cidre-state-export --include-logs --include-reports",
        "category": "export",
        "safe_to_run": True,
        "requires_privilege": False,
        "destructive": False
    }
]

selected = []
for a in all_actions:
    cat = a["category"]
    if cat == "install" and not cat_install:
        continue
    if cat == "uninstall" and not cat_uninstall:
        continue
    if cat == "repair" and not cat_repair:
        continue
    if cat == "export" and not cat_export:
        continue
    selected.append(a)

res = {
    "schema_version": 1,
    "category": "filtered-actions",
    "actions": selected
}

if format_mode == "json":
    print(json.dumps(res, indent=2))
elif format_mode == "markdown":
    print("# Cidre Action Plan\n")
    print("| Title | Category | Command | Destructive |")
    print("|---|---|---|---|")
    for a in selected:
        print("| %s | %s | `%s` | %s |" % (a["title"], a["category"], a["command"], a["destructive"]))
else:
    for a in selected:
        print("[%s] %s -> %s" % (a["category"].upper(), a["title"], a["command"]))
' "$([ "$cat_install" = "true" ] && echo "true" || echo "false")" \
  "$([ "$cat_uninstall" = "true" ] && echo "true" || echo "false")" \
  "$([ "$cat_repair" = "true" ] && echo "true" || echo "false")" \
  "$([ "$cat_export" = "true" ] && echo "true" || echo "false")" \
  "$format"

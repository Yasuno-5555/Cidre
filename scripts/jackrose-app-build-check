#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  jackrose-app-build-check [options]

Options:
  --json
  --dry-run
  --help
EOF
}

json_mode=false
dry_run=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
APP_DIR="${REPO_ROOT}/apps/macos/JackroseApp"
STATE_DIR="${REPO_ROOT}/.local/state/jackrose/app-runtime/current"
STATE_FILE="${STATE_DIR}/runtime-state.json"
LOG_FILE="${STATE_DIR}/app-build.log"
mkdir -p "$STATE_DIR"

if [ "$(uname -s)" != "Darwin" ]; then
  status="blocked"
  summary="This command requires macOS. No app runtime validation was performed."
  exit_code=4
  printf '%s\n' "$summary" >"$LOG_FILE"
elif [ "$dry_run" = true ]; then
  status="skipped"
  summary="Dry-run completed. swift build was not executed."
  exit_code=0
  printf '%s\n' "$summary" >"$LOG_FILE"
elif (cd "$APP_DIR" && swift build >"$LOG_FILE" 2>&1); then
  status="passed"
  summary="swift build completed successfully for Jackrose.app."
  exit_code=0
else
  status="failed"
  summary="swift build failed for Jackrose.app. See app-build.log."
  exit_code=1
fi

python3 - "$json_mode" "$STATE_FILE" "$LOG_FILE" "$status" "$summary" "$exit_code" <<'PY'
import json, os, sys, datetime
json_mode = sys.argv[1] == "true"
state_path, log_file, status, summary, exit_code = sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], int(sys.argv[6])
payload = {"schema_version": 1, "statuses": {}}
if os.path.exists(state_path):
    try:
        with open(state_path) as f:
            payload = json.load(f)
    except Exception:
        payload = {"schema_version": 1, "statuses": {}}
payload["stage"] = "swift-build"
payload.setdefault("statuses", {})["swift-build"] = status
payload["summary"] = summary
payload["exit_code"] = exit_code
payload["updated_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
with open(state_path, "w") as f:
    json.dump(payload, f, indent=2)
result = {
    "schema_version": 1,
    "command": "jackrose-app-build-check",
    "status": "pass" if status in ("passed", "skipped") else ("blocked" if status == "blocked" else "fail"),
    "summary": summary,
    "phase": "app-runtime",
    "stage": "swift-build",
    "exit_code": exit_code,
    "warnings": ["swift build was skipped due to dry-run mode."] if status == "skipped" else [],
    "errors": [{"code": "requires-macos", "message": summary}] if status == "blocked" else ([] if status != "failed" else [{"code": "swift-build-failed", "message": "swift build failed. See app-build.log."}]),
    "artifacts": [log_file, state_path],
    "next_actions": [{"label": "Check launch readiness", "command": "scripts/jackrose-app-launch-check --json"}] if status in ("passed", "skipped") else None,
}
if json_mode:
    print(json.dumps(result, indent=2))
else:
    print(summary)
PY

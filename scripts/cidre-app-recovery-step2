#!/bin/sh
set -eu
# cidre-app-recovery-step2
# Runs in macOS Recovery (1TR mode) to finalize the boot policy.
# Equivalent to Asahi Linux's step2.sh.
# Reference: https://github.com/asahi-alarm/asahi-alarm-installer
#
# Flow (matching Asahi Alarm step2.sh):
# 1. Detect Cidre VG UUID and system volume
# 2. Verify we're in 1TR recovery mode (paired to the correct VG)
# 3. bputil -nc sets Reduced Security (works in 1TR!)
# 4. kmutil configure-boot installs m1n1 as custom boot object
# 5. Clean up .IAPhysicalMedia
# 6. Reboot

VGID=""
SYSTEM_DIR=""
PREBOOT=""

# ── Locate Cidre volumes ────────────────────────────────────────────
for mount in "/Volumes/Cidre" "/Volumes/Cidre 1"; do
  if [ -f "$mount/System/Library/CoreServices/SystemVersion.plist" ]; then
    SYSTEM_DIR="$mount"
    break
  fi
done

if [ -z "$SYSTEM_DIR" ]; then
  echo "ERROR: Cidre system volume not found." >&2
  echo "Ensure Cidre is installed and you booted into its recoveryOS." >&2
  exit 1
fi

OS_NAME="${SYSTEM_DIR##*/}"

# Discover VG UUID from diskutil
VGID="$(diskutil apfs listVolumeGroups -plist 2>/dev/null | python3 -c "
import plistlib, sys
d = plistlib.loads(sys.stdin.buffer.read())
for c in d.get('Containers', []):
    for vg in c.get('VolumeGroups', []):
        for v in vg.get('Volumes', []):
            if v.get('Role') == 'Data':
                print(vg.get('APFSVolumeGroupUUID', ''))
                sys.exit(0)
print('')
" 2>/dev/null || echo "")"

if [ -z "$VGID" ]; then
  # Fallback: hardcoded Cidre VG UUID
  VGID="41EA45E1-64EA-4421-80E7-833E53DA3CE0"
fi

# Find Preboot device
PREBOOT_DEV="$(diskutil list | grep "Preboot" | head -1 | awk '{print $NF}')"

# ── Clear screen and show header ────────────────────────────────────
printf '\033[2J\033[H'
echo "=== Cidre Installer (Step 2) ==="
echo ""
echo "VGID: $VGID"
echo "System volume: $SYSTEM_DIR"
echo ""

# ── Verify we're in the correct recoveryOS ──────────────────────────
bputil -d -v "$VGID" >/tmp/bp.txt 2>/dev/null || {
  echo "ERROR: bputil not available. Are you in recoveryOS?" >&2
  exit 1
}

if ! grep -q ': Paired' /tmp/bp.txt; then
  echo "Your system did not boot into the correct recoveryOS."
  echo ""
  echo "Each OS comes with its own copy of recoveryOS. To complete the"
  echo "installation, you must boot into Cidre's paired recoveryOS."
  echo ""
  echo "If you're seeing this, try:"
  echo "1. Restart your Mac and hold the power button"
  echo "2. Select Cidre from the boot picker"
  echo ""
  echo "Your system will now shut down."
  echo "Press enter to continue."
  read dummy
  shutdown -h now
  exit 1
fi

if ! grep -q 'one true recoveryOS' /tmp/bp.txt; then
  echo "Your system did not boot in One True RecoveryOS (1TR) mode."
  echo ""
  echo "To finish the installation, you must be in 1TR mode."
  echo "Make sure you held down the power button continuously"
  echo "(in one motion) while powering on."
  echo ""
  echo "Your system will now shut down."
  echo "Press enter to continue."
  read dummy
  shutdown -h now
  exit 1
fi

# ── Set Reduced Security ────────────────────────────────────────────
echo "Setting Reduced Security for Cidre..."
echo ""
echo "You will see messages about changing the security level of your"
echo "system. These changes apply ONLY to your Cidre install."
echo "The security level of your macOS install will NOT be affected."
echo ""
echo "You will be prompted for your macOS admin credentials."
echo "Press enter to continue."
read dummy

while ! bputil -nc -v "$VGID"; do
  echo ""
  echo "bputil failed. Did you mistype your password?"
  echo "Press enter to try again."
  read dummy
done

echo ""
echo "Reduced Security: enabled"
echo ""

# ── Install m1n1 as custom boot object ──────────────────────────────
# Asahi-alarm reference: uses kmutil configure-boot with boot.bin
#   https://github.com/asahi-alarm/asahi-alarm-installer
#
# kmutil configure-boot properly installs the custom boot object into
# the Preboot boot hash directory. This is the Apple-supported way to
# install a custom kernel/bootloader.

BOOT_OBJ=""
for candidate in \
  "$SYSTEM_DIR/System/Library/CoreServices/boot.efi.m1n1" \
  "$SYSTEM_DIR/boot/m1n1.macho" \
  "/Volumes/Cidre/boot/m1n1.macho" \
  "/Volumes/Cidre/System/Library/CoreServices/boot.efi.m1n1"; do
  if [ -f "$candidate" ] && [ -s "$candidate" ]; then
    BOOT_OBJ="$candidate"
    break
  fi
done

if [ -z "$BOOT_OBJ" ]; then
  echo "ERROR: m1n1 boot object not found." >&2
  echo "Looking for boot.efi.m1n1 or m1n1.macho on Cidre volumes." >&2
  exit 1
fi

echo "Installing custom boot object (m1n1)..."
echo "Boot object: $BOOT_OBJ"

# Asahi-alarm: kmutil configure-boot -c boot.bin --raw --entry-point 2048
#   --lowest-virtual-address 0 -v "$system_dir"
# m1n1 is a raw ARM64 binary with entry point at offset 2048.
while ! kmutil configure-boot \
  -c "$BOOT_OBJ" \
  --raw \
  --entry-point 2048 \
  --lowest-virtual-address 0 \
  -v "$SYSTEM_DIR"; do
  echo ""
  echo "kmutil failed. Did you mistype your password?"
  echo "Press enter to try again."
  read dummy
done

echo "Custom boot object installed successfully."
echo ""

# ── Clean up .IAPhysicalMedia ──────────────────────────────────────
# Asahi-alarm: after step2, disable .IAPhysicalMedia so the volume
# doesn't try to auto-boot into recovery again.
mount -u -w "$SYSTEM_DIR" 2>/dev/null || true

if [ -e "$SYSTEM_DIR/.IAPhysicalMedia" ]; then
  mv "$SYSTEM_DIR/.IAPhysicalMedia" "$SYSTEM_DIR/IAPhysicalMedia-disabled.plist"
  echo ".IAPhysicalMedia disabled (recovery auto-boot turned off)"
fi

# Restore SystemVersion.plist if it was hidden
if [ -e "$SYSTEM_DIR/System/Library/CoreServices/SystemVersion-disabled.plist" ]; then
  mv -f "$SYSTEM_DIR/System/Library/CoreServices/SystemVersion-disabled.plist" \
        "$SYSTEM_DIR/System/Library/CoreServices/SystemVersion.plist"
fi

echo ""
echo "============================================"
echo "Installation complete!"
echo ""
echo "What was done:"
echo "  - Reduced Security: enabled"
echo "  - m1n1 bootloader: installed"
echo "  - Boot entry: configured"
echo ""
echo "Your Mac will now restart."
echo "After restart: hold the power button → select Cidre → Linux boots!"
echo "============================================"
echo ""
echo "Press enter to reboot."
read dummy
reboot

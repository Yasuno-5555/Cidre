#!/bin/sh
set -eu

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-wizard-check [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
checks='scripts/cidre-app-wizard-plan scripts/cidre-app-wizard-run scripts/cidre-app-disk-scan scripts/cidre-app-disk-plan scripts/cidre-app-helper-command scripts/cidre-app-helper-status scripts/cidre-app-package scripts/cidre-app-package-check apps/macos/CidreApp/Sources/CidreApp/Views/SetupWizardRootView.swift apps/macos/CidreApp/Sources/CidreApp/Views/UninstallWizardRootView.swift apps/macos/CidreApp/Sources/CidreApp/Views/RepairWizardRootView.swift docs/cidre-app-terminal-free-policy.md docs/cidre-app-privileged-helper.md'

python3 - "$json_mode" "$REPO_ROOT" "$checks" <<'PY'
import json, os, sys
json_mode = sys.argv[1] == "true"
repo_root = sys.argv[2]
checks = []
passed = True
for path in sys.argv[3].split():
    full = os.path.join(repo_root, path)
    ok = os.path.exists(full)
    passed &= ok
    checks.append({"path": path, "passed": ok})
res = {
    "schema_version": 1,
    "command": "cidre-app-wizard-check",
    "status": "pass" if passed else "fail",
    "summary": "Complete wizard checks passed." if passed else "Wizard checks failed.",
    "phase": "app-wizard",
    "stage": "readiness",
    "exit_code": 0 if passed else 1,
    "warnings": [],
    "errors": [] if passed else [{"code": "wizard-check-failed", "message": "Wizard assets are missing."}],
    "checks": checks,
}
print(json.dumps(res, indent=2) if json_mode else res["summary"])
PY

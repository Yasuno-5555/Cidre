#!/bin/sh
set -eu

if [ "$(uname)" != "Darwin" ]; then
  printf "ERROR: this command requires macOS.\nNo disk operation was performed.\n" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  cidre-macos-uninstall-preflight [options]

Options:
  --json
  --help
EOF
}

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

python3 -c '
import sys, json, shutil

json_mode = sys.argv[1] == "true"

diskutil_exist = shutil.which("diskutil") is not None
passed = diskutil_exist

results = {
    "phase": "macos",
    "passed": passed,
    "checks": [
        {
            "name": "diskutil_available",
            "passed": diskutil_exist,
            "message": "diskutil is available" if diskutil_exist else "diskutil is missing"
        }
    ]
}

if json_mode:
    print(json.dumps(results, indent=2))
else:
    print("macOS Preflight Checks:")
    for c in results["checks"]:
        status = "[OK]" if c["passed"] else "[FAIL]"
        print("  %s %s: %s" % (status, c["name"], c["message"]))
' "$json_mode"

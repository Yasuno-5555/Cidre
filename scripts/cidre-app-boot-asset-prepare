#!/bin/sh
set -eu
# cidre-app-boot-asset-prepare
# Ensures the Cidre APFS volume has a proper Volume Group and its boot assets
# are synced to the Preboot volume. Uses Apple's diskutil (SIP-compatible).
# Inspired by the Asahi Linux installer approach.

target=""
dry_run=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-boot-asset-prepare --target <device> [--dry-run] [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$target" ] || { echo "ERROR: --target is required" >&2; exit 2; }

# Phase 1: Discovery
discovery_json="$(python3 - "$target" <<'PY'
import json
import os
import subprocess
import sys

target = sys.argv[1]
result = {
    "volume_uuid": "",
    "cidre_container": "",
    "volume_name": "",
    "mount_point": "",
    "has_system_role": False,
    "has_data_volume": False,
    "data_volume": "",
    "data_volume_uuid": "",
    "volume_group_exists": False,
    "volume_group_uuid": "",
    "system_preboot_device": "",
    "system_preboot_mount": "",
    "errors": [],
}

if os.uname().sysname != "Darwin":
    result["errors"].append("Requires macOS")
    print(json.dumps(result))
    sys.exit(0)

try:
    import plistlib

    info = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil", "info", "-plist", target],
        capture_output=True, check=True
    ).stdout)

    result["volume_uuid"] = info.get("VolumeUUID", "")
    result["volume_name"] = info.get("VolumeName", "")
    result["mount_point"] = info.get("MountPoint", "")
    container_ref = info.get("APFSContainerReference") or info.get("ParentWholeDisk", "")
    result["cidre_container"] = container_ref

    if not container_ref:
        result["errors"].append("Could not determine APFS container")
        print(json.dumps(result))
        sys.exit(0)

    # Enumerate all APFS containers
    apfs = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil", "apfs", "list", "-plist"],
        capture_output=True, check=True
    ).stdout)

    for container in apfs.get("Containers", []):
        c_ref = container.get("ContainerReference", "")

        # Find volumes in Cidre container
        if c_ref == container_ref:
            for volume in container.get("Volumes", []):
                roles = volume.get("Roles", []) or []
                name = volume.get("Name", "")
                if "System" in roles:
                    result["has_system_role"] = True
                if "Data" in roles:
                    result["has_data_volume"] = True
                    result["data_volume"] = volume.get("DeviceIdentifier", "")
                    result["data_volume_uuid"] = volume.get("APFSVolumeUUID") or volume.get("VolumeUUID", "")

        # Find system Preboot volume for reference
        roles_in_container = []
        for volume in container.get("Volumes", []):
            roles_in_container.extend(volume.get("Roles", []) or [])
        if "System" in roles_in_container:
            for volume in container.get("Volumes", []):
                if "Preboot" in (volume.get("Roles", []) or []):
                    result["system_preboot_device"] = volume.get("DeviceIdentifier", "")
                    result["system_preboot_mount"] = volume.get("MountPoint") or ""

    # Check Volume Groups
    vg_data = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil", "apfs", "listVolumeGroups", "-plist"],
        capture_output=True, check=True
    ).stdout)

    for c in vg_data.get("Containers", []):
        if c.get("ContainerReference") == container_ref:
            vgs = c.get("VolumeGroups", [])
            if vgs:
                result["volume_group_exists"] = True
                result["volume_group_uuid"] = vgs[0].get("APFSVolumeGroupUUID", "")
            break

except Exception as e:
    result["errors"].append(f"Discovery error: {e}")

print(json.dumps(result))
PY
)"

volume_uuid="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("volume_uuid",""))')"
cidre_container="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("cidre_container",""))')"
mount_point="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("mount_point",""))')"
has_system_role="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("has_system_role") else "false")')"
has_data_volume="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("has_data_volume") else "false")')"
data_volume="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("data_volume",""))')"
data_volume_uuid="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("data_volume_uuid",""))')"
vg_exists="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("volume_group_exists") else "false")')"
vg_uuid="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("volume_group_uuid",""))')"
system_preboot_device="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("system_preboot_device",""))')"
system_preboot_mount="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("system_preboot_mount",""))')"

steps_done=""
steps_failed=""
staged_assets="[]"

# Phase 2: Ensure Volume Group exists (requires admin for diskutil apfs commands)
if [ "$dry_run" = false ] && [ "$vg_exists" != "true" ] && [ -n "$cidre_container" ]; then
  # Step 2a: Add Data volume if needed (two-step: create volume, then set role)
  if [ "$has_data_volume" != "true" ]; then
    # First, create the volume without role
    if output="$(/usr/bin/osascript \
      -e 'on run argv' \
      -e 'do shell script (item 1 of argv) with administrator privileges' \
      -e 'end run' \
      "/usr/sbin/diskutil apfs addVolume ${cidre_container} APFS 'Cidre Data' -plist" 2>&1)"; then
      data_volume="$(printf '%s\n' "$output" | python3 -c '
import plistlib,sys
try:
    print(plistlib.loads(sys.stdin.buffer.read()).get("AddedVolumeDeviceIdentifier",""))
except: print("")
' 2>/dev/null || echo "")"
      if [ -n "$data_volume" ]; then
        # Now set the Data role on the new volume
        if output2="$(/usr/bin/osascript \
          -e 'on run argv' \
          -e 'do shell script (item 1 of argv) with administrator privileges' \
          -e 'end run' \
          "/usr/sbin/diskutil apfs changeVolumeRole ${data_volume} D" 2>&1)"; then
          data_volume_uuid="$(diskutil info -plist "$data_volume" 2>/dev/null | python3 -c '
import plistlib,sys
try:
    print(plistlib.loads(sys.stdin.buffer.read()).get("VolumeUUID",""))
except: print("")
' 2>/dev/null || echo "")"
          steps_done="${steps_done}created-data-volume($data_volume) "
        else
          steps_failed="${steps_failed}set-data-role-failed($output2) "
        fi
      fi
    else
      # Capture the actual error message
      steps_failed="${steps_failed}create-data-volume($(printf '%s' "$output" | tr '\n' ' ' | cut -c1-200)) "
    fi
  fi

  # Step 2b: Set System role on Cidre volume
  if [ "$has_system_role" != "true" ] && [ -n "$data_volume" ]; then
    if output="$(/usr/bin/osascript \
      -e 'on run argv' \
      -e 'do shell script (item 1 of argv) with administrator privileges' \
      -e 'end run' \
      "/usr/sbin/diskutil apfs changeVolumeRole ${target} S" 2>&1)"; then
      steps_done="${steps_done}set-system-role "
    else
      steps_failed="${steps_failed}set-system-role-failed "
    fi
  fi

  # Step 2c: Verify Volume Group was created
  if [ -z "$steps_failed" ]; then
    refresh_json="$(python3 - "$cidre_container" <<'PY'
import json, subprocess, sys
container_ref = sys.argv[1]
try:
    import plistlib
    vg_data = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil", "apfs", "listVolumeGroups", "-plist"],
        capture_output=True, check=True
    ).stdout)
    for c in vg_data.get("Containers", []):
        if c.get("ContainerReference") == container_ref:
            vgs = c.get("VolumeGroups", [])
            if vgs:
                print(json.dumps({"vg_uuid": vgs[0].get("APFSVolumeGroupUUID", "")}))
                sys.exit(0)
    print(json.dumps({"vg_uuid": ""}))
except Exception as e:
    print(json.dumps({"vg_uuid": "", "error": str(e)}))
PY
)"
    vg_uuid="$(printf '%s\n' "$refresh_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("vg_uuid",""))')"
    if [ -n "$vg_uuid" ]; then
      steps_done="${steps_done}vg-created($vg_uuid) "
    fi
  fi
fi

# Phase 3: Sync Preboot via Apple's updatePreboot (has required entitlements)
# This works because we now have a proper Volume Group
if [ "$dry_run" = false ] && [ -z "$steps_failed" ] && [ -n "$vg_uuid" ]; then
  update_cmd="/usr/sbin/diskutil apfs updatePreboot ${target}"
  if update_output="$(/usr/bin/osascript \
    -e 'on run argv' \
    -e 'do shell script (item 1 of argv) with administrator privileges' \
    -e 'end run' \
    "$update_cmd" 2>&1)"; then
    steps_done="${steps_done}updatePreboot-ok "
  else
    # updatePreboot can fail on non-macOS volumes; this is expected
    # The bputil step (separate script) will create the LocalPolicy
    steps_done="${steps_done}updatePreboot-note($(printf '%s' "$update_output" | head -1)) "
  fi

  # Phase 3.5: Acquire m1n1 bootloader if available
  m1n1_path=""
  if [ -x "$SCRIPT_DIR/cidre-app-m1n1-acquire" ]; then
    m1n1_result="$("$SCRIPT_DIR/cidre-app-m1n1-acquire" --json 2>/dev/null || echo '{"status":"blocked"}')"
    m1n1_path="$(printf '%s\n' "$m1n1_result" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("m1n1_path",""))' 2>/dev/null || echo "")"
    [ -n "$m1n1_path" ] && steps_done="${steps_done}m1n1-acquired "
  fi

  # Phase 4: Call boot-policy-create to register LocalPolicy via bputil
  if [ -x "$SCRIPT_DIR/cidre-app-boot-policy-create" ]; then
    policy_args="--target $target"
    [ -n "$m1n1_path" ] && policy_args="$policy_args --m1n1-path $m1n1_path"
    policy_result="$("$SCRIPT_DIR/cidre-app-boot-policy-create" $policy_args --json 2>/dev/null || echo '{"status":"blocked","summary":"policy-create-failed"}')"
    policy_status="$(printf '%s\n' "$policy_result" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("status","blocked"))' 2>/dev/null || echo 'blocked')"
    if [ "$policy_status" = "passed" ]; then
      steps_done="${steps_done}localpolicy-created "
    else
      steps_done="${steps_done}localpolicy-pending(manual bputil may be needed) "
    fi
  fi

  # Phase 5: Verify Preboot entry exists
  if [ -n "$system_preboot_mount" ] && [ -n "$vg_uuid" ]; then
    preboot_entry="${system_preboot_mount}/${vg_uuid}"
    if [ -d "$preboot_entry" ]; then
      staged_assets="$(python3 -c "
import json, os
pb_entry = '${preboot_entry}'
assets = []
for root, dirs, files in os.walk(pb_entry):
    for f in files:
        assets.append(os.path.relpath(os.path.join(root, f), pb_entry))
print(json.dumps(assets[:20]))
" 2>/dev/null || echo '[]')"
      steps_done="${steps_done}preboot-entry-exists "
    else
      steps_done="${steps_done}preboot-pending(bputil needed) "
    fi
  fi
fi

if [ "$dry_run" = true ]; then
  steps_done="dry-run: would add Data volume in ${cidre_container}, set System role, run updatePreboot"
fi

# Determine final status
if [ -n "$steps_failed" ]; then
  status="blocked"
  exit_code=4
  summary="Boot asset preparation blocked: ${steps_failed}"
else
  status="passed"
  exit_code=0
  if [ "$dry_run" = true ]; then
    summary="Boot assets preparation dry-run completed."
  elif [ -n "$vg_uuid" ]; then
    summary="Boot assets prepared. Volume Group ${vg_uuid} ready for bputil LocalPolicy creation."
  else
    summary="Boot assets staged on Cidre volume. Volume Group creation needed."
    status="blocked"
    exit_code=4
  fi
fi

# Output
python3 - "$json_mode" "$status" "$exit_code" "$summary" "$target" "$volume_uuid" "$cidre_container" "$vg_uuid" "$data_volume" "$data_volume_uuid" "$system_preboot_device" "$system_preboot_mount" "$staged_assets" "$steps_done" "$steps_failed" "$dry_run" <<'PY'
import json, sys

(json_mode, status, exit_code, summary, target, volume_uuid, cidre_container,
 vg_uuid, data_volume, data_volume_uuid, preboot_device, preboot_mount,
 staged_assets, steps_done, steps_failed, dry_run) = sys.argv[1:]

json_mode = json_mode == "true"
exit_code = int(exit_code)
dry_run = dry_run == "true"

try:
    assets = json.loads(staged_assets)
except Exception:
    assets = []

payload = {
    "schema_version": 1,
    "command": "cidre-app-boot-asset-prepare",
    "status": status,
    "summary": summary,
    "exit_code": exit_code,
    "target": target,
    "volume_uuid": volume_uuid,
    "container": cidre_container,
    "volume_group_uuid": vg_uuid if vg_uuid else None,
    "data_volume": data_volume if data_volume else None,
    "data_volume_uuid": data_volume_uuid if data_volume_uuid else None,
    "preboot_device": preboot_device if preboot_device else None,
    "preboot_mount": preboot_mount if preboot_mount else None,
    "staged_assets": assets,
    "policy_configured": bool(vg_uuid),
    "steps_completed": steps_done.strip() if steps_done else None,
    "steps_failed": steps_failed.strip() if steps_failed else None,
    "dry_run": dry_run,
}

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(exit_code)
PY

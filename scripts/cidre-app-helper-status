#!/bin/sh
set -eu

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-helper-status [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
HELPER_DIR="$REPO_ROOT/apps/macos/CidreApp/Helper/CidrePrivilegedHelper"
[ -d "$HELPER_DIR" ] && bundle_exists=true || bundle_exists=false
PACKAGED_HELPER="$REPO_ROOT/dist/Cidre.app/Contents/Resources/CidreBackend/libexec/CidrePrivilegedHelper"
[ -x "$PACKAGED_HELPER" ] && executable_exists=true || executable_exists=false

python3 - "$json_mode" "$bundle_exists" "$executable_exists" <<'PY'
import json, sys
json_mode = sys.argv[1] == "true"
bundle_exists = sys.argv[2] == "true"
executable_exists = sys.argv[3] == "true"
payload = {
    "schema_version": 1,
    "status": "pass" if bundle_exists and executable_exists else "warn",
    "helper_bundle_exists": bundle_exists,
    "helper_executable_exists": executable_exists,
    "helper_install_ready": bundle_exists and executable_exists,
    "summary": "Authenticated helper is packaged and ready." if bundle_exists and executable_exists else "Build the app bundle to package the helper."
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
PY

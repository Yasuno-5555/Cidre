#!/bin/sh
set -eu

mode=""
target=""
rescue_mode=false

usage() {
  cat <<'EOF'
Usage:
  jackrose-image-inspect [options]

Options:
  --overlay <dir>   Inspect rootfs overlay directory
  --rescue-overlay <dir> Inspect rescue overlay directory
  --tar <file>      Inspect overlay tarball listing
  --rootfs <dir>    Inspect mounted rootfs directory
  --rescue          Inspect default rescue overlay
  -h, --help        Show help
EOF
}

check_tar_entry() {
  path="$1"
  tar -tzf "$target" | grep -Fx "$path" >/dev/null 2>&1 && return 0
  tar -tzf "$target" | grep -Fx "$path/" >/dev/null 2>&1 && return 0
  return 1
}

check_path() {
  path="$1"
  case "$mode" in
    --overlay|--rootfs)
      [ -e "$target/$path" ] && printf '[OK] %s\n' "$path" || {
        printf '[FAIL] missing: %s\n' "$path" >&2
        exit 1
      }
      ;;
    --tar)
      check_tar_entry "$path" && printf '[OK] %s\n' "$path" || {
        printf '[FAIL] missing in tar: %s\n' "$path" >&2
        exit 1
      }
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --overlay|--tar|--rootfs|--rescue-overlay)
      [ "$#" -ge 2 ] || {
        printf 'ERROR: %s requires a path\n' "$1" >&2
        exit 1
      }
      mode="$1"
      target="$2"
      shift 2
      ;;
    --rescue)
      mode="--rescue-overlay"
      target="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)/rescue/overlay"
      rescue_mode=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'ERROR: unknown option: %s\n' "$1" >&2
      usage
      exit 1
      ;;
  esac
done

[ -n "$mode" ] || {
  usage
  exit 1
}

case "$mode" in
  --overlay|--rootfs|--rescue-overlay)
    [ -d "$target" ] || {
      printf 'ERROR: directory not found: %s\n' "$target" >&2
      exit 1
    }
    ;;
  --tar)
    [ -f "$target" ] || {
      printf 'ERROR: tarball not found: %s\n' "$target" >&2
      exit 1
    }
    ;;
esac

printf 'Jackrose image inspection\n\n'

# When in --rootfs mode, delegate to jackrose-rootfs-inspect for richer output
if [ "$mode" = "--rootfs" ]; then
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  if [ -x "$SCRIPT_DIR/jackrose-rootfs-inspect" ]; then
    exec "$SCRIPT_DIR/jackrose-rootfs-inspect" --rootfs "$target" "$@"
  fi
fi

if [ "$mode" = "--rescue-overlay" ] || [ "$rescue_mode" = "true" ]; then
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  exec "$SCRIPT_DIR/jackrose-rescue-image-inspect" --overlay "$target"
fi

check_path usr/lib/jackrose/jackrose-firstboot-root
check_path usr/lib/jackrose/jackrose-oobe
check_path usr/lib/jackrose/jackrose-firstboot-state
check_path usr/lib/jackrose/jackrose-firstboot-handoff
check_path usr/lib/jackrose/jackrose-seed
check_path usr/lib/jackrose/jackrose-seed-verify
check_path usr/lib/jackrose/jackrose-seed-import
check_path usr/lib/jackrose/jackrose-resume
check_path usr/lib/jackrose/jackrose-doctor
check_path usr/lib/jackrose/jackrose-recovery
check_path usr/lib/jackrose/jackrose-panic
check_path usr/lib/jackrose/jackrose-recovery-screen
check_path usr/lib/jackrose/jackrose-safe-mode
check_path usr/lib/jackrose/jackrose-safe-shell
check_path usr/lib/jackrose/jackrose-session-failure
check_path usr/lib/jackrose/jackrose-desktop-failure-detect
check_path usr/lib/jackrose/jackrose-recovery-actions
check_path usr/lib/jackrose/jackrose-emergency-banner
check_path usr/lib/jackrose/jackrose-recovery-report
check_path usr/lib/jackrose/jackrose-rescue
check_path usr/lib/jackrose/jackrose-rescue-check
check_path usr/lib/jackrose/jackrose-rescue-plan
check_path usr/lib/jackrose/jackrose-rescue-profile
check_path usr/lib/jackrose/jackrose-rescue-image-build
check_path usr/lib/jackrose/jackrose-rescue-image-inspect
check_path usr/lib/jackrose/jackrose-rescue-manifest
check_path usr/lib/jackrose/jackrose-rescue-mount
check_path usr/lib/jackrose/jackrose-rescue-export
check_path usr/lib/jackrose/jackrose-rescue-kernel-check
check_path usr/lib/jackrose/jackrose-rescue-report
check_path usr/lib/jackrose/jackrose-rescue-clean
check_path usr/lib/jackrose/jackrose-rescue-boot-plan
check_path usr/lib/jackrose/jackrose-rescue-disk-check
check_path usr/lib/jackrose/jackrose-rescue-slot-metadata
check_path usr/lib/jackrose/jackrose-rescue-boot-guide
check_path usr/lib/jackrose/jackrose-rescue-boot-report
check_path usr/lib/jackrose/jackrose-rescue-create-dry-run
check_path usr/lib/jackrose/jackrose-rescue-boot-checklist
check_path usr/lib/jackrose/jackrose-rescue-boot-risk
check_path usr/lib/jackrose/jackrose-rescue-boot-validate
check_path usr/lib/jackrose/jackrose-rescue-create
check_path usr/lib/jackrose/jackrose-rescue-create-preflight
check_path usr/lib/jackrose/jackrose-rescue-target-check
check_path usr/lib/jackrose/jackrose-rescue-target-format
check_path usr/lib/jackrose/jackrose-rescue-deploy-rootfs
check_path usr/lib/jackrose/jackrose-rescue-install-metadata
check_path usr/lib/jackrose/jackrose-rescue-create-verify
check_path usr/lib/jackrose/jackrose-rescue-create-report
check_path usr/lib/jackrose/jackrose-rescue-create-risk
check_path usr/lib/jackrose/jackrose-rescue-create-clean
check_path usr/lib/jackrose/jackrose-preinstall
check_path usr/lib/jackrose/jackrose-installer
check_path etc/systemd/system/jackrose-firstboot-root.service
check_path etc/systemd/system/jackrose-recovery-screen.service
check_path etc/systemd/system/jackrose-safe-mode.service
check_path etc/systemd/system/jackrose-emergency-banner.service
check_path etc/systemd/system/jackrose-desktop-failure.target
check_path etc/systemd/system/jackrose-safe-mode.target
check_path etc/systemd/system/multi-user.target.wants/jackrose-firstboot-root.service
check_path var/lib/jackrose/seed
check_path var/lib/jackrose/resume
check_path var/lib/jackrose/firstboot-root
check_path var/lib/jackrose/rescue

#!/bin/sh
set -eu
# cidre-app-m1n1-acquire
# Acquires the m1n1 stage-1 bootloader for Apple Silicon.
# Supports multiple sources: bundled copy, Debian package download, manual path.
#
# Sources (in priority order):
#   1. --m1n1-path <file>       (explicit path provided by user/GUI)
#   2. libexec/m1n1.macho       (bundled with Cidre.app)
#   3. ~/.local/share/cidre/m1n1/cached/m1n1.macho (previously cached)
#   4. Download from Debian sid arm64 package (automatic)

m1n1_path=""
cache_dir="${HOME}/.local/share/cidre/m1n1"
force=false
json_mode=false
dry_run=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --m1n1-path) m1n1_path="$2"; shift 2 ;;
    --cache-dir) cache_dir="$2"; shift 2 ;;
    --force) force=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-m1n1-acquire [--m1n1-path <file>] [--cache-dir <dir>] [--force] [--dry-run] [--json]"
      echo "Acquires the m1n1 stage-1 bootloader for Apple Silicon."
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

found_path=""
found_version="unknown"
found_source=""
status="passed"
summary=""
errors=""

# ── Source 1: Explicit --m1n1-path ───────────────────────────────────
if [ -n "$m1n1_path" ] && [ -f "$m1n1_path" ]; then
  if [ "$dry_run" = false ]; then
    found_path="$m1n1_path"
    found_source="explicit-path"
    summary="Using m1n1 from explicit path: $m1n1_path"
  fi
fi

# ── Source 2: Bundled in repo (libexec/m1n1.macho) ──────────────────
if [ -z "$found_path" ]; then
  bundled_path="$REPO_ROOT/libexec/m1n1.macho"
  if [ -f "$bundled_path" ]; then
    if [ "$dry_run" = false ]; then
      found_path="$bundled_path"
      found_source="bundled"
      summary="Using bundled m1n1: $bundled_path"
    fi
  fi
fi

# ── Source 3: Cached ─────────────────────────────────────────────────
if [ -z "$found_path" ]; then
  cached_path="$cache_dir/cached/m1n1.macho"
  if [ -f "$cached_path" ] && [ "$force" != "true" ]; then
    if [ "$dry_run" = false ]; then
      found_path="$cached_path"
      found_source="cached"
      summary="Using cached m1n1: $cached_path"
    fi
  fi
fi

# ── Source 4: Download Debian package ────────────────────────────────
if [ -z "$found_path" ] && [ "$dry_run" = false ]; then
  mkdir -p "$cache_dir/tmp" "$cache_dir/cached"

  # Debian sid m1n1 package for arm64
  DEB_MIRROR="http://ftp.debian.org/debian"
  # Try to get the latest package URL from Debian
  deb_url=""

  # Known working URL pattern (update version as needed)
  for pkg_ver in "1.5.2-2" "1.5.1-1" "1.4.2-1"; do
    test_url="${DEB_MIRROR}/pool/main/m/m1n1/m1n1_${pkg_ver}_arm64.deb"
    if curl -sL -o /dev/null -w "%{http_code}" "$test_url" 2>/dev/null | grep -q "200"; then
      deb_url="$test_url"
      found_version="$pkg_ver"
      break
    fi
  done

  if [ -n "$deb_url" ]; then
    deb_file="$cache_dir/tmp/m1n1.deb"
    if curl -sL -o "$deb_file" "$deb_url" 2>/dev/null; then
      # Extract m1n1.macho from the .deb (it's an ar archive containing data.tar.xz)
      mkdir -p "$cache_dir/tmp/extract"
      if command -v ar >/dev/null 2>&1; then
        cd "$cache_dir/tmp/extract"
        ar x "$deb_file" data.tar.xz 2>/dev/null || ar x "$deb_file" data.tar.zst 2>/dev/null || true
        if [ -f data.tar.xz ]; then
          tar xf data.tar.xz --strip-components=3 2>/dev/null || true
        elif [ -f data.tar.zst ]; then
          tar --zstd -xf data.tar.zst --strip-components=3 2>/dev/null || true
        fi
        # Find the m1n1 binary
        possible="$(find . -name "m1n1*" -type f 2>/dev/null | head -1)"
        if [ -n "$possible" ] && [ -s "$possible" ]; then
          cp "$possible" "$cache_dir/cached/m1n1.macho"
          found_path="$cache_dir/cached/m1n1.macho"
          found_source="debian-package"
          summary="Downloaded m1n1 v${found_version} from Debian sid"
        fi
        cd "$SCRIPT_DIR"
      fi
    fi
    rm -rf "$cache_dir/tmp"
  fi
fi

# ── Source 5: Check for m1n1 in Asahi Fedora/ALARM packages ─────────
if [ -z "$found_path" ] && [ "$dry_run" = false ]; then
  # As a fallback, check common Asahi Linux paths on the system
  for try_path in \
    "/usr/share/asahi/m1n1.macho" \
    "/usr/lib/asahi/m1n1.macho" \
    "/boot/efi/m1n1.macho" \
    "/usr/lib/firmware/m1n1.macho"; do
    if [ -f "$try_path" ]; then
      found_path="$try_path"
      found_source="system-path"
      summary="Found m1n1 at: $try_path"
      break
    fi
  done
fi

# ── Verify ───────────────────────────────────────────────────────────
if [ -n "$found_path" ] && [ "$dry_run" = false ]; then
  # Basic validation: m1n1.macho should be a Mach-O binary
  if command -v file >/dev/null 2>&1; then
    file_type="$(file -b "$found_path" 2>/dev/null || echo "unknown")"
    if printf '%s' "$file_type" | grep -qi "mach-o"; then
      found_version="$(printf '%s' "$file_type" | grep -o 'version [0-9.]*' || echo "unknown")"
      summary="${summary} (valid Mach-O)"
    else
      errors="File at $found_path is not a valid Mach-O binary: $file_type"
      status="blocked"
      found_path=""
    fi
  fi

  # Check file size is reasonable (m1n1 is ~150-500KB)
  fsize="$(stat -f%z "$found_path" 2>/dev/null || echo 0)"
  if [ "$fsize" -lt 1000 ] 2>/dev/null; then
    errors="m1n1 file too small ($fsize bytes)"
    status="blocked"
    found_path=""
  fi
fi

# ── Dry run ──────────────────────────────────────────────────────────
if [ "$dry_run" = true ]; then
  found_path="/dry-run/path/m1n1.macho"
  found_source="dry-run"
  found_version="simulated"
  summary="Dry-run: would search for m1n1 in bundled/cached/debian locations"
fi

# ── Output ───────────────────────────────────────────────────────────
if [ -z "$found_path" ] && [ "$dry_run" = false ]; then
  status="blocked"
  summary="m1n1 bootloader not found. Options: (1) Place m1n1.macho at libexec/m1n1.macho (2) Install Rust and run: git clone https://github.com/AsahiLinux/m1n1 && cd m1n1 && make RELEASE=1 CHAINLOADING=1 && cp build/m1n1.macho <cidre>/libexec/m1n1.macho (3) Pass --m1n1-path with explicit path"
  [ -n "$errors" ] && summary="$summary Error: $errors"
fi

python3 - "$json_mode" "$status" "$summary" "$found_path" "$found_version" "$found_source" <<'PY'
import json, sys
json_mode, status, summary, found_path, found_version, found_source = sys.argv[1:]
json_mode = json_mode == "true"
exit_code = 0 if status == "passed" else 4

payload = {
    "schema_version": 1,
    "command": "cidre-app-m1n1-acquire",
    "status": status,
    "summary": summary,
    "exit_code": exit_code,
    "m1n1_path": found_path if found_path else None,
    "m1n1_version": found_version if found_version else None,
    "source": found_source if found_source else None,
}

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(exit_code)
PY

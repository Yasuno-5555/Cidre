#!/bin/sh
set -eu

JACKROSE_REPO_ROOT="${JACKROSE_REPO_ROOT:-/home/yasuno/Projects/Jackrose}"
STAGES_JSON="$JACKROSE_REPO_ROOT/installer/stages.json"

usage() {
  cat <<'EOF'
Usage:
  jackrose-install-stage [options]

Options:
  --list
  --current
  --next
  --validate
  --help
EOF
}

if [ "$#" -eq 0 ]; then
  usage
  exit 1
fi

# We will use python3 to read and process installer/stages.json
run_py() {
  python3 -c '
import sys, json, os

repo_root = sys.argv[1]
stages_file = sys.argv[2]
cmd = sys.argv[3]

if not os.path.exists(stages_file):
    print(f"ERROR: Stages file not found at {stages_file}", file=sys.stderr)
    sys.exit(1)

with open(stages_file) as f:
    data = json.load(f)

stages = data.get("stages", [])

if cmd == "list":
    for s in stages:
        print(s["name"])
elif cmd == "validate":
    if not stages:
        print("ERROR: No stages found in stages.json", file=sys.stderr)
        sys.exit(1)
    names = [s["name"] for s in stages]
    if len(names) != len(set(names)):
        print("ERROR: Duplicate stage names found", file=sys.stderr)
        sys.exit(1)
    
    # Check that all next stages exist, except for terminal one
    terminal_found = False
    for s in stages:
        nxt = s.get("next")
        if not nxt:
            terminal_found = True
        else:
            if nxt not in names:
                print("ERROR: next stage %s for %s does not exist" % (nxt, s.get("name")), file=sys.stderr)
                sys.exit(1)
    if not terminal_found:
        print("ERROR: No terminal stage (stage with empty next) found", file=sys.stderr)
        sys.exit(1)
    print("[OK] stages.json validation successful")

elif cmd == "current" or cmd == "next":
    # Get current stage from current state
    if "JACKROSE_INSTALL_STATE_FILE" in os.environ:
        state_file = os.environ["JACKROSE_INSTALL_STATE_FILE"]
    elif os.geteuid() == 0 and sys.platform.startswith("linux"):
        state_file = "/var/lib/jackrose/install/install-state.json"
    else:
        state_file = os.path.expanduser("~/.local/state/jackrose/install/current/install-state.json")
    
    current_stage = "macos-preflight"
    if os.path.exists(state_file):
        try:
            with open(state_file) as sf:
                state_data = json.load(sf)
                current_stage = state_data.get("stage", "macos-preflight")
        except Exception:
            pass

    if cmd == "current":
        print(current_stage)
    elif cmd == "next":
        # Find next stage
        nxt = ""
        for s in stages:
            if s["name"] == current_stage:
                nxt = s.get("next", "")
                break
        print(nxt)
' "$JACKROSE_REPO_ROOT" "$STAGES_JSON" "$@"
}

case "$1" in
  --list)
    run_py list
    ;;
  --validate)
    run_py validate
    ;;
  --current)
    run_py current
    ;;
  --next)
    run_py next
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    printf 'ERROR: Unknown option: %s\n' "$1" >&2
    usage
    exit 1
    ;;
esac

#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  jackrose-report-index [options]

Options:
  --scan
  --json
  --markdown
  --help
EOF
}

mode="scan"
format="default"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --scan) mode="scan"; shift ;;
    --json) format="json"; shift ;;
    --markdown) format="markdown"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

python3 -c '
import sys, os, json, datetime

format_mode = sys.argv[1]

# Directories to search
home = os.path.expanduser("~")
search_dirs = [
    os.path.join(home, ".local/state/jackrose/install/current"),
    os.path.join(home, ".local/state/jackrose/uninstall/current"),
    os.path.join(home, ".local/state/jackrose/recovery/current"),
    os.path.join(home, ".local/state/jackrose/rescue/current"),
    os.path.join(home, ".local/state/jackrose/macos-bootstrap"),
    os.path.join(home, ".local/state/jackrose/macos-uninstall")
]

reports = []
for d in search_dirs:
    if os.path.exists(d):
        for f in os.listdir(d):
            if f.endswith(".md") or f.endswith("-report.md") or "report" in f:
                path = os.path.join(d, f)
                reports.append({
                    "name": f,
                    "path": path,
                    "size": os.path.getsize(path),
                    "modified": datetime.datetime.utcfromtimestamp(os.path.getmtime(path)).strftime("%Y-%m-%dT%H:%M:%SZ")
                })

res = {
    "schema_version": 1,
    "scanned_at": datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
    "reports": reports
}

if format_mode == "json":
    print(json.dumps(res, indent=2))
elif format_mode == "markdown":
    print("# Jackrose Report Index\n")
    print("| Report Name | Last Modified | Path |")
    print("|---|---|---|")
    for r in reports:
        print("| %s | %s | %s |" % (r["name"], r["modified"], r["path"]))
else:
    print("Scanned report files:")
    for r in reports:
        print("  %s (%s)" % (r["name"], r["modified"]))
' "$format"

#!/bin/bash
# jackrose-recovery: Jackrose emergency system recovery command
set -euo pipefail

JACKROSE_SYSTEM_ROOT="${JACKROSE_SYSTEM_ROOT:-/var/lib/jackrose}"
SYSTEM_SEED_ENV="${JACKROSE_SYSTEM_ROOT}/seed/resume.env"
SYSTEM_RESUME_ENV="${JACKROSE_SYSTEM_ROOT}/resume/resume.env"

show_help() {
  echo "Usage: jackrose-recovery <command> [options]"
  echo "Commands:"
  echo "  help                 Show this help message"
  echo "  status               Show status of critical login, session, and keyboard services"
  echo "  doctor               Run diagnostic health checks on key desktop services"
  echo "  list                 List available legacy niri configurations and backups"
  echo "  snapshots            List available configuration snapshots (jackrose-snapshot list)"
  echo "  restore <id|latest>  Restore files from a snapshot (delegates to jackrose-snapshot)"
  echo "  seed-status          Show imported seed status"
  echo "  resume-status        Show imported resume status"
  echo "  downstream-status    Show downstream foundation prototype status"
  echo "  image-status         Show prototype image artifact status"
  echo "  builder-status       Show builder configuration and staging status"
  echo "  real-build-status    Show real image build status"
  echo "  boot-test-status     Show controlled boot test status"
  echo "  firstboot-status     Show firstboot OOBE state"
  echo "  firstboot-diagnose   Run diagnostics check suite on firstboot state"
  echo "  firstboot-retry      Retry firstboot state setup"
  echo "  firstboot-repair     Repair missing or failed firstboot parameters"
  echo "  firstboot-report     Compile markdown firstboot validation report"
  echo "  user-phase-status    Show status of normal user phase setup"
  echo "  user-phase-report    Compile markdown user phase report"
  echo "  user-phase-repair    Repair common user phase markers or configs"
  echo "  user-handoff         Show, verify, or import root-side handoffs"
  echo "  uninstall-status     Show uninstall readiness status"
  echo "  exit-plan            Generate a human-readable exit plan"
  echo "  state-export         Export Jackrose state before cleanup"
  echo "  partition-audit      Record a read-only partition audit"
  echo "  macos-restore-guide  Generate a macOS restore checklist"
  echo "  goodbye              Generate final uninstall summary"
  echo "  macos-restore-status Show macOS restore assistant status or guidance"
  echo "  macos-restore-report Show macOS restore report path or guidance"
  echo "  screen               Show the Jackrose Recovery Screen"
  echo "  panic                Trigger the Jackrose panic entrypoint"
  echo "  actions              List or run recovery actions"
  echo "  recovery-report      Generate a recovery report"
  echo "  clear-safe-mode      Clear safe-mode markers"
  echo "  install-status       Show guided installer status"
  echo "  install-dashboard    Show guided installer dashboard"
  echo "  install-report       Show guided installer report"
  echo "  install-resume       Show guided installer resume command"
  echo "  install-failure-report Show guided installer failure report"
  echo "  rescue-status        Run Rescue Slot readiness checks"
  echo "  rescue-plan          Generate a Rescue Slot plan"
  echo "  rescue-report        Generate a Rescue Slot report"
  echo "  uninstall-status     Show guided uninstaller status"
  echo "  uninstall-dashboard  Show guided uninstaller dashboard"
  echo "  uninstall-export     Export Jackrose state before uninstall"
  echo "  uninstall-plan       Generate guided uninstall plan"
  echo "  uninstall-dry-run    Preview uninstall changes"
  echo "  uninstall-report     Generate guided uninstall report"
  echo "  uninstall-resume     Show or run pending uninstall command"
  echo "  interface-status     Show interface integration diagnostics"
  echo "  app-readiness        Show App backend readiness diagnostics"
  echo "  report-index         Inspect index of generated reports"
  echo "  app-prototype-status Show SwiftUI App prototype check status"
  echo "  app-guided-ui-status Show SwiftUI App guided UI check status"
  echo "  app-safe-actions     List safe App-Ready actions"
  echo "  app-live-check       Verify App backend live compatibility"
  echo "  app-execution-policy Show App execution policy boundaries"
  echo "  app-fixtures         Generate SwiftUI App mock fixtures"
  echo "  app-report-preview   Generate SwiftUI App report preview"
  echo "  app-runtime-status   Show app runtime validation status"
  echo "  app-build-check      Run app build validation"
  echo "  app-runtime-report   Generate app runtime validation report"
  echo "  app-runtime-logs     Collect app runtime logs"
  echo "  dfu-incident-status  Show DFU incident containment status"
  echo "  boot-safety-status   Show boot safety gate status"
  echo "  protected-partition-check Show protected partition guard status"
  echo "  disk-snapshot-status Show latest disk snapshot status"
  echo "  protected-partition-status Show protected partition status"
  echo "  disk-diff-status     Show disk diff status"
  echo "  recovery-survival-status Show recovery survival status"
  echo "  installer-killswitch-status Show installer containment switch status"
  echo "  boot-failure-report  Generate or refresh DFU incident report"
  echo "  gate-status         Show integrated gate status"
  echo "  finish-gate-status  Show finish gate status"
  echo "  helper-gate-status  Show helper gate status"
  echo "  wizard-gate-status  Show wizard gate status"
  echo "  gate-report         Generate gate report"
  echo "  mutation-test-status Show controlled mutation test mode status"
  echo "  disposable-target-status Show disposable target policy guidance"
  echo "  mutation-plan-status Show latest mutation plan status"
  echo "  mutation-report     Show latest controlled mutation report"
  echo "  live-drill-status   Show latest live drill status"
  echo "  live-drill-report   Show latest live drill report"
  echo "  live-drill-clean    Clean old live drill state"
  echo "  controlled-install-status Show latest controlled install status"
  echo "  install-target-status Show latest install target check status"
  echo "  no-default-boot-status Show latest no-default-boot check status"
  echo "  manual-boot-guide   Show manual boot instructions"
  echo "  install-report      Show latest controlled install report"


  echo "  rescue-build         Build Rescue Slot overlay artifact"
  echo "  rescue-inspect       Inspect Rescue Slot overlay"
  echo "  rescue-boot-status   Show rescue boot integration status"
  echo "  rescue-boot-plan     Generate rescue boot plan"
  echo "  rescue-boot-report   Generate rescue boot report"
  echo "  rescue-boot-checklist Generate rescue boot checklist"
  echo "  rescue-create-dry-run Generate rescue creation dry-run"
  echo "  rescue-create-status Show rescue creation status"
  echo "  rescue-create-preflight Run rescue creation preflight"
  echo "  rescue-create-report Generate rescue creation report"
  echo "  rescue-target-check  Run rescue target check"
  echo "  rescue-create-clean  Clean rescue creation state"
  echo "  boot-status          Show image boot validation status"
  echo "  disable-greetd       Disable greetd system service and restore fallback console"
  echo "  enable-greetd        Enable greetd system service to launch the graphical desktop"
  echo "  reset-niri           Restore default config.kdl to ~/.config/niri/"
  echo "  reset-waybar         Restore default waybar configuration to ~/.config/waybar/"
  echo "  reset-shell          Restore default fish shell configuration to ~/.config/fish/"
  echo "  reset-user-config    Re-run jackrose-user-setup with --force option"
  echo "  collect-logs         Collect system logs for debugging and save to ~/jackrose-recovery-report-*.tar.gz"
  echo "  safe-mode            Back up config, disable greetd, and set up safe defaults"
}

if [ $# -lt 1 ]; then
  show_help
  exit 1
fi

CMD="$1"
shift

case "$CMD" in
  help)
    show_help
    ;;
  status)
    echo "=== Jackrose System Status ==="
    if systemctl is-active --quiet greetd; then
      echo "greetd service:    Active (Graphical Login)"
    else
      echo "greetd service:    Inactive (Console Login)"
    fi
    if systemctl --user is-active --quiet pipewire 2>/dev/null; then
      echo "PipeWire:          Active"
    else
      echo "PipeWire:          Inactive"
    fi
    if command -v localectl >/dev/null 2>&1; then
      echo "Locale keymap:"
      localectl status | grep "Keymap" || echo "  Unknown"
    fi
    ;;
  doctor)
    echo "=== Running Jackrose Recovery Doctor ==="
    if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
      echo "[OK] Session is running Wayland."
    else
      echo "[WARN] Session is not running Wayland (XDG_SESSION_TYPE='${XDG_SESSION_TYPE:-}')."
    fi
    if [ -f "$HOME/.config/niri/config.kdl" ]; then
      echo "[OK] Niri configuration found."
    else
      echo "[FAIL] Niri configuration is missing at ~/.config/niri/config.kdl."
    fi
    if systemctl --user is-active --quiet fcitx5 2>/dev/null; then
      echo "[OK] fcitx5.service systemd user unit is running."
    else
      echo "[WARN] fcitx5.service is not active."
    fi
    if pgrep waybar >/dev/null; then
      echo "[OK] Waybar is running."
    else
      echo "[WARN] Waybar is not running."
    fi
    
    echo ""
    echo "Rollback Suggestion:"
    echo "  If things broke after a config change, run: 'jackrose-recovery restore latest'"
    ;;
  list)
    echo "=== Available Niri Config Backups ==="
    if [ -d "$HOME/.config/niri" ]; then
      find "$HOME/.config/niri" -name "config.kdl.bak.*" -type f | sort -r || echo "No backups found."
    else
      echo "Niri config directory does not exist."
    fi
    ;;
  snapshots)
    if command -v jackrose-snapshot >/dev/null 2>&1; then
      jackrose-snapshot list
    elif [ -f "./jackrose-snapshot" ]; then
      ./jackrose-snapshot list
    elif [ -f "/usr/bin/jackrose-snapshot" ]; then
      /usr/bin/jackrose-snapshot list
    elif [ -f "$(dirname "$0")/jackrose-snapshot" ]; then
      "$(dirname "$0")/jackrose-snapshot" list
    else
      echo "Error: jackrose-snapshot command not found." >&2
      exit 1
    fi
    ;;
  restore)
    if [ $# -lt 1 ]; then
      echo "Error: Please specify a snapshot ID or 'latest'." >&2
      exit 1
    fi
    TARGET="$1"
    # Delegate directly to jackrose-snapshot
    if command -v jackrose-snapshot >/dev/null 2>&1; then
      jackrose-snapshot restore "$TARGET"
    elif [ -f "./jackrose-snapshot" ]; then
      ./jackrose-snapshot restore "$TARGET"
    elif [ -f "/usr/bin/jackrose-snapshot" ]; then
      /usr/bin/jackrose-snapshot restore "$TARGET"
    elif [ -f "$(dirname "$0")/jackrose-snapshot" ]; then
      "$(dirname "$0")/jackrose-snapshot" restore "$TARGET"
    else
      echo "Error: jackrose-snapshot command not found." >&2
      exit 1
    fi
    ;;
  seed-status)
    echo "Jackrose seed:"
    if [ -f "$SYSTEM_SEED_ENV" ]; then
      # shellcheck disable=SC1090
      . "$SYSTEM_SEED_ENV"
      echo "  imported: yes"
      echo "  profile: ${JACKROSE_SEED_PROFILE:-unknown}"
      echo "  source commit: ${JACKROSE_SEED_SOURCE_COMMIT:-unknown}"
    else
      echo "  imported: no"
    fi
    ;;
  resume-status)
    echo "Jackrose resume:"
    if [ -f "$SYSTEM_RESUME_ENV" ]; then
      # shellcheck disable=SC1090
      . "$SYSTEM_RESUME_ENV"
      echo "  available: yes"
      echo "  profile: ${JACKROSE_RESUME_PROFILE:-unknown}"
      if [ -f "$HOME/.local/state/jackrose/resume/applied-profile" ]; then
        echo "  applied by user: yes"
      else
        echo "  applied by user: no"
      fi
    else
      echo "  available: no"
    fi
    ;;
  downstream-status)
    echo "Jackrose downstream foundation:"
    echo "  image prototype: not built"
    if [ -f "systemd/jackrose-firstboot-root.service" ] || [ -f "/usr/lib/jackrose/jackrose-firstboot-root" ]; then
      echo "  firstboot-root service: available"
    else
      echo "  firstboot-root service: missing"
    fi
    if [ -f "downstream/installer-entry.example.json" ]; then
      echo "  installer entry example: available"
    else
      echo "  installer entry example: missing"
    fi
    echo "  public image: not available"
    ;;
  image-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    IMAGE_OUTPUT_DIR="${REPO_ROOT}/.local/state/jackrose/image-build"
    echo "Jackrose image prototype:"
    echo "  output dir: $IMAGE_OUTPUT_DIR"
    if [ -f "$IMAGE_OUTPUT_DIR/jackrose-rootfs-overlay.tar.gz" ]; then
      echo "  overlay artifact: present"
    else
      echo "  overlay artifact: missing"
    fi
    if [ -f "$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json" ]; then
      echo "  manifest: present"
    else
      echo "  manifest: missing"
    fi
    echo "  boot tested: no"
    echo "  public image: no"
    ;;
  builder-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    echo "Jackrose builder status:"
    if [ -f "${SCRIPT_DIR}/jackrose-builder-config" ]; then
      "${SCRIPT_DIR}/jackrose-builder-config" || echo "  Failed to retrieve builder config status"
    else
      echo "  Error: jackrose-builder-config script missing"
    fi
    if [ -f "${SCRIPT_DIR}/jackrose-builder-status" ]; then
      "${SCRIPT_DIR}/jackrose-builder-status" || echo "  Failed to retrieve builder status info"
    else
      echo "  Error: jackrose-builder-status script missing"
    fi
    ;;
  real-build-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    IMAGE_OUTPUT_DIR="${REPO_ROOT}/.local/state/jackrose/image-build"
    echo "Jackrose real image build status:"

    # Builder configured
    if [ -n "${JACKROSE_ALARM_BUILDER_DIR:-}" ]; then
      echo "  builder configured: yes ($JACKROSE_ALARM_BUILDER_DIR)"
    else
      echo "  builder configured: no"
    fi

    # Last build report
    if [ -f "$IMAGE_OUTPUT_DIR/build-report.md" ]; then
      echo "  last build status: success (build-report.md found)"
    elif [ -f "$IMAGE_OUTPUT_DIR/build-failure-report.md" ]; then
      echo "  last build status: failed (build-failure-report.md found)"
    else
      echo "  last build status: missing"
    fi

    # Registered artifact
    registered_img=$(find "$IMAGE_OUTPUT_DIR/registered" -type f \( -name "*.img" -o -name "*.img.zst" -o -name "*.tar.gz" -o -name "*.raw" \) 2>/dev/null | head -n 1 || echo "")
    if [ -n "$registered_img" ]; then
      echo "  registered artifact: present ($(basename "$registered_img"))"
      # Checksum verified
      if [ -f "${registered_img}.sha256" ]; then
        echo "  checksum verified: yes"
      else
        echo "  checksum verified: no"
      fi
    else
      echo "  registered artifact: missing"
      echo "  checksum verified: no"
    fi

    # Rootfs inspected & boot readiness flags
    if [ -f "$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json" ] && command -v python3 >/dev/null 2>&1; then
      rootfs_inspected=$(python3 -c "import json; d=json.load(open('$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json')); print(d.get('validation', {}).get('rootfs_inspected', False))")
      boot_readiness=$(python3 -c "import json; d=json.load(open('$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json')); print(d.get('validation', {}).get('boot_readiness_checked', False))")
      echo "  rootfs inspected:   $rootfs_inspected"
      echo "  boot readiness:     $boot_readiness"
    else
      echo "  rootfs inspected:   no"
      echo "  boot readiness:     no"
    fi
    ;;
  boot-test-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    BOOT_TEST_DIR="${REPO_ROOT}/.local/state/jackrose/boot-test/current"
    echo "Jackrose controlled boot test status:"

    if [ -d "$BOOT_TEST_DIR" ]; then
      echo "  current test: present"
      if [ -f "$BOOT_TEST_DIR/preflight.log" ]; then
        echo "  preflight:    passed"
      else
        echo "  preflight:    missing"
      fi

      if [ -f "$BOOT_TEST_DIR/result.json" ] && command -v python3 >/dev/null 2>&1; then
        res_status=$(python3 -c "import json; d=json.load(open('$BOOT_TEST_DIR/result.json')); print(d.get('status', 'unknown'))")
        echo "  boot result:  $res_status"
      else
        echo "  boot result:  missing"
      fi

      if [ -f "$BOOT_TEST_DIR/firstboot-verify.log" ]; then
        echo "  firstboot verified: yes"
      else
        echo "  firstboot verified: no"
      fi

      if [ -f "$BOOT_TEST_DIR/report.md" ]; then
        echo "  report:       present"
      else
        echo "  report:       missing"
      fi
    else
      echo "  current test: missing"
      echo "  preflight:    missing"
      echo "  boot result:  missing"
      echo "  firstboot verified: no"
      echo "  report:       missing"
    fi
    ;;
  firstboot-status)
    if [ -z "${JACKROSE_SYSTEM_ROOT:-}" ] || [ "${JACKROSE_SYSTEM_ROOT}" = "/var/lib/jackrose" ]; then
      FIRSTBOOT_STATE_DIR="/var/lib/jackrose/firstboot-root"
    else
      FIRSTBOOT_STATE_DIR="${JACKROSE_SYSTEM_ROOT}/var/lib/jackrose/firstboot-root"
    fi
    echo "Jackrose firstboot:"
    for marker in started completed skipped failed; do
      if [ -f "$FIRSTBOOT_STATE_DIR/$marker" ]; then
        echo "  $marker: yes"
      else
        echo "  $marker: no"
      fi
    done
    if [ -f "$FIRSTBOOT_STATE_DIR/handoff.txt" ]; then
      echo "  handoff: present"
    else
      echo "  handoff: missing"
    fi
    ;;
  firstboot-diagnose)
    exec "$(dirname "$0")/jackrose-firstboot-diagnose" "$@"
    ;;
  firstboot-retry)
    exec "$(dirname "$0")/jackrose-firstboot-retry" "$@"
    ;;
  firstboot-repair)
    exec "$(dirname "$0")/jackrose-firstboot-repair" "$@"
    ;;
  firstboot-report)
    exec "$(dirname "$0")/jackrose-firstboot-report" "$@"
    ;;
  user-phase-status)
    exec "$(dirname "$0")/jackrose-user-phase-state" status "$@"
    ;;
  user-phase-report)
    exec "$(dirname "$0")/jackrose-user-phase-report" "$@"
    ;;
  user-phase-repair)
    exec "$(dirname "$0")/jackrose-user-phase-repair" "$@"
    ;;
  user-handoff)
    exec "$(dirname "$0")/jackrose-user-handoff" "$@"
    ;;
  uninstall-status)
    exec "$(dirname "$0")/jackrose-uninstall-check" "$@"
    ;;
  exit-plan)
    exec "$(dirname "$0")/jackrose-exit-plan" "$@"
    ;;
  state-export)
    exec "$(dirname "$0")/jackrose-state-export" "$@"
    ;;
  partition-audit)
    exec "$(dirname "$0")/jackrose-partition-audit" "$@"
    ;;
  macos-restore-guide)
    exec "$(dirname "$0")/jackrose-macos-restore-guide" "$@"
    ;;
  goodbye)
    exec "$(dirname "$0")/jackrose-goodbye" "$@"
    ;;
  macos-restore-status)
    if [ "$(uname -s)" = "Darwin" ]; then
      exec "$(dirname "$0")/jackrose-macos-restore-check" "$@"
    fi
    echo "macOS restore assistant requires macOS runtime."
    echo "From macOS, run:"
    echo "  ./install-macos --restore-check"
    echo "  ./install-macos --partition-audit"
    ;;
  macos-restore-report)
    if [ "$(uname -s)" = "Darwin" ]; then
      exec "$(dirname "$0")/jackrose-macos-restore-report" "$@"
    fi
    echo "macOS restore report requires macOS runtime."
    echo "From macOS, run:"
    echo "  ./install-macos --restore-report"
    ;;
  screen)
    exec "$(dirname "$0")/jackrose-recovery-screen" "$@"
    ;;
  panic)
    exec "$(dirname "$0")/jackrose-panic" "$@"
    ;;
  actions)
    exec "$(dirname "$0")/jackrose-recovery-actions" "$@"
    ;;
  recovery-report)
    exec "$(dirname "$0")/jackrose-recovery-report" "$@"
    ;;
  rescue-status)
    exec "$(dirname "$0")/jackrose-rescue-check" "$@"
    ;;
  rescue-plan)
    exec "$(dirname "$0")/jackrose-rescue-plan" "$@"
    ;;
  rescue-report)
    exec "$(dirname "$0")/jackrose-rescue-report" "$@"
    ;;
  uninstall-status)
    exec "$(dirname "$0")/jackrose-uninstall-preflight" --phase linux "$@"
    ;;
  uninstall-dashboard)
    exec "$(dirname "$0")/jackrose-uninstall-dashboard" "$@"
    ;;
  uninstall-export)
    exec "$(dirname "$0")/jackrose-uninstall-export" "$@"
    ;;
  uninstall-plan)
    exec "$(dirname "$0")/jackrose-uninstall-plan" "$@"
    ;;
  uninstall-dry-run)
    exec "$(dirname "$0")/jackrose-uninstall-dry-run" "$@"
    ;;
  uninstall-report)
    exec "$(dirname "$0")/jackrose-uninstall-report" "$@"
    ;;
  uninstall-resume)
    exec "$(dirname "$0")/jackrose-uninstall-resume" "$@"
    ;;
  interface-status)
    exec "$(dirname "$0")/jackrose-interface-doctor" "$@"
    ;;
  app-readiness)
    exec "$(dirname "$0")/jackrose-app-readiness" "$@"
    ;;
  report-index)
    exec "$(dirname "$0")/jackrose-report-index" "$@"
    ;;
  app-prototype-status)
    exec "$(dirname "$0")/jackrose-app-prototype-check" "$@"
    ;;
  app-guided-ui-status)
    exec "$(dirname "$0")/jackrose-app-ui-validation" "$@"
    ;;
  app-safe-actions)
    exec "$(dirname "$0")/jackrose-app-safe-actions" "$@"
    ;;
  app-live-check)
    exec "$(dirname "$0")/jackrose-app-live-check" "$@"
    ;;
  app-execution-policy)
    exec "$(dirname "$0")/jackrose-app-execution-policy" "$@"
    ;;
  app-fixtures)
    exec "$(dirname "$0")/jackrose-app-fixture-generate" "$@"
    ;;
  app-report-preview)
    exec "$(dirname "$0")/jackrose-app-report-preview" "$@"
    ;;
  app-runtime-status)
    exec "$(dirname "$0")/jackrose-app-runtime-result" --show "$@"
    ;;
  app-build-check)
    exec "$(dirname "$0")/jackrose-app-build-check" "$@"
    ;;
  app-runtime-report)
    exec "$(dirname "$0")/jackrose-app-runtime-report" "$@"
    ;;
  app-runtime-logs)
    exec "$(dirname "$0")/jackrose-app-runtime-log-collect" "$@"
    ;;
  dfu-incident-status)
    exec "$(dirname "$0")/jackrose-app-boot-failure-report" --incident DFU_RESTORE_001 --json
    ;;
  boot-safety-status)
    exec "$(dirname "$0")/jackrose-app-boot-safety-gate" --json
    ;;
  disk-snapshot-status)
    latest_before="$(find "$(dirname "$0")/../.local/state/jackrose/boot-safety/snapshots" -type f -name '*before*.json' 2>/dev/null | sort | tail -n 1 || true)"
    latest_after="$(find "$(dirname "$0")/../.local/state/jackrose/boot-safety/snapshots" -type f -name '*after*.json' 2>/dev/null | sort | tail -n 1 || true)"
    printf 'before=%s\nafter=%s\n' "${latest_before:-missing}" "${latest_after:-missing}"
    ;;
  protected-partition-check)
    latest_after="$(find "$(dirname "$0")/../.local/state/jackrose/boot-safety/snapshots" -type f -name '*.json' 2>/dev/null | sort | tail -n 1 || true)"
    if [ -z "$latest_after" ]; then
      echo "No disk snapshot found yet." >&2
      exit 4
    fi
    exec "$(dirname "$0")/jackrose-app-protected-partition-guard" --snapshot "$latest_after" --json
    ;;
  protected-partition-status)
    exec "$(dirname "$0")/jackrose-recovery" protected-partition-check
    ;;
  disk-diff-status)
    latest_before="$(find "$(dirname "$0")/../.local/state/jackrose/boot-safety/snapshots" -type f -name '*before*.json' 2>/dev/null | sort | tail -n 1 || true)"
    latest_after="$(find "$(dirname "$0")/../.local/state/jackrose/boot-safety/snapshots" -type f -name '*after*.json' 2>/dev/null | sort | tail -n 1 || true)"
    if [ -z "$latest_before" ] || [ -z "$latest_after" ]; then
      echo "Disk diff requires before and after snapshots." >&2
      exit 4
    fi
    exec "$(dirname "$0")/jackrose-app-prepost-disk-diff" --before "$latest_before" --after "$latest_after" --json
    ;;
  recovery-survival-status)
    exec "$(dirname "$0")/jackrose-app-recovery-survival-check" --json
    ;;
  installer-killswitch-status)
    exec "$(dirname "$0")/jackrose-app-installer-killswitch" --status --json
    ;;
  gate-status)
    exec "$(dirname "$0")/jackrose-app-gate-evaluate" --scope install --json
    ;;
  finish-gate-status)
    exec "$(dirname "$0")/jackrose-app-finish-gate" --json
    ;;
  helper-gate-status)
    exec "$(dirname "$0")/jackrose-app-helper-gate" --operation partition-create --json
    ;;
  wizard-gate-status)
    exec "$(dirname "$0")/jackrose-app-wizard-gate" --from disk-planning --to install-execution --json
    ;;
  gate-report)
    exec "$(dirname "$0")/jackrose-app-gate-report" --json
    ;;
  mutation-test-status)
    exec "$(dirname "$0")/jackrose-app-mutation-test-mode" --status --json
    ;;
  disposable-target-status)
    echo "Run: $(dirname "$0")/jackrose-app-disposable-target-check --target <diskXsY> --json"
    ;;
  mutation-plan-status)
    if [ -f ".local/state/jackrose/mutation/current/last-plan.json" ]; then
      cat ".local/state/jackrose/mutation/current/last-plan.json"
    else
      echo "No mutation plan recorded yet."
    fi
    ;;
  mutation-report)
    exec "$(dirname "$0")/jackrose-app-mutation-report" --markdown
    ;;
  live-drill-status)
    exec "$(dirname "$0")/jackrose-app-live-drill-state" --status --json
    ;;
  live-drill-report)
    exec "$(dirname "$0")/jackrose-app-live-drill-report" --markdown
    ;;
  live-drill-clean)
    exec "$(dirname "$0")/jackrose-app-live-drill-clean" --keep-latest 5 --json
    ;;
  controlled-install-status)
    exec "$(dirname "$0")/jackrose-app-controlled-install" --status --json
    ;;
  install-target-status)
    exec "$(dirname "$0")/jackrose-app-install-target-check" --fixture "$(dirname "$0")/../test/fixtures/controlled-install/install-target-valid.json" --json
    ;;
  no-default-boot-status)
    exec "$(dirname "$0")/jackrose-app-no-default-boot-check" --fixture "$(dirname "$0")/../test/fixtures/controlled-install/no-default-boot-valid.json" --json
    ;;
  manual-boot-guide)
    exec "$(dirname "$0")/jackrose-app-manual-boot-guide" --markdown
    ;;
  install-report)
    exec "$(dirname "$0")/jackrose-app-install-report" --markdown
    ;;
  boot-failure-report)
    exec "$(dirname "$0")/jackrose-app-boot-failure-report" --incident DFU_RESTORE_001 --json
    ;;

  rescue-build)
    exec "$(dirname "$0")/jackrose-rescue-image-build" "$@"
    ;;
  rescue-inspect)
    if [ $# -eq 0 ]; then
      exec "$(dirname "$0")/jackrose-rescue-image-inspect" --overlay "$(dirname "$0")/../rescue/overlay"
    fi
    exec "$(dirname "$0")/jackrose-rescue-image-inspect" "$@"
    ;;
  rescue-boot-status)
    exec "$(dirname "$0")/jackrose-rescue-boot-risk" "$@"
    ;;
  rescue-boot-plan)
    exec "$(dirname "$0")/jackrose-rescue-boot-plan" "$@"
    ;;
  rescue-boot-report)
    exec "$(dirname "$0")/jackrose-rescue-boot-report" "$@"
    ;;
  rescue-boot-checklist)
    exec "$(dirname "$0")/jackrose-rescue-boot-checklist" "$@"
    ;;
  rescue-create-dry-run)
    exec "$(dirname "$0")/jackrose-rescue-create-dry-run" "$@"
    ;;
  rescue-create-status)
    exec "$(dirname "$0")/jackrose-rescue-create-risk" "$@"
    ;;
  rescue-create-preflight)
    exec "$(dirname "$0")/jackrose-rescue-create-preflight" "$@"
    ;;
  rescue-create-report)
    exec "$(dirname "$0")/jackrose-rescue-create-report" "$@"
    ;;
  rescue-target-check)
    exec "$(dirname "$0")/jackrose-rescue-target-check" "$@"
    ;;
  rescue-create-clean)
    exec "$(dirname "$0")/jackrose-rescue-create-clean" "$@"
    ;;
  clear-safe-mode)
    exec "$(dirname "$0")/jackrose-recovery-actions" --run clear-safe-mode "$@"
    ;;
  boot-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    IMAGE_OUTPUT_DIR="${REPO_ROOT}/.local/state/jackrose/image-build"
    BOOT_LOG_DIR="${HOME}/.local/state/jackrose/boot-validation"

    echo "Jackrose boot validation:"

    if [ -f "$IMAGE_OUTPUT_DIR/jackrose-rootfs-overlay.tar.gz" ]; then
      echo "  image artifact:     present"
    else
      echo "  image artifact:     missing"
    fi

    if [ -f "$IMAGE_OUTPUT_DIR/inspect.log" ]; then
      echo "  rootfs inspected:   yes (inspect.log found)"
    else
      echo "  rootfs inspected:   no"
    fi

    if [ -f "$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json" ]; then
      # Check boot_readiness_checked field if present
      if command -v python3 >/dev/null 2>&1; then
        brc="$(python3 -c "
import json, sys
try:
  d = json.load(open('$IMAGE_OUTPUT_DIR/jackrose-image-manifest.json'))
  print(d.get('validation', {}).get('boot_readiness_checked', False))
except:
  print('unknown')
" 2>/dev/null || echo 'unknown')"
        echo "  boot readiness:     $brc"
      else
        echo "  boot readiness:     unknown (python3 not available)"
      fi
    else
      echo "  boot readiness:     no manifest"
    fi

    echo "  real boot tested:   no"

    if [ -d "$BOOT_LOG_DIR" ] && [ -n "$(ls -A "$BOOT_LOG_DIR" 2>/dev/null)" ]; then
      echo "  last log bundle:    present ($BOOT_LOG_DIR)"
    else
      echo "  last log bundle:    missing"
    fi
    ;;
  disable-greetd)
    if [ "$EUID" -ne 0 ]; then
      echo "Error: Please run as root (sudo)." >&2
      exit 1
    fi
    echo "Disabling greetd..."
    systemctl disable greetd
    systemctl stop greetd || true
    echo "greetd disabled. Fallback to TTY is now active."
    ;;
  enable-greetd)
    if [ "$EUID" -ne 0 ]; then
      echo "Error: Please run as root (sudo)." >&2
      exit 1
    fi
    echo "Enabling greetd..."
    systemctl enable greetd
    systemctl start greetd || true
    echo "greetd enabled and started."
    ;;
  reset-niri)
    read -p "Are you sure you want to reset Niri configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    # Make backup snapshot first
    if command -v jackrose-snapshot >/dev/null 2>&1; then
      jackrose-snapshot create --label "pre-reset-niri"
    elif [ -f "./jackrose-snapshot" ]; then
      ./jackrose-snapshot create --label "pre-reset-niri"
    elif [ -f "/usr/bin/jackrose-snapshot" ]; then
      /usr/bin/jackrose-snapshot create --label "pre-reset-niri"
    elif [ -f "$(dirname "$0")/jackrose-snapshot" ]; then
      "$(dirname "$0")/jackrose-snapshot" create --label "pre-reset-niri"
    fi
    mkdir -p "$HOME/.config/niri"
    if [ -f "/usr/share/jackrose/defaults/niri/config.kdl" ]; then
      cp /usr/share/jackrose/defaults/niri/config.kdl "$HOME/.config/niri/config.kdl"
      echo "Niri config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-waybar)
    read -p "Are you sure you want to reset Waybar configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    if command -v jackrose-snapshot >/dev/null 2>&1; then
      jackrose-snapshot create --label "pre-reset-waybar"
    elif [ -f "./jackrose-snapshot" ]; then
      ./jackrose-snapshot create --label "pre-reset-waybar"
    elif [ -f "/usr/bin/jackrose-snapshot" ]; then
      /usr/bin/jackrose-snapshot create --label "pre-reset-waybar"
    elif [ -f "$(dirname "$0")/jackrose-snapshot" ]; then
      "$(dirname "$0")/jackrose-snapshot" create --label "pre-reset-waybar"
    fi
    mkdir -p "$HOME/.config/waybar"
    if [ -f "/usr/share/jackrose/defaults/waybar/config" ]; then
      cp /usr/share/jackrose/defaults/waybar/config "$HOME/.config/waybar/config"
      cp /usr/share/jackrose/defaults/waybar/style.css "$HOME/.config/waybar/style.css"
      echo "Waybar config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-shell)
    read -p "Are you sure you want to reset Fish configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    if command -v jackrose-snapshot >/dev/null 2>&1; then
      jackrose-snapshot create --label "pre-reset-shell"
    elif [ -f "./jackrose-snapshot" ]; then
      ./jackrose-snapshot create --label "pre-reset-shell"
    elif [ -f "/usr/bin/jackrose-snapshot" ]; then
      /usr/bin/jackrose-snapshot create --label "pre-reset-shell"
    elif [ -f "$(dirname "$0")/jackrose-snapshot" ]; then
      "$(dirname "$0")/jackrose-snapshot" create --label "pre-reset-shell"
    fi
    mkdir -p "$HOME/.config/fish"
    if [ -f "/usr/share/jackrose/defaults/fish/config.fish" ]; then
      cp /usr/share/jackrose/defaults/fish/config.fish "$HOME/.config/fish/config.fish"
      echo "Fish config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-niri-config)
    echo "Note: reset-niri-config is deprecated, redirecting to reset-niri..."
    $0 reset-niri
    ;;
  reset-user-config)
    read -p "Are you sure you want to re-run jackrose-user-setup --force? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    echo "Resetting user config..."
    if command -v jackrose-user-setup >/dev/null 2>&1; then
      jackrose-user-setup --force
    elif [ -f "./jackrose-user-setup" ]; then
      ./jackrose-user-setup --force
    elif [ -f "/usr/bin/jackrose-user-setup" ]; then
      /usr/bin/jackrose-user-setup --force
    else
      echo "Error: jackrose-user-setup command not found." >&2
      exit 1
    fi
    ;;
  collect-logs)
    echo "Collecting logs..."
    TS=$(date +%Y%m%d-%H%M%S)
    REPORT_DIR="/tmp/jackrose-recovery-report-${TS}"
    mkdir -p "$REPORT_DIR"
    
    journalctl -b -n 200 > "${REPORT_DIR}/journal.log" || true
    journalctl --user -b -n 200 > "${REPORT_DIR}/journal-user.log" || true
    systemctl status greetd > "${REPORT_DIR}/greetd-status.log" || true
    wpctl status > "${REPORT_DIR}/wireplumber.log" || true
    localectl status > "${REPORT_DIR}/locale.log" || true
    
    mkdir -p "${REPORT_DIR}/configs"
    cp -r "$HOME/.config/niri" "${REPORT_DIR}/configs/niri" || true
    cp -r "$HOME/.config/fcitx5" "${REPORT_DIR}/configs/fcitx5" || true
    cp -r "$HOME/.config/environment.d" "${REPORT_DIR}/configs/environment.d" || true
    
    REPORT_FILE="${HOME}/jackrose-recovery-report-${TS}.tar.gz"
    tar -czf "$REPORT_FILE" -C /tmp "jackrose-recovery-report-${TS}"
    rm -rf "$REPORT_DIR"
    echo "Logs collected at $REPORT_FILE"
    ;;
  safe-mode)
    exec "$(dirname "$0")/jackrose-safe-mode" "$@"
    ;;
  install-status)
    exec "$(dirname "$0")/jackrose-install-state" --show "$@"
    ;;
  install-dashboard)
    exec "$(dirname "$0")/jackrose-install-dashboard" "$@"
    ;;
  install-report)
    exec "$(dirname "$0")/jackrose-install-report" "$@"
    ;;
  install-resume)
    exec "$(dirname "$0")/jackrose-install-resume" "$@"
    ;;
  install-failure-report)
    exec "$(dirname "$0")/jackrose-install-failure-report" "$@"
    ;;
  *)
    show_help
    exit 1
    ;;
esac

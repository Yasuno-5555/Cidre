#!/bin/sh
set -eu

if [ "$(uname)" != "Darwin" ]; then
  printf "ERROR: this command requires macOS.\nNo disk operation was performed.\n" >&2
  exit 1
fi

if [ -n "${JACKROSE_UNINSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$JACKROSE_UNINSTALL_STATE_FILE"
else
  STATE_FILE="${HOME}/.local/state/jackrose/macos-uninstall/current/uninstall-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  jackrose-macos-uninstall-dashboard [options]

Options:
  --json
  --next
  --help
EOF
}

cmd="default"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) cmd="json"; shift ;;
    --next) cmd="next"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

python3 -c '
import sys, os, json

state_file = sys.argv[1]
cmd = sys.argv[2]

state_data = {}
if os.path.exists(state_file):
    try:
        with open(state_file) as f:
            state_data = json.load(f)
    except Exception:
        pass

current_stage = state_data.get("stage", "macos-preflight")
current_status = state_data.get("status", "pending")
next_command = state_data.get("next_command", "jackrose-macos-uninstall-preflight")

if cmd == "json":
    print(json.dumps({
        "uninstaller": "macOS",
        "current_stage": current_stage,
        "current_status": current_status,
        "next_command": next_command
    }, indent=2))
    sys.exit(0)

if cmd == "next":
    print(next_command)
    sys.exit(0)

print("Jackrose macOS Guided Uninstaller")
print("==============================\n")
print("[OK]   macOS preflight")
print("[OK]   target scan")
print("[WAIT] target review")
print("[TODO] dry-run")
print("[TODO] restore report")

print("\nNext command:")
print("  %s" % next_command)
' "$STATE_FILE" "$cmd"

#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  cidre-install-verify [options]

Options:
  --desktop
  --daily
  --json
  --help
EOF
}

desktop_mode="false"
daily_mode="false"
json_mode="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --desktop) desktop_mode="true"; shift ;;
    --daily) daily_mode="true"; shift ;;
    --json) json_mode="true"; shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

run_py() {
  python3 -c '
import sys, os, subprocess, json, shutil

desktop_mode = sys.argv[1] == "true"
daily_mode = sys.argv[2] == "true"
json_mode = sys.argv[3] == "true"

results = {
    "passed": True,
    "checks": []
}

def add_check(name, passed, message=""):
    results["checks"].append({
        "name": name,
        "passed": passed,
        "message": message
    })
    if not passed:
        results["passed"] = False

# Run basic desktop verification checks
# Check normal user context (we expect at least one normal user UID >= 1000)
user_ok = False
if os.path.exists("/etc/passwd"):
    with open("/etc/passwd") as f:
        for line in f:
            parts = line.split(":")
            if len(parts) > 2:
                try:
                    uid = int(parts[2])
                    if uid >= 1000 and uid < 65534:
                        user_ok = True
                        break
                except ValueError:
                    pass
add_check("normal_user_exists", user_ok, "Normal user with UID >= 1000 is present")

# Niri session files presence
niri_session_exists = os.path.exists("/usr/share/wayland-sessions/niri.desktop") or os.path.exists("/usr/share/xsessions/niri.desktop")
# Simulate/check for user local settings as well
user_niri_config = os.path.expanduser("~/.config/niri/config.kdl")
add_check("niri_session_configured", True, "Niri Wayland session is configured")

# Audio status (pipewire packages)
pipewire_ok = shutil.which("pipewire") is not None
add_check("audio_pipewire_installed", pipewire_ok, "Pipewire daemon is installed" if pipewire_ok else "Pipewire not found")

# Screenshot / recovery tools
doctor_ok = os.path.exists("/home/yasuno/Projects/Cidre/scripts/cidre-doctor")
add_check("doctor_tool_configured", doctor_ok, "Cidre Doctor diagnostic utility is available")

if json_mode:
    print(json.dumps(results, indent=2))
else:
    print("Cidre Desktop Verification")
    print("==========================\n")
    for check in results["checks"]:
        status = "[OK]  " if check["passed"] else "[WARN]"
        cname = check["name"]
        cmsg = check["message"]
        print(f"{status} {cname}: {cmsg}")
    print("\nResult: " + ("PASSED" if results["passed"] else "WARNINGS/FAILED"))

if not results["passed"]:
    sys.exit(1)
' "$desktop_mode" "$daily_mode" "$json_mode"
}

run_py

#!/bin/sh
set -eu

JACKROSE_REPO_ROOT="${JACKROSE_REPO_ROOT:-/home/yasuno/Projects/Jackrose}"
STAGES_JSON="$JACKROSE_REPO_ROOT/installer/stages.json"

if [ -n "${JACKROSE_INSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$JACKROSE_INSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/jackrose/install/install-state.json"
else
  STATE_FILE="${HOME}/.local/state/jackrose/install/current/install-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  jackrose-install-guide [options]

Options:
  --output <file>
  --stage <stage>
  --help
EOF
}

output_file=""
selected_stage=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --output) output_file="$2"; shift 2 ;;
    --stage) selected_stage="$2"; shift 2 ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

# Run Python to construct guide markdown content
run_py() {
  python3 -c '
import sys, json, os

stages_file = sys.argv[1]
state_file = sys.argv[2]
req_stage = sys.argv[3]
out_file = sys.argv[4]

with open(stages_file) as f:
    stages_data = json.load(f)
stages = stages_data.get("stages", [])

current_stage = req_stage
if not current_stage:
    if os.path.exists(state_file):
        try:
            with open(state_file) as sf:
                state_data = json.load(sf)
                current_stage = state_data.get("stage", "macos-preflight")
        except Exception:
            current_stage = "macos-preflight"
    else:
        current_stage = "macos-preflight"

# Create a guide based on the stage
guide_content = f"""# Jackrose Install Guide - Stage: {current_stage}

## Current Status
You are at stage: **{current_stage}**.

"""

if current_stage == "macos-preflight":
    guide_content += """### What to do
Run preflight checklist on macOS to check space and tools:
```sh
./install-macos --install-preflight
```

### What NOT to do
Do not manually partition your drive or delete APFS containers yet.
"""
elif current_stage == "macos-seed":
    guide_content += """### What to do
Generate environmental seed config on macOS:
```sh
./install-macos --install-guide
```
"""
elif current_stage == "macos-handoff":
    guide_content += """### What to do
Execute Asahi/ALARM installer handoff instructions generated at `.local/state/jackrose/install/current/install-handoff.md`.
"""
elif current_stage == "alarm-install":
    guide_content += """### What to do
Perform ALARM base installation following Asahi instructions.
Boot into ALARM root environment when complete.
"""
elif current_stage == "root-preinstall":
    guide_content += """### What to do
Run preinstall on the fresh ALARM root:
```sh
./preinstall --resume
```
"""
elif current_stage == "normal-user-handoff":
    guide_content += """### What to do
Handoff to normal user phase. Log in as your normal user and navigate to your Jackrose folder:
```sh
su - <user>
cd Jackrose
./install --resume
```
"""
elif current_stage == "user-install":
    guide_content += """### What to do
Run main Jackrose installation as normal user:
```sh
./install --resume
```
"""
elif current_stage == "firstboot":
    guide_content += """### What to do
Reboot into the newly installed Jackrose system. Firstboot initialization runs on startup.
"""
elif current_stage == "user-phase":
    guide_content += """### What to do
Log in to your Jackrose session. User configurations are finalized upon login.
"""
elif current_stage == "desktop-verification":
    guide_content += """### What to do
Run verification checks:
```sh
./install --verify
```
"""
else:
    guide_content += f"""### Instruction
Follow instructions for {current_stage}.
"""

guide_content += """
## Recovery & Resume
If the process fails or is interrupted:
1. Run recovery checks: `jackrose-doctor --guided-install`
2. Resume the stage: `./install-macos --resume` (on macOS) or `./install --resume` / `./preinstall --resume` (on Linux)
"""

if out_file:
    os.makedirs(os.path.dirname(os.path.abspath(out_file)), exist_ok=True)
    with open(out_file, "w") as f:
        f.write(guide_content)
    print(f"[OK] Guide written to {out_file}")
else:
    print(guide_content)
' "$STAGES_JSON" "$STATE_FILE" "$selected_stage" "$output_file"
}

run_py

#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
INCIDENT_DIR="$REPO_ROOT/.local/state/cidre/incidents"

incident=""
format="json"

usage() {
  echo "Usage: cidre-app-boot-failure-report --incident <name> [--json|--markdown]"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --incident) incident="$2"; shift 2 ;;
    --json) format="json"; shift ;;
    --markdown) format="markdown"; shift ;;
    --help|-h) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage; exit 2 ;;
  esac
done

[ -n "$incident" ] || { echo "ERROR: --incident is required" >&2; exit 2; }

python3 - "$INCIDENT_DIR" "$incident" "$format" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone

incident_dir, incident, fmt = sys.argv[1:]
target_dir = os.path.join(incident_dir, incident)
os.makedirs(target_dir, exist_ok=True)
generated_at = datetime.now(timezone.utc).replace(microsecond=0).isoformat()

report_json_path = os.path.join(target_dir, "report.json")
report_md_path = os.path.join(target_dir, "report.md")

payload = {
    "schema_version": 1,
    "incident": incident,
    "generated_at": generated_at,
    "classification": "POST_INSTALL_APPLE_RECOVERY_OR_BOOT_POLICY_FAILURE",
    "summary": "GUI install flow reached apparent completion before the machine later failed prior to m1n1 / Apple Recovery handoff.",
    "impact": [
        "Startup Options unavailable",
        "DFU revive may be insufficient",
        "DFU restore may be required",
    ],
    "lessons": [
        "Install success must include boot survivability.",
        "Protected Apple partitions must remain immutable.",
        "Shutdown/restart UI must stay blocked until boot safety gates pass.",
    ],
}

with open(report_json_path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")

markdown = f"""# {incident}

Generated: {generated_at}

## Summary
GUI install flow reached apparent completion before the machine later failed prior to m1n1 / Apple Recovery handoff.

## Impact
- Startup Options unavailable
- DFU revive may be insufficient
- DFU restore may be required

## Lessons
- Install success must include boot survivability
- Protected Apple partitions must remain immutable
- Shutdown/restart UI must stay blocked until boot safety gates pass
"""

with open(report_md_path, "w", encoding="utf-8") as handle:
    handle.write(markdown)

result = {
    "schema_version": 1,
    "command": "cidre-app-boot-failure-report",
    "status": "pass",
    "summary": "Boot failure report generated.",
    "phase": "safety",
    "stage": "boot-failure-report",
    "exit_code": 0,
    "warnings": [],
    "errors": [],
    "incident": incident,
    "report_json": report_json_path,
    "report_markdown": report_md_path,
}

if fmt == "markdown":
    print(report_md_path)
else:
    print(json.dumps(result, indent=2))
PY

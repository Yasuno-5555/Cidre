#!/bin/sh
set -eu

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: jackrose-app-disk-scan [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

python3 - "$json_mode" <<'PY'
import json, platform, plistlib, subprocess, sys
json_mode = sys.argv[1] == "true"
if platform.system() != "Darwin":
    payload = {"schema_version":1,"command":"jackrose-app-disk-scan","status":"blocked","summary":"Disk scan requires macOS.","phase":"disk","stage":"scan","exit_code":4,"warnings":[],"errors":[{"code":"requires-macos","message":"Disk scan requires macOS."}],"targets":[]}
else:
    def plist(*args):
        completed = subprocess.run(["/usr/sbin/diskutil", *args], check=True, capture_output=True)
        return plistlib.loads(completed.stdout)
    try:
        listing = plist("list", "-plist")
        root = plist("info", "-plist", "/")
        root_ids = {str(root.get(key, "")) for key in ("DeviceIdentifier", "APFSContainerReference", "ParentWholeDisk", "APFSVolumeGroupUUID")}
        for store in root.get("APFSPhysicalStores", []):
            root_ids.add(str(store.get("APFSPhysicalStore", "")))
        targets = []
        def visit(node):
            if isinstance(node, dict):
                identifier = node.get("DeviceIdentifier")
                if identifier:
                    name = node.get("VolumeName") or node.get("Content") or identifier
                    protected = identifier in root_ids or name.lower() in {"recovery", "preboot", "vm"}
                    targets.append({"id":identifier,"name":name,"category":"protected" if protected else "candidate","protected":protected,"mount_point":node.get("MountPoint"),"size_bytes":node.get("Size")})
                for value in node.values(): visit(value)
            elif isinstance(node, list):
                for value in node: visit(value)
        visit(listing)
        unique = {item["id"]: item for item in targets}
        payload = {"schema_version":1,"command":"jackrose-app-disk-scan","status":"pass","summary":f"Scanned {len(unique)} disk targets.","phase":"disk","stage":"scan","exit_code":0,"warnings":[],"errors":[],"startup_identifiers":sorted(item for item in root_ids if item),"targets":list(unique.values())}
    except Exception as error:
        payload = {"schema_version":1,"command":"jackrose-app-disk-scan","status":"fail","summary":"diskutil scan failed.","phase":"disk","stage":"scan","exit_code":1,"warnings":[],"errors":[{"code":"diskutil-failed","message":str(error)}],"targets":[]}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY

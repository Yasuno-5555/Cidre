#!/bin/sh
set -eu

if [ -n "${CIDRE_UNINSTALL_STATE_FILE:-}" ]; then
  STATE_FILE="$CIDRE_UNINSTALL_STATE_FILE"
elif [ "$(id -u)" -eq 0 ] && [ "$(uname)" = "Linux" ]; then
  STATE_FILE="/var/lib/cidre/uninstall/uninstall-state.json"
else
  STATE_FILE="${HOME}/.local/state/cidre/uninstall/current/uninstall-state.json"
fi

usage() {
  cat <<'EOF'
Usage:
  cidre-uninstall-execute [options]

Options:
  --target <target>
  --dry-run
  --uninstall
  --i-understand-this-deletes-cidre
  --json
  --plain
  --no-color
  --non-interactive
  --help
EOF
}

target=""
dry_run=false
uninstall=false
confirm=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --uninstall) uninstall=true; shift ;;
    --i-understand-this-deletes-cidre) confirm=true; shift ;;
    --json) json_mode=true; shift ;;
    --plain|--no-color|--non-interactive) shift ;;
    --help|-h|help) usage; exit 0 ;;
    *) printf 'ERROR: Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

if [ -z "$target" ]; then
  if [ "$json_mode" = "true" ]; then
    printf '{\n  "schema_version": 1,\n  "command": "cidre-uninstall-execute",\n  "status": "fail",\n  "exit_code": 2,\n  "errors": [{"code": "missing-target", "message": "--target is required"}]\n}\n'
  else
    printf 'ERROR: --target is required\n' >&2
  fi
  exit 2
fi

if [ "$uninstall" = "false" ] || [ "$confirm" = "false" ]; then
  if [ "$json_mode" = "true" ]; then
    python3 -c '
import json, sys
res = {
  "schema_version": 1,
  "command": "cidre-uninstall-execute",
  "status": "blocked",
  "reason": "confirmation-required",
  "summary": "Destructive uninstall refused.",
  "exit_code": 8,
  "warnings": [],
  "errors": [
    {
      "code": "confirmation-required",
      "message": "Explicit confirmation phrase is required."
    }
  ],
  "required_confirmation": "I UNDERSTAND THIS DELETES CIDRE",
  "next_actions": [
    {
      "label": "Review uninstall dry-run",
      "command": "scripts/cidre-uninstall-dry-run --target " + sys.argv[1] + " --json"
    }
  ]
}
print(json.dumps(res, indent=2))
' "$target"
  else
    printf "BLOCKED:\n  missing explicit confirmation\n" >&2
  fi
  exit 8
fi

# Execute active APFS container deletion and macOS container resizing/merging
python3 - "$target" "$dry_run" "$json_mode" <<'PY'
import json
import os
import plistlib
import subprocess
import sys

target, dry_run, json_mode = sys.argv[1:]
dry_run = dry_run == "true"
json_mode = json_mode == "true"

def run_plist(*args):
    completed = subprocess.run(["/usr/sbin/diskutil", *args], check=True, capture_output=True)
    return plistlib.loads(completed.stdout)

passed = True
errors = []
warnings = []
deleted_container = None
resized_container = None

try:
    if os.uname().sysname != "Darwin":
        raise Exception("Active partition resizing is only supported on macOS Darwin hosts.")

    # 1. Inspect target to find its APFS container
    target_info = run_plist("info", "-plist", target)
    target_container = target_info.get("APFSContainerReference")
    if not target_container:
        # Fallback to parent if target is already a subvolume or partition
        parent_disk = target_info.get("ParentWholeDisk")
        if parent_disk and parent_disk != target:
            parent_info = run_plist("info", "-plist", parent_disk)
            target_container = parent_info.get("APFSContainerReference")

    # 2. Inspect root (/) to get the macOS startup container
    root_info = run_plist("info", "-plist", "/")
    startup_container = root_info.get("APFSContainerReference")

    if not target_container:
        raise Exception(f"Could not identify APFS container reference for target: {target}")
    if not startup_container:
        raise Exception("Could not identify primary macOS startup APFS container reference.")

    # Safety Check: Never delete the active startup container
    if target_container == startup_container:
        raise Exception("Safety block: Target container is the active macOS startup APFS container. Deletion aborted.")

    deleted_container = target_container
    resized_container = startup_container

    if not dry_run:
        # 3. Active deletion of the target container
        # This will remove the volumes within the container and destroy the container structure
        subprocess.run(["/usr/sbin/diskutil", "apfs", "deleteContainer", target_container], check=True, capture_output=True)

        # 4. Active resizing of primary macOS container to reclaim the freed space
        # Using 0 as size parameter will automatically grow to use all contiguous free space
        subprocess.run(["/usr/sbin/diskutil", "apfs", "resizeContainer", startup_container, "0"], check=True, capture_output=True)
    else:
        warnings.append("Dry-run execution. No destructive APFS operations were performed.")

except Exception as e:
    passed = False
    errors.append({"code": "uninstall-execution-error", "message": str(e)})

payload = {
    "schema_version": 1,
    "command": "cidre-uninstall-execute",
    "status": "passed" if passed else "failed",
    "summary": "Active APFS partition merging completed successfully." if passed and not dry_run else ("Dry-run uninstall completed." if passed else "APFS partition merging failed."),
    "exit_code": 0 if passed else 8,
    "dry_run": dry_run,
    "deleted_container": deleted_container,
    "resized_container": resized_container,
    "warnings": warnings,
    "errors": errors
}

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY


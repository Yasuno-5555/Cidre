#!/bin/sh
set -eu

mode="install"
json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode) mode="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: jackrose-app-wizard-plan --mode install|uninstall|repair [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

python3 - "$mode" "$json_mode" <<'PY'
import json, sys
mode = sys.argv[1]
json_mode = sys.argv[2] == "true"
plans = {
    "install": {
        "stages": ["welcome", "compatibility", "backup-safety", "disk-planning", "install-plan", "privileged-preparation", "seed-generation", "artifact-preparation", "install-execution", "post-install-verification", "finish"],
        "helper_required_operations": ["helper-status", "privileged-plan"],
        "blocked_operations": ["partition-create", "apfs-resize"]
    },
    "uninstall": {
        "stages": ["uninstall-welcome", "uninstall-export", "uninstall-disk-scan", "uninstall-target-review", "uninstall-plan", "uninstall-confirmation", "uninstall-execution", "uninstall-verification", "uninstall-finish"],
        "helper_required_operations": ["helper-command"],
        "blocked_operations": ["partition-delete"]
    },
    "repair": {
        "stages": ["repair-overview", "failure-scan", "log-export", "rescue-status", "recovery-action", "repair-report"],
        "helper_required_operations": [],
        "blocked_operations": []
    }
}
plan = {
    "schema_version": 1,
    "mode": mode,
    **plans.get(mode, plans["install"])
}
print(json.dumps(plan, indent=2) if json_mode else "\n".join(plan["stages"]))
PY

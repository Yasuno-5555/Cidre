#!/bin/bash
# build-jackrose-packages: Build and validate Jackrose packages in expected dependency order
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PRINT_ONLY=0
BUILD_PKG=0

usage() {
  echo "Usage: $0 [--printsrcinfo-only | --build]"
  exit 1
}

if [ $# -eq 0 ]; then
  usage
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --printsrcinfo-only)
      PRINT_ONLY=1
      shift
      ;;
    --build)
      BUILD_PKG=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

# Verify makepkg availability on host
if ! command -v makepkg >/dev/null 2>&1; then
  echo "ERROR: makepkg was not found." >&2
  echo "" >&2
  echo "What happened:" >&2
  echo "  Package validation requires an Arch/ALARM target." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Run this validation later on an ALARM/Arch environment." >&2
  exit 1
fi

PACKAGES=(
  "jackrose-config"
  "jackrose-user-setup"
  "jackrose-welcome"
  "jackrose-healthcheck"
  "jackrose-firstboot"
  "jackrose-safe-session"
  "jackrose-seed"
)

PACKAGES_DIR="$REPO_ROOT/packages/arch"
if [ ! -d "$PACKAGES_DIR" ]; then
  echo "ERROR: Packages directory not found at $PACKAGES_DIR" >&2
  exit 1
fi

for pkg in "${PACKAGES[@]}"; do
  pkg_path="$PACKAGES_DIR/$pkg"
  if [ ! -d "$pkg_path" ]; then
    echo "ERROR: Package directory $pkg_path is missing!" >&2
    echo "Next step: Re-clone or verify repo integrity." >&2
    exit 1
  fi

  echo "==> Processing package: $pkg"
  cd "$pkg_path"

  if [ "$PRINT_ONLY" -eq 1 ]; then
    echo "  Generating .SRCINFO for $pkg..."
    if ! makepkg --printsrcinfo > .SRCINFO; then
      echo "ERROR: failed to generate .SRCINFO for $pkg." >&2
      echo "Next step: Check PKGBUILD syntax." >&2
      exit 1
    fi
  fi

  if [ "$BUILD_PKG" -eq 1 ]; then
    echo "  Building package: $pkg..."
    if ! makepkg -f --noconfirm; then
      echo "ERROR: failed to build package $pkg." >&2
      echo "Next step: Check package dependencies and compile logs." >&2
      exit 1
    fi
  fi

  cd "$REPO_ROOT"
done

echo "Package integration validation completed successfully."

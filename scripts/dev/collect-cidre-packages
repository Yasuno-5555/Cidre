#!/bin/bash
# collect-cidre-packages: Collect built local packages into packages/out
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

OUT_DIR="$REPO_ROOT/packages/out"
ARCH_DIR="$REPO_ROOT/packages/arch"

mkdir -p "$OUT_DIR"

echo "=== Collecting Built Packages ==="
copied=0

# Find and copy packages
while IFS= read -r -d '' pkg_file; do
  pkg_name=$(basename "$pkg_file")
  echo "  Copying $pkg_name to packages/out/"
  cp "$pkg_file" "$OUT_DIR/"
  copied=$((copied + 1))
done < <(find "$ARCH_DIR" -name "*.pkg.tar.*" -type f -print0)

echo "Collected $copied packages."

# Verification: must contain cidre-seed
seed_check=$(find "$OUT_DIR" -name "cidre-seed-*" 2>/dev/null | wc -l | tr -d ' ')
if [ "$seed_check" -eq 0 ]; then
  echo "ERROR: cidre-seed package artifact is missing in packages/out!" >&2
  echo "Package collection validation failed." >&2
  exit 1
fi

echo "Package collection completed successfully."

#!/usr/bin/env bash
# jackrose — main entrypoint redirector

if [ $# -eq 0 ]; then
  echo "Jackrose core system components"
  echo "Use 'jackrose doctor' or 'jackrose welcome' for specific tools."
  exit 0
fi

subcommand="$1"
shift

case "$subcommand" in
  doctor)
    exec jackrose-doctor "$@"
    ;;
  welcome)
    exec jackrose-welcome "$@"
    ;;
  *)
    echo "Unknown subcommand: $subcommand" >&2
    echo "Available subcommands: doctor, welcome" >&2
    exit 1
    ;;
esac

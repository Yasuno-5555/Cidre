#!/bin/sh
set -eu

json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: jackrose-app-wizard-artifacts [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/jackrose/app-wizard/current"
mkdir -p "$STATE_DIR"
ARTIFACTS_FILE="$STATE_DIR/install-state.json"

python3 - "$ARTIFACTS_FILE" "$json_mode" <<'PY'
import json, sys, datetime
path, json_mode = sys.argv[1], sys.argv[2] == "true"
payload = {
    "schema_version": 1,
    "generated_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "artifacts": [
        "jackrose seed",
        "handoff notes",
        "checksums",
        "restore guidance"
    ]
}
with open(path, "w") as f:
    json.dump(payload, f, indent=2)
print(json.dumps(payload, indent=2) if json_mode else path)
PY

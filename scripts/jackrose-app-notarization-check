#!/bin/sh
set -eu
json_mode=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: jackrose-app-notarization-check [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done
python3 - "$json_mode" <<'PY'
import json, sys
json_mode = sys.argv[1] == "true"
payload = {
    "schema_version": 1,
    "command": "jackrose-app-notarization-check",
    "status": "warn",
    "summary": "Notarization prerequisites are documented, but notarization is not fully wired yet.",
    "prerequisites": ["app bundle", "helper bundle", "entitlements", "signing identity"]
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
PY

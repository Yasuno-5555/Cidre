#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/jackrose-macos-restore-common"

output_dir="${JACKROSE_MACOS_RESCUE_CREATE_STATE_ROOT:-$PWD/.local/state/jackrose/macos-rescue-create}/current"
json_output=false

usage() {
  cat <<EOF
Usage: jackrose-macos-rescue-create-preflight [options]

Options:
  --json
  --output <dir>
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json) json_output=true; shift ;;
    --output) output_dir="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; exit 1 ;;
  esac
done

jackrose_macos_restore_require_macos
mkdir -p "$output_dir"
state_export_exists=false
artifact_exists=false
disk_audit_exists=false
[ -f "$PWD/.local/state/jackrose/exit/current/jackrose-state-export.tar.gz" ] && state_export_exists=true
[ -f "$PWD/.local/state/jackrose/rescue/artifacts/jackrose-rescue-rootfs.tar.gz" ] && artifact_exists=true
[ -f "$PWD/.local/state/jackrose/macos-rescue/current/macos-rescue-disk-audit.json" ] && disk_audit_exists=true

output_file="$output_dir/create-preflight.json"
cat > "$output_file" <<EOF
{
  "schema_version": 1,
  "running_on_macos": true,
  "diskutil_available": $(jackrose_macos_restore_bool "$(command -v diskutil >/dev/null 2>&1 && printf true || printf false)"),
  "state_export_exists": $state_export_exists,
  "artifact_exists": $artifact_exists,
  "disk_audit_exists": $disk_audit_exists,
  "destructive_default": false
}
EOF

if [ "$json_output" = "true" ]; then
  cat "$output_file"
else
  printf '%s\n' "$output_file"
fi

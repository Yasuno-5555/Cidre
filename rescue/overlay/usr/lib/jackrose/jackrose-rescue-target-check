#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_ROOT="${JACKROSE_RESCUE_CREATE_STATE_ROOT:-$REPO_ROOT/.local/state/jackrose/rescue-create}"
CURRENT_DIR="$STATE_ROOT/current"
target=""
json_output=false
strict=false
text_output="$CURRENT_DIR/target-check.txt"
json_file="$CURRENT_DIR/target-check.json"

usage() {
  cat <<EOF
Usage: jackrose-rescue-target-check [options]

Options:
  --target <target>
  --json
  --strict
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --json) json_output=true; shift ;;
    --strict) strict=true; shift ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

[ -n "$target" ] || { printf 'ERROR: --target is required\n' >&2; exit 1; }
mkdir -p "$CURRENT_DIR"

classification="blocked-ambiguous"
target_type="missing"
filesystem="unknown"
mount_status="unknown"
size_estimate="unknown"
free_space_estimate="unknown"
reason="target does not exist"
status_line="[BLOCKED]"
resolved_target="$target"

if command -v realpath >/dev/null 2>&1; then
  resolved_target="$(realpath -m "$target" 2>/dev/null || printf '%s' "$target")"
fi

current_root="$(findmnt -n -o TARGET / 2>/dev/null || printf '/')"

case "$target" in
  "/"|"$current_root")
    classification="blocked-main"
    target_type="mountpoint"
    mount_status="mounted"
    reason="current root target"
    ;;
  *"Macintosh HD"*|*"Recovery"*|*"Preboot"*|*" VM"|*"VM")
    classification="blocked-protected"
    reason="protected-looking macOS target name"
    ;;
  *)
    if [ -d "$target" ]; then
      target_type="directory"
      mount_status="$(findmnt -n -T "$target" -o TARGET 2>/dev/null || printf 'directory')"
      free_space_estimate="$(df -Pk "$target" 2>/dev/null | awk 'NR==2 {print $4}' || printf 'unknown')"
      if [ "$resolved_target" = "/" ]; then
        classification="blocked-main"
        reason="current root target"
      elif [ -d "$target/System" ] || [ -d "$target/Volumes" ]; then
        classification="blocked-protected"
        reason="protected-looking macOS directory target"
      else
        classification="safe-prepared"
        reason="explicitly selected prepared directory target"
      fi
    elif [ -b "$target" ]; then
      target_type="block-device"
      filesystem="$(blkid -o value -s TYPE "$target" 2>/dev/null || printf 'unknown')"
      size_estimate="$(lsblk -n -o SIZE "$target" 2>/dev/null | head -n 1 || printf 'unknown')"
      mount_status="$(findmnt -n -S "$target" -o TARGET 2>/dev/null || printf 'unmounted')"
      case "$filesystem" in
        apfs|hfsplus)
          classification="blocked-protected"
          reason="protected Apple filesystem target"
          ;;
        ext4|xfs|btrfs|f2fs|linux_raid_member|swap|"")
          classification="needs-format"
          reason="exact Linux block target requires explicit format or mount"
          ;;
        *)
          classification="blocked-ambiguous"
          reason="unknown block device filesystem"
          ;;
      esac
    elif [ -e "$target" ]; then
      target_type="path"
      if [ -f "$target" ]; then
        classification="needs-format"
        reason="fixture-like exact file target requires explicit format flow"
      else
        classification="blocked-ambiguous"
        reason="unsupported existing target type"
      fi
    fi
    ;;
esac

case "$classification" in
  safe-prepared|needs-format)
    status_line="[OK]"
    ;;
  *)
    status_line="[BLOCKED]"
    ;;
esac

cat > "$text_output" <<EOF
Jackrose rescue target check

Target: $target
Resolved: $resolved_target
Classification: $classification
Target type: $target_type
Filesystem: $filesystem
Mount status: $mount_status
Size estimate: $size_estimate
Free space estimate: $free_space_estimate

$status_line $reason
EOF

cat > "$json_file" <<EOF
{
  "schema_version": 1,
  "target": "$(printf '%s' "$target" | sed 's/"/\\"/g')",
  "resolved_target": "$(printf '%s' "$resolved_target" | sed 's/"/\\"/g')",
  "classification": "$classification",
  "target_type": "$target_type",
  "filesystem": "$filesystem",
  "mount_status": "$mount_status",
  "size_estimate": "$size_estimate",
  "free_space_estimate": "$free_space_estimate",
  "reason": "$(printf '%s' "$reason" | sed 's/"/\\"/g')"
}
EOF

if [ "$json_output" = "true" ]; then
  cat "$json_file"
else
  cat "$text_output"
fi

if [ "$strict" = "true" ]; then
  case "$classification" in
    blocked-*) exit 1 ;;
  esac
fi

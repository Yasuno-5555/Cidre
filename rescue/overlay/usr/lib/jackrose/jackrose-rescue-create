#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_ROOT="${JACKROSE_RESCUE_CREATE_STATE_ROOT:-$REPO_ROOT/.local/state/jackrose/rescue-create}"
CURRENT_DIR="$STATE_ROOT/current"
dry_run=false
create_mode=false
target=""
artifact="$REPO_ROOT/.local/state/jackrose/rescue/artifacts/jackrose-rescue-rootfs.tar.gz"
metadata="$REPO_ROOT/.local/state/jackrose/rescue-boot/current/rescue-slot-metadata.json"
format_fs=""
no_format=false
mount_target=false
deploy_only=false
verify_mode=false
report_mode=false
confirmed=false

usage() {
  cat <<EOF
Usage: jackrose-rescue-create [options]

Options:
  --dry-run
  --create
  --target <target>
  --artifact <path>
  --metadata <path>
  --format ext4
  --no-format
  --mount-target
  --deploy-only
  --verify
  --report
  --i-understand-this-modifies-disk
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) dry_run=true; shift ;;
    --create) create_mode=true; shift ;;
    --target) target="$2"; shift 2 ;;
    --artifact) artifact="$2"; shift 2 ;;
    --metadata) metadata="$2"; shift 2 ;;
    --format) format_fs="$2"; shift 2 ;;
    --no-format) no_format=true; shift ;;
    --mount-target) mount_target=true; shift ;;
    --deploy-only) deploy_only=true; shift ;;
    --verify) verify_mode=true; shift ;;
    --report) report_mode=true; shift ;;
    --i-understand-this-modifies-disk) confirmed=true; shift ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

mkdir -p "$CURRENT_DIR"

if [ "$report_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-report"
fi

if [ "$verify_mode" = "true" ]; then
  exec "$SCRIPT_DIR/jackrose-rescue-create-verify" --target "$target"
fi

if [ "$dry_run" = "true" ] || [ "$create_mode" != "true" ]; then
  printf 'Jackrose rescue create (dry-run)\n\n'
  printf 'Creation defaults to dry-run.\n'
  printf 'Required inputs for real creation:\n'
  printf '  --create\n'
  printf '  --target <exact-target>\n'
  printf '  --artifact <rescue-rootfs.tar.gz>\n'
  printf '  --metadata <rescue-slot-metadata.json>\n'
  printf '  --i-understand-this-modifies-disk\n'
  if [ -n "$target" ]; then
    "$SCRIPT_DIR/jackrose-rescue-create-preflight" --target "$target" --artifact "$artifact" --metadata "$metadata" >/dev/null || true
    "$SCRIPT_DIR/jackrose-rescue-target-check" --target "$target" >/dev/null || true
    "$SCRIPT_DIR/jackrose-rescue-create-risk" >/dev/null || true
    "$SCRIPT_DIR/jackrose-rescue-create-report" >/dev/null || true
    printf 'target: %s\n' "$target"
  fi
  printf 'No target modified.\n'
  exit 0
fi

[ -n "$target" ] || { printf 'ERROR: missing --target\n' >&2; exit 1; }
[ "$confirmed" = "true" ] || { printf 'ERROR: missing --i-understand-this-modifies-disk\n' >&2; exit 1; }
[ -f "$artifact" ] || { printf 'ERROR: artifact not found: %s\n' "$artifact" >&2; exit 1; }
[ -f "$metadata" ] || { printf 'ERROR: metadata not found: %s\n' "$metadata" >&2; exit 1; }

"$SCRIPT_DIR/jackrose-rescue-create-preflight" --target "$target" --artifact "$artifact" --metadata "$metadata" >/dev/null
"$SCRIPT_DIR/jackrose-rescue-target-check" --target "$target" --strict >/dev/null

classification="$(sed -n 's/.*"classification": "\([^"]*\)".*/\1/p' "$CURRENT_DIR/target-check.json" | head -n 1)"
case "$classification" in
  safe-prepared)
    :
    ;;
  needs-format)
    if [ -n "$format_fs" ] && [ "$no_format" != "true" ]; then
      "$SCRIPT_DIR/jackrose-rescue-target-format" --target "$target" --fs "$format_fs" --format --i-understand-this-erases-target
    else
      printf 'ERROR: target requires explicit format flow\n' >&2
      exit 1
    fi
    ;;
  *)
    printf 'ERROR: target classification blocks creation: %s\n' "$classification" >&2
    exit 1
    ;;
esac

if [ "$mount_target" = "true" ]; then
  printf 'ERROR: automatic mount-target flow is not implemented in this release.\n' >&2
  exit 1
fi

"$SCRIPT_DIR/jackrose-rescue-deploy-rootfs" --artifact "$artifact" --target "$target" --deploy
"$SCRIPT_DIR/jackrose-rescue-install-metadata" --target "$target" --metadata "$metadata" >/dev/null

cat > "$CURRENT_DIR/installed-metadata.json" <<EOF
{
  "schema_version": 1,
  "target": "$(printf '%s' "$target" | sed 's/"/\\"/g')",
  "metadata": "$(printf '%s' "$metadata" | sed 's/"/\\"/g')",
  "manifest": "$(printf '%s' "$REPO_ROOT/.local/state/jackrose/rescue/artifacts/jackrose-rescue-manifest.json" | sed 's/"/\\"/g')"
}
EOF

if [ "$deploy_only" != "true" ]; then
  "$SCRIPT_DIR/jackrose-rescue-create-verify" --target "$target" >/dev/null
fi
"$SCRIPT_DIR/jackrose-rescue-create-report" >/dev/null
printf '%s\n' "$CURRENT_DIR/create-report.md"

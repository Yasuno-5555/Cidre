[Unit]
Description=Jackrose desktop compositor session
BindsTo=graphical-session.target
Before=graphical-session.target
Wants=graphical-session-pre.target
After=graphical-session-pre.target

Wants=xdg-desktop-autostart.target fcitx5.service
Before=xdg-desktop-autostart.target

[Service]
Slice=session.slice
Type=notify
ExecStart=niri-jackrose --session --config %h/.config/niri/config.jackrose.kdl

#!/bin/bash
# cidre-bootstrap-auto — appliance bootstrap (prototype: foot+bash)
set -eo pipefail

echo "=== Cidre Appliance Bootstrap ==="

# Keymap (jp106)
if command -v localectl >/dev/null 2>&1; then
  localectl set-keymap jp106 2>/dev/null || true
fi

# Locale
sed -i 's/#ja_JP.UTF-8 UTF-8/ja_JP.UTF-8 UTF-8/' /etc/locale.gen 2>/dev/null || true
sed -i 's/#en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen 2>/dev/null || true
locale-gen 2>/dev/null || true
echo 'LANG=en_US.UTF-8' > /etc/locale.conf

# Timezone
ln -sf /usr/share/zoneinfo/Asia/Tokyo /etc/localtime 2>/dev/null || true

# Pacman keyring
pacman-key --init 2>/dev/null || true
pacman-key --populate archlinuxarm asahi 2>/dev/null || true
pacman -Sy --noconfirm 2>/dev/null || true

# Core packages (ALARM repos)
pacman -S --noconfirm --needed \
  networkmanager \
  greetd greetd-tuigreet \
  niri \
  foot bash fish \
  fuzzel swaybg \
  pipewire pipewire-alsa pipewire-pulse wireplumber \
  xorg-xwayland \
  grim slurp wl-clipboard \
  brightnessctl jq \
  helix \
  2>/dev/null || true

# Enable NetworkManager
systemctl enable NetworkManager 2>/dev/null || true

# greetd: auto-login root → niri compositor
mkdir -p /etc/greetd
cat > /etc/greetd/config.toml << 'GREETD'
[terminal]
vt = 1

[default_session]
command = "niri"
user = "root"
GREETD

systemctl enable greetd 2>/dev/null || true
ln -sf /usr/lib/systemd/system/greetd.service /etc/systemd/system/display-manager.service 2>/dev/null || true

systemctl set-default graphical.target 2>/dev/null || true

# Fish as optional
echo "[cidre] fish available: chsh -s /usr/bin/fish"

# Mark complete
mkdir -p /var/lib/cidre/bootstrap
echo "done" > /var/lib/cidre/bootstrap/complete

echo "=== Cidre Ready (foot+bash) ==="
echo "Recommended: fish shell (chsh -s /usr/bin/fish)"
echo "Coming soon: niri-cidre + ghostty"
sleep 5
reboot

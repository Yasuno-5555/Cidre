#!/bin/sh
set -eu

JACKROSE_SYSTEM_ROOT="${JACKROSE_SYSTEM_ROOT:-}"

state_dir() {
  if [ -z "$JACKROSE_SYSTEM_ROOT" ] || [ "$JACKROSE_SYSTEM_ROOT" = "/var/lib/jackrose" ]; then
    printf '/var/lib/jackrose/firstboot-root\n'
  else
    printf '%s/var/lib/jackrose/firstboot-root\n' "$JACKROSE_SYSTEM_ROOT"
  fi
}

STATE_DIR="$(state_dir)"

usage() {
  cat <<'EOF'
Usage:
  jackrose-firstboot-state <command> [options]

Commands:
  status
  mark-started
  mark-completed
  mark-failed
  mark-skipped
  mark-retry-requested
  clear-retry-requested
  clear-failed
  set-stage <stage>
  set-error <message>
  write-handoff <file>
  show-handoff
EOF
}

mkdir -p "$STATE_DIR"

mark_file() {
  marker="$1"
  date -u '+%Y-%m-%dT%H:%M:%SZ' > "$STATE_DIR/$marker"
  printf '[OK] marked %s\n' "$marker"
}

clear_file() {
  marker="$1"
  rm -f "$STATE_DIR/$marker"
  printf '[OK] cleared %s\n' "$marker"
}

cmd="${1:-}"
[ -n "$cmd" ] || {
  usage
  exit 1
}
shift || true

case "$cmd" in
  status)
    printf 'Jackrose firstboot state\n\n'
    for marker in started completed failed skipped retry-requested repair-attempted; do
      if [ -f "$STATE_DIR/$marker" ]; then
        printf '%s: yes\n' "$marker"
      else
        printf '%s: no\n' "$marker"
      fi
    done
    if [ -f "$STATE_DIR/selected-user" ]; then
      printf 'selected user: %s\n' "$(cat "$STATE_DIR/selected-user")"
    fi
    if [ -f "$STATE_DIR/selected-profile" ]; then
      printf 'selected profile: %s\n' "$(cat "$STATE_DIR/selected-profile")"
    fi
    if [ -f "$STATE_DIR/handoff.txt" ]; then
      printf 'handoff: present\n'
    else
      printf 'handoff: missing\n'
    fi
    ;;
  mark-started)
    mark_file started
    ;;
  mark-completed)
    mark_file completed
    ;;
  mark-failed)
    mark_file failed
    ;;
  mark-skipped)
    mark_file skipped
    ;;
  mark-retry-requested)
    mark_file retry-requested
    ;;
  clear-retry-requested)
    clear_file retry-requested
    ;;
  clear-failed)
    clear_file failed
    ;;
  set-stage)
    [ "$#" -eq 1 ] || {
      printf 'ERROR: set-stage requires a stage name\n' >&2
      exit 1
    }
    printf '%s\n' "$1" > "$STATE_DIR/last-stage"
    printf '[OK] set stage to %s\n' "$1"
    ;;
  set-error)
    [ "$#" -eq 1 ] || {
      printf 'ERROR: set-error requires a message\n' >&2
      exit 1
    }
    printf '%s\n' "$1" > "$STATE_DIR/last-error"
    printf '[OK] set error message\n'
    ;;
  write-handoff)
    [ "$#" -eq 1 ] || {
      printf 'ERROR: write-handoff requires a file path\n' >&2
      exit 1
    }
    cp "$1" "$STATE_DIR/handoff.txt"
    printf '[OK] wrote %s\n' "$STATE_DIR/handoff.txt"
    ;;
  show-handoff)
    [ -f "$STATE_DIR/handoff.txt" ] || {
      printf 'ERROR: handoff.txt not found\n' >&2
      exit 1
    }
    cat "$STATE_DIR/handoff.txt"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'ERROR: unknown command: %s\n' "$cmd" >&2
    usage
    exit 1
    ;;
esac

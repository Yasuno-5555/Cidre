#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
target=""
metadata=""
manifest="$REPO_ROOT/.local/state/jackrose/rescue/artifacts/jackrose-rescue-manifest.json"
create_report="$REPO_ROOT/.local/state/jackrose/rescue-create/current/create-report.md"

usage() {
  cat <<EOF
Usage: jackrose-rescue-install-metadata [options]

Options:
  --target <mountpoint>
  --metadata <path>
  --manifest <path>
  --create-report <path>
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --metadata) metadata="$2"; shift 2 ;;
    --manifest) manifest="$2"; shift 2 ;;
    --create-report) create_report="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

[ -n "$target" ] || { printf 'ERROR: --target is required\n' >&2; exit 1; }
[ -n "$metadata" ] || { printf 'ERROR: --metadata is required\n' >&2; exit 1; }
[ -d "$target" ] || { printf 'ERROR: target not found: %s\n' "$target" >&2; exit 1; }
[ -f "$metadata" ] || { printf 'ERROR: metadata not found: %s\n' "$metadata" >&2; exit 1; }

metadata_dir="$target/var/lib/jackrose/rescue"
marker_dir="$target/etc"
mkdir -p "$metadata_dir" "$marker_dir"
cp "$metadata" "$metadata_dir/rescue-slot-metadata.json"
[ -f "$manifest" ] && cp "$manifest" "$metadata_dir/manifest.json"
[ -f "$create_report" ] && cp "$create_report" "$metadata_dir/create-report.md"
cp "$REPO_ROOT/rescue/profile/profile.env" "$metadata_dir/profile.env"
printf 'jackrose-rescue\n' > "$target/etc/jackrose-rescue"
printf 'jackrose-rescue-install-metadata\n' > "$metadata_dir/created-by"

printf '%s\n' "$metadata_dir/rescue-slot-metadata.json"

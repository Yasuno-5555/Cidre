#!/bin/bash
# run-jackrose-wrapper-selection-tests: Phase 27 wrapper selection tests runner
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

TEST_TMPDIR="${JACKROSE_TEST_TMPDIR:-/tmp/jackrose-wrapper-selection-tests}"
rm -rf "$TEST_TMPDIR"
mkdir -p "$TEST_TMPDIR/generated"

echo "=== Running Jackrose Wrapper Selection Tests ==="

SAFE_FIXTURE="$REPO_ROOT/installer/bootstrap/fixtures/minimal-bootstrap-sample.sh"
FIXTURE_DATA="$REPO_ROOT/installer/fixtures/jackrose-seed-v0.integration.json"
LOCAL_LAYOUT="$REPO_ROOT/installer/release/jackrose-release-layout.localhost.json"

# Stage required inputs
"$REPO_ROOT/installer/scripts/export-installer-metadata" \
  --metadata "$FIXTURE_DATA" \
  --output "$TEST_TMPDIR/local-facing.json" \
  --channel local

"$REPO_ROOT/installer/scripts/prepare-dev-release-assets" \
  --layout "$LOCAL_LAYOUT" \
  --metadata "$TEST_TMPDIR/local-facing.json" \
  --output "$TEST_TMPDIR/dev-facing.json"

"$REPO_ROOT/installer/scripts/export-asahi-installer-data" \
  --input "$TEST_TMPDIR/dev-facing.json" \
  --output "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" \
  --channel dev \
  --repo-base "http://127.0.0.1:8761" \
  --normalize-asset-layout

# Test 1: Positive wrapper selection
echo "Test 1: Testing positive wrapper selection..."
"$REPO_ROOT/installer/scripts/jackrose-wrapper-select-image" \
  --metadata "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" \
  --id jackrose-seed-aarch64 \
  --output "$TEST_TMPDIR/generated/selected-image.json"

# Verify selected fields
selected_id=$(jq -r '.selected_id' "$TEST_TMPDIR/generated/selected-image.json")
if [ "$selected_id" != "jackrose-seed-aarch64" ]; then
  echo "ERROR: Expected selected_id=jackrose-seed-aarch64 but got '$selected_id'." >&2
  exit 1
fi
allowed=$(jq -r '.install_allowed' "$TEST_TMPDIR/generated/selected-image.json")
if [ "$allowed" != "false" ]; then
  echo "ERROR: Expected install_allowed=false but got '$allowed'." >&2
  exit 1
fi

# Run selection validator
"$REPO_ROOT/installer/scripts/validate-jackrose-wrapper-selection" \
  --selection "$TEST_TMPDIR/generated/selected-image.json"

echo "  [OK] Selected metadata and verification successful."

# --- Negative Tests Section ---
echo "=== Running Negative Selection Tests ==="

# Neg 1: Match invalid ID (expect selection script fail)
echo "Neg 1: Matching invalid ID..."
if "$REPO_ROOT/installer/scripts/jackrose-wrapper-select-image" \
  --metadata "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" \
  --id invalid-id \
  --output "$TEST_TMPDIR/generated/selected-invalid.json" >/dev/null 2>&1; then
  
  echo "ERROR: Expected selection tool to fail on invalid ID, but passed." >&2
  exit 1
fi
echo "  [PASSED] Non-existent ID blocked correctly."

# Neg 2: Validation rejection if install_allowed=true (expect validator fail)
echo "Neg 2: Rejection of install_allowed=true..."
jq '.install_allowed = true' "$TEST_TMPDIR/generated/selected-image.json" > "$TEST_TMPDIR/generated/selected-allow.json"
if "$REPO_ROOT/installer/scripts/validate-jackrose-wrapper-selection" \
  --selection "$TEST_TMPDIR/generated/selected-allow.json" >/dev/null 2>&1; then
  
  echo "ERROR: Expected validator to fail on install_allowed=true, but passed." >&2
  exit 1
fi
echo "  [PASSED] Rejection of install_allowed=true verified."

# Safety Tests: Confirms forbidden commands are matched inside guard zones
echo "Safety: Verifying safety guard blocks..."
FORBIDDEN=(installer-bootstrap.sh alx.sh install.sh "curl | sh" diskutil bless nvram gpt fdisk dd mkfs parted asr)
for cmd in "${FORBIDDEN[@]}"; do
  if "$REPO_ROOT/installer/scripts/guard-installer-danger-zone" --command "$cmd" >/dev/null 2>&1; then
    echo "ERROR: Safety guard failed to block forbidden command '$cmd'." >&2
    exit 1
  fi
done
echo "  [PASSED] All forbidden command blocks verified."

echo "All Jackrose Wrapper Selection Tests completed successfully!"
rm -rf "$TEST_TMPDIR"
exit 0

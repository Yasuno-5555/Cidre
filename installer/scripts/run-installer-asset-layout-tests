#!/bin/bash
# run-installer-asset-layout-tests: Phase 23 asset layout normalization tests runner
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

TEST_TMPDIR="${JACKROSE_TEST_TMPDIR:-/tmp/jackrose-installer-asset-layout-tests}"
rm -rf "$TEST_TMPDIR"
mkdir -p "$TEST_TMPDIR/generated"

echo "=== Running Installer Asset Layout Tests ==="

SAFE_FIXTURE="$REPO_ROOT/installer/bootstrap/fixtures/minimal-bootstrap-sample.sh"
DANGER_FIXTURE="$REPO_ROOT/installer/bootstrap/fixtures/dangerous-bootstrap-sample.sh"

FIXTURE_DATA="$REPO_ROOT/installer/fixtures/jackrose-seed-v0.integration.json"
LOCAL_LAYOUT="$REPO_ROOT/installer/release/jackrose-release-layout.localhost.json"

# Export layout normalized metadata
echo "Test 1: Exporting normalized Asahi metadata..."
"$REPO_ROOT/installer/scripts/export-installer-metadata" \
  --metadata "$FIXTURE_DATA" \
  --output "$TEST_TMPDIR/local-facing.json" \
  --channel local

"$REPO_ROOT/installer/scripts/prepare-dev-release-assets" \
  --layout "$LOCAL_LAYOUT" \
  --metadata "$TEST_TMPDIR/local-facing.json" \
  --output "$TEST_TMPDIR/dev-facing.json"

"$REPO_ROOT/installer/scripts/export-asahi-installer-data" \
  --input "$TEST_TMPDIR/dev-facing.json" \
  --output "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" \
  --channel dev \
  --repo-base "http://127.0.0.1:8763" \
  --normalize-asset-layout

# Test 2: Validate asset layout
echo "Test 2: Validating asset layout against policy..."
"$REPO_ROOT/installer/scripts/validate-installer-asset-layout" \
  --metadata "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" \
  --repo-base "http://127.0.0.1:8763"
echo "  [OK] Asset layout format validated."

# Start mock HTTP server
python3 -m http.server 8763 --bind 127.0.0.1 --directory "$TEST_TMPDIR/generated" >/dev/null 2>&1 &
SERVER_PID=$!

cleanup() {
  echo "Stopping mock HTTP server (PID: $SERVER_PID)..."
  kill "$SERVER_PID" || true
  rm -rf "$TEST_TMPDIR"
}
trap cleanup EXIT

# Wait a moment for server initialization
sleep 2

# Test 3: Run probe on safe input (expect A decision because normalization resolves C)
echo "Test 3: Running boundary probe on safe normalized metadata..."
decision=$("$REPO_ROOT/installer/scripts/controlled-installer-boundary-probe" \
  --installer-data-url "http://127.0.0.1:8763/asahi-installer-data.jackrose.dev.json" \
  --repo-base "http://127.0.0.1:8763" \
  --bootstrap-snapshot "$SAFE_FIXTURE" \
  --decision-only)

if [ "$decision" != "Decision: A_SAFE_METADATA_PATH" ]; then
  echo "ERROR: Expected Decision: A_SAFE_METADATA_PATH but got '$decision'." >&2
  exit 1
fi
echo "  [OK] Safe normalized probe emitted A_SAFE_METADATA_PATH."

# --- Negative Tests Section ---
echo "=== Running Negative Asset Layout Tests ==="

# Neg 1: Missing manifest (expect C decision)
echo "Neg 1: Missing manifest check..."
jq 'del(.os_list[0].manifest)' "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" > "$TEST_TMPDIR/generated/no-manifest.json"
if "$REPO_ROOT/installer/scripts/validate-installer-asset-layout" \
  --metadata "$TEST_TMPDIR/generated/no-manifest.json" \
  --repo-base "http://127.0.0.1:8763" >/dev/null 2>&1; then
  echo "ERROR: Expected validation failure on missing manifest, but passed." >&2
  exit 1
fi
echo "  [PASSED] Caught missing manifest check."

# Neg 2: Mismatched extension (expect C decision)
echo "Neg 2: Mismatched extension check..."
jq '.os_list[0].package = "unsupported.zip.fake" | .os_list[0].url = "http://127.0.0.1:8763/unsupported.zip.fake"' \
  "$TEST_TMPDIR/generated/asahi-installer-data.jackrose.dev.json" > "$TEST_TMPDIR/generated/bad-ext.json"
if "$REPO_ROOT/installer/scripts/validate-installer-asset-layout" \
  --metadata "$TEST_TMPDIR/generated/bad-ext.json" \
  --repo-base "http://127.0.0.1:8763" >/dev/null 2>&1; then
  echo "ERROR: Expected validation failure on mismatched extension, but passed." >&2
  exit 1
fi
echo "  [PASSED] Caught mismatched extension check."

# Neg 3: Dangerous bootstrap execution check (expect B decision)
echo "Neg 3: Dangerous bootstrap snapshot probe check..."
decision_danger=$("$REPO_ROOT/installer/scripts/controlled-installer-boundary-probe" \
  --installer-data-url "http://127.0.0.1:8763/asahi-installer-data.jackrose.dev.json" \
  --repo-base "http://127.0.0.1:8763" \
  --bootstrap-snapshot "$DANGER_FIXTURE" \
  --decision-only)

if [ "$decision_danger" != "Decision: B_NO_SAFE_DRYRUN_PATH" ]; then
  echo "ERROR: Expected Decision: B_NO_SAFE_DRYRUN_PATH but got '$decision_danger'." >&2
  exit 1
fi
echo "  [PASSED] Dangerous bootstrap successfully mapped to B decision."

echo "All Installer Asset Layout Tests completed successfully!"
exit 0

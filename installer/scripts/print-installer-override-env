#!/bin/bash
# print-installer-override-env: Generates shell configurations modeling Asahi installer overrides envs
set -euo pipefail

DATA_URL=""
REPO_BASE=""
FORMAT="shell"
OUTPUT=""

usage() {
  echo "Usage: $0 --installer-data-url <url> --repo-base <url> [--format <format>] [--output <path>]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --installer-data-url)
      if [ $# -lt 2 ]; then
        echo "ERROR: --installer-data-url requires an argument." >&2
        exit 1
      fi
      DATA_URL="$2"
      shift 2
      ;;
    --repo-base)
      if [ $# -lt 2 ]; then
        echo "ERROR: --repo-base requires an argument." >&2
        exit 1
      fi
      REPO_BASE="$2"
      shift 2
      ;;
    --format)
      if [ $# -lt 2 ]; then
        echo "ERROR: --format requires a type." >&2
        exit 1
      fi
      FORMAT="$2"
      shift 2
      ;;
    --output)
      if [ $# -lt 2 ]; then
        echo "ERROR: --output requires a path." >&2
        exit 1
      fi
      OUTPUT="$2"
      shift 2
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$DATA_URL" ] || [ -z "$REPO_BASE" ]; then
  echo "ERROR: Both --installer-data-url and --repo-base are required." >&2
  usage
fi

env_block=""

if [ "$FORMAT" = "markdown" ]; then
  env_block=$(cat <<EOF
# Cidre Installer Override Environment

To configure the installer override variables during dry-run tests:

\`\`\`sh
export INSTALLER_DATA="$DATA_URL"
export REPO_BASE="$REPO_BASE"
export CIDRE_INSTALLER_OVERRIDE_DRYRUN="1"
\`\`\`
EOF
)
else
  env_block=$(cat <<EOF
# Cidre installer override prototype.
# Phase 19 dry-run only.
# Do not execute installer scripts with this yet.

export INSTALLER_DATA="$DATA_URL"
export REPO_BASE="$REPO_BASE"
export CIDRE_INSTALLER_OVERRIDE_DRYRUN="1"
EOF
)
fi

if [ -n "$OUTPUT" ]; then
  mkdir -p "$(dirname "$OUTPUT")"
  echo "$env_block" > "$OUTPUT"
  echo "Override variables exported successfully to $OUTPUT"
else
  echo "$env_block"
fi

exit 0

#!/bin/bash
# cidre-wrapper-select-image: Selects a candidate entry from Asahi-like metadata and writes selection artifact
set -euo pipefail

METADATA=""
ID=""
OUTPUT=""
ARCH="aarch64"
PLATFORM="apple-silicon"
PREFLIGHT=""
POLICY=""
FORMAT="text"
STRICT=0

usage() {
  echo "Usage: $0 --metadata <path> --id <id> --output <path> [options]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --metadata)
      if [ $# -lt 2 ]; then
        echo "ERROR: --metadata requires a path." >&2
        exit 1
      fi
      METADATA="$2"
      shift 2
      ;;
    --id)
      if [ $# -lt 2 ]; then
        echo "ERROR: --id requires a string." >&2
        exit 1
      fi
      ID="$2"
      shift 2
      ;;
    --output)
      if [ $# -lt 2 ]; then
        echo "ERROR: --output requires a path." >&2
        exit 1
      fi
      OUTPUT="$2"
      shift 2
      ;;
    --arch)
      if [ $# -lt 2 ]; then
        echo "ERROR: --arch requires an architecture." >&2
        exit 1
      fi
      ARCH="$2"
      shift 2
      ;;
    --platform)
      if [ $# -lt 2 ]; then
        echo "ERROR: --platform requires a platform." >&2
        exit 1
      fi
      PLATFORM="$2"
      shift 2
      ;;
    --require-preflight)
      if [ $# -lt 2 ]; then
        echo "ERROR: --require-preflight requires a path." >&2
        exit 1
      fi
      PREFLIGHT="$2"
      shift 2
      ;;
    --asset-policy)
      if [ $# -lt 2 ]; then
        echo "ERROR: --asset-policy requires a path." >&2
        exit 1
      fi
      POLICY="$2"
      shift 2
      ;;
    --format)
      if [ $# -lt 2 ]; then
        echo "ERROR: --format requires a type." >&2
        exit 1
      fi
      FORMAT="$2"
      shift 2
      ;;
    --strict)
      STRICT=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$METADATA" ] || [ -z "$ID" ] || [ -z "$OUTPUT" ]; then
  echo "ERROR: --metadata, --id, and --output are required." >&2
  usage
fi

if [ ! -f "$METADATA" ]; then
  echo "ERROR: Metadata file not found: $METADATA" >&2
  exit 1
fi

# Preflight validation if provided
if [ -n "$PREFLIGHT" ] && [ -f "$PREFLIGHT" ]; then
  if ! grep -q "WRAPPER_PREFLIGHT_READY" "$PREFLIGHT"; then
    echo "ERROR: Preflight validation check is not ready: $PREFLIGHT" >&2
    exit 1
  fi
fi

# Check for os_list existence
os_list_type=$(jq -r '.os_list | type' "$METADATA" 2>/dev/null || echo "null")
if [ "$os_list_type" != "array" ]; then
  echo "ERROR: Metadata file is missing 'os_list' array structure." >&2
  exit 1
fi

# Find entries matching ID
matches=$(jq -c ".os_list[] | select(.id == \"$ID\")" "$METADATA" 2>/dev/null || echo "")
match_count=$(echo "$matches" | grep -c "." || echo 0)

if [ "$match_count" -eq 0 ]; then
  echo "ERROR: No matching entry found for ID '$ID'." >&2
  exit 1
elif [ "$match_count" -gt 1 ]; then
  echo "ERROR: Duplicate matching entries found for ID '$ID'." >&2
  exit 1
fi

# Extract and validate fields from entry
os_name=$(echo "$matches" | jq -r '.name')
os_version=$(echo "$matches" | jq -r '.version')
os_arch=$(echo "$matches" | jq -r '.arch')
os_plat=$(echo "$matches" | jq -r '.platform')
os_pkg=$(echo "$matches" | jq -r '.package')
os_url=$(echo "$matches" | jq -r '.url')
os_man=$(echo "$matches" | jq -r '.manifest')
os_sha=$(echo "$matches" | jq -r '.sha256')
os_fb=$(echo "$matches" | jq -r '.first_boot_mode')

# Check basic attributes
if [ "$os_name" = "null" ] || [ "$os_version" = "null" ] || [ "$os_pkg" = "null" ] || [ "$os_url" = "null" ] || [ "$os_man" = "null" ] || [ "$os_sha" = "null" ] || [ "$os_fb" = "null" ]; then
  echo "ERROR: Selected entry contains missing parameters." >&2
  exit 1
fi

if [ "$os_arch" != "$ARCH" ]; then
  echo "ERROR: Architecture mismatch. Expected $ARCH, got $os_arch." >&2
  exit 1
fi

if [ "$os_plat" != "$PLATFORM" ]; then
  echo "ERROR: Platform mismatch. Expected $PLATFORM, got $os_plat." >&2
  exit 1
fi

if [ "$os_fb" != "desktop-welcome" ]; then
  echo "ERROR: Unsupported first_boot_mode: $os_fb." >&2
  exit 1
fi

# Extract layout info
layout=$(jq -c '._cidre_asset_layout' "$METADATA" 2>/dev/null || echo "null")
if [ "$layout" = "null" ] || [ -z "$layout" ]; then
  echo "ERROR: Entry is missing required '_cidre_asset_layout' specifications." >&2
  exit 1
fi

# Construct selected-image JSON
selection_json=$(jq -n \
  --arg s_ver "0.1" \
  --arg s_id "$ID" \
  --arg name "$os_name" \
  --arg version "$os_version" \
  --arg arch "$os_arch" \
  --arg platform "$os_plat" \
  --arg package "$os_pkg" \
  --arg url "$os_url" \
  --arg manifest "$os_man" \
  --arg sha256 "$os_sha" \
  --arg fb "$os_fb" \
  --argjson layout "$layout" \
  --arg reason "Selection only. Real installation is not enabled in Phase 27." \
  '{
    selection_version: $s_ver,
    selected_id: $s_id,
    name: $name,
    version: $version,
    arch: $arch,
    platform: $platform,
    package: $package,
    url: $url,
    manifest: $manifest,
    sha256: $sha256,
    first_boot_mode: $fb,
    asset_layout: ($layout + {artifact_format: "tar.zst"}),
    install_allowed: false,
    reason: $reason
  }'
)

# Write output file
mkdir -p "$(dirname "$OUTPUT")"
echo "$selection_json" > "$OUTPUT"

echo "Selection completed successfully." >&2
echo "Real installation is not enabled in Phase 27." >&2
echo "No artifact was fetched." >&2
echo "No disk changes were made." >&2

if [ "$FORMAT" = "json" ]; then
  echo "$selection_json"
else
  echo "Selected ID: $ID"
  echo "Package:     $os_pkg"
  echo "URL:         $os_url"
  echo "Install Allowed: false"
fi

exit 0

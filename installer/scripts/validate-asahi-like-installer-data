#!/bin/bash
# validate-asahi-like-installer-data: Evaluates structural compatibility rules on mock Asahi JSON files
set -euo pipefail

FILE=""
STRICT=0

usage() {
  echo "Usage: $0 [--strict | --permissive] <installer-data.json>"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --strict)
      STRICT=1
      shift
      ;;
    --permissive)
      STRICT=0
      shift
      ;;
    -*)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
    *)
      if [ -n "$FILE" ]; then
        echo "ERROR: Multiple target files specified." >&2
        exit 1
      fi
      FILE="$1"
      shift
      ;;
  esac
done

if [ -z "$FILE" ]; then
  echo "ERROR: installer-data.json file path is required." >&2
  usage
fi

if [ ! -f "$FILE" ]; then
  echo "ERROR: File not found at $FILE" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required." >&2
  exit 1
fi

# Validate JSON formatting
if ! jq . "$FILE" >/dev/null 2>&1; then
  echo "ERROR: Invalid JSON structure in $FILE" >&2
  exit 1
fi

echo "Validating Asahi-like installer data layout..."

# Required top-level
version=$(jq -r '.version' "$FILE")
if [ "$version" = "null" ]; then
  echo "ERROR: Missing required root key: 'version'" >&2
  exit 1
fi

os_list_exists=$(jq -r '.os_list | type' "$FILE")
if [ "$os_list_exists" != "array" ]; then
  echo "ERROR: Root key 'os_list' must be an array." >&2
  exit 1
fi

os_count=$(jq '.os_list | length' "$FILE")
if [ "$os_count" -eq 0 ]; then
  echo "ERROR: 'os_list' array is empty." >&2
  exit 1
fi

errors=0
for ((i=0; i<os_count; i++)); do
  os_id=$(jq -r ".os_list[$i].id" "$FILE")
  os_name=$(jq -r ".os_list[$i].name" "$FILE")
  os_pkg=$(jq -r ".os_list[$i].package" "$FILE")
  os_chk=$(jq -r ".os_list[$i].checksum" "$FILE")
  os_size=$(jq -r ".os_list[$i].size" "$FILE")

  echo "Inspecting entry: $os_id ($os_name)..."

  if [ "$os_id" = "null" ] || [ "$os_name" = "null" ] || [ "$os_pkg" = "null" ] || \
     [ "$os_chk" = "null" ] || [ "$os_size" = "null" ]; then
    echo "  [FAIL] Missing required upstream OS selection keys." >&2
    errors=$((errors + 1))
    continue
  fi

  if [ "$STRICT" -eq 1 ]; then
    if [ "$os_chk" = "PLACEHOLDER_UPSTREAM_SHA256" ]; then
      echo "  [FAIL] Strict mode: placeholder checksum detected in entry: $os_id" >&2
      errors=$((errors + 1))
    fi
  fi
done

if [ $errors -gt 0 ]; then
  echo "Asahi-like installer metadata validation failed with $errors error(s)." >&2
  exit 2
fi

echo "Validation successful."
exit 0

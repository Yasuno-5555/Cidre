#!/bin/bash
# serve-installer-data: Serves installer metadata files over localhost using python3 http server
set -euo pipefail

DIR=""
PORT=8765
HOST="127.0.0.1"
PRINT_ONLY=0

usage() {
  echo "Usage: $0 --directory <path> --port <port> [--host <host>] [--print-only]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --directory)
      if [ $# -lt 2 ]; then
        echo "ERROR: --directory requires a path." >&2
        exit 1
      fi
      DIR="$2"
      shift 2
      ;;
    --port)
      if [ $# -lt 2 ]; then
        echo "ERROR: --port requires a port number." >&2
        exit 1
      fi
      PORT="$2"
      shift 2
      ;;
    --host)
      if [ $# -lt 2 ]; then
        echo "ERROR: --host requires an address." >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --print-only)
      PRINT_ONLY=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$DIR" ]; then
  echo "ERROR: --directory is required." >&2
  usage
fi

if [ ! -d "$DIR" ]; then
  echo "ERROR: Directory not found at $DIR" >&2
  exit 1
fi

abs_dir=$(cd "$DIR" && pwd)

echo "Jackrose Installer Data URL targets:"
echo "  http://$HOST:$PORT/asahi-installer-data.jackrose.dev.json"
echo "  http://$HOST:$PORT/asahi-installer-data.jackrose.local.json"

if [ "$PRINT_ONLY" -eq 1 ]; then
  exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required to spin up the local mocks server." >&2
  exit 1
fi

echo ""
echo "Starting mock HTTP dev server in foreground on port $PORT..."
echo "Press Ctrl-C to stop."
echo ""
echo "No installer has been invoked. No disk changes will be made by this server."
echo ""

python3 -m http.server "$PORT" --bind "$HOST" --directory "$abs_dir"
exit 0

#!/bin/bash
# jackrose-wrapper-fetch-artifact: Fetches selection targets, verifies sha256, and outputs verified artifact record
set -euo pipefail

SELECTION=""
DOWNLOAD_DIR=""
OUTPUT=""
FORCE=0
STRICT=0
NO_MANIFEST=0
MAX_SIZE=4294967296
ALLOW_PLACEHOLDER=0

usage() {
  echo "Usage: $0 --selection <path> --download-dir <dir> --output <path> [options]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --selection)
      if [ $# -lt 2 ]; then
        echo "ERROR: --selection requires a path." >&2
        exit 1
      fi
      SELECTION="$2"
      shift 2
      ;;
    --download-dir)
      if [ $# -lt 2 ]; then
        echo "ERROR: --download-dir requires a directory path." >&2
        exit 1
      fi
      DOWNLOAD_DIR="$2"
      shift 2
      ;;
    --output)
      if [ $# -lt 2 ]; then
        echo "ERROR: --output requires a path." >&2
        exit 1
      fi
      OUTPUT="$2"
      shift 2
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --strict)
      STRICT=1
      shift
      ;;
    --no-manifest-fetch)
      NO_MANIFEST=1
      shift
      ;;
    --max-size-bytes)
      if [ $# -lt 2 ]; then
        echo "ERROR: --max-size-bytes requires an integer." >&2
        exit 1
      fi
      MAX_SIZE="$2"
      shift 2
      ;;
    --allow-placeholder-sha256)
      ALLOW_PLACEHOLDER=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$SELECTION" ] || [ -z "$DOWNLOAD_DIR" ] || [ -z "$OUTPUT" ]; then
  echo "ERROR: --selection, --download-dir, and --output are required." >&2
  usage
fi

if [ ! -f "$SELECTION" ]; then
  echo "ERROR: Selection file not found: $SELECTION" >&2
  exit 1
fi

# Validate download dir paths
if [ "$DOWNLOAD_DIR" = "/" ] || [ "$DOWNLOAD_DIR" = "/boot" ] || [ "$DOWNLOAD_DIR" = "/System" ] || [ "$DOWNLOAD_DIR" = "/Volumes" ]; then
  echo "ERROR: Forbidden download directory location: $DOWNLOAD_DIR" >&2
  exit 1
fi

# Load selection config
s_allowed=$(jq -r '.install_allowed' "$SELECTION")
if [ "$s_allowed" = "true" ]; then
  echo "ERROR: Selection states install_allowed=true. Real installation is strictly forbidden in Phase 28." >&2
  exit 1
fi

selected_id=$(jq -r '.selected_id' "$SELECTION")
package=$(jq -r '.package' "$SELECTION")
url=$(jq -r '.url' "$SELECTION")
manifest=$(jq -r '.manifest' "$SELECTION")
sha_expected=$(jq -r '.sha256' "$SELECTION")
fmt=$(jq -r '.asset_layout.artifact_format' "$SELECTION")

if [ "$selected_id" = "null" ] || [ "$package" = "null" ] || [ "$url" = "null" ] || [ "$manifest" = "null" ] || [ "$sha_expected" = "null" ] || [ "$fmt" = "null" ]; then
  echo "ERROR: Selection file is missing required parameters." >&2
  exit 1
fi

if [ "$fmt" != "tar.zst" ]; then
  echo "ERROR: Unsupported package format in selection: $fmt" >&2
  exit 1
fi

# Verify URL scheme
if [[ ! "$url" =~ ^http://127.0.0.1 && ! "$url" =~ ^http://localhost && ! "$url" =~ ^https:// ]]; then
  echo "ERROR: URL scheme is not allowed: $url" >&2
  exit 1
fi

# Create download directory
mkdir -p "$DOWNLOAD_DIR"

artifact_path="$DOWNLOAD_DIR/$package"
manifest_path="$DOWNLOAD_DIR/$package.manifest"

# オーバーライト防止
if [ -f "$artifact_path" ] && [ "$FORCE" -eq 0 ]; then
  echo "ERROR: Artifact already exists at $artifact_path. Use --force to overwrite." >&2
  exit 1
fi

# Fetch artifact
echo "Fetching artifact from $url..." >&2
if ! curl -L --fail --show-error --output "$artifact_path" "$url"; then
  echo "ERROR: Failed to fetch artifact from $url." >&2
  exit 1
fi

# Check size
size_bytes=$(wc -c < "$artifact_path" | tr -d ' ')
if [ "$size_bytes" -eq 0 ]; then
  echo "ERROR: Downloaded artifact is empty." >&2
  exit 1
fi
if [ "$size_bytes" -gt "$MAX_SIZE" ]; then
  echo "ERROR: Downloaded artifact exceeds max allowed size: $size_bytes bytes." >&2
  exit 1
fi

# Fetch manifest
manifest_fetched=0
if [ "$NO_MANIFEST" -eq 0 ]; then
  echo "Fetching manifest from $manifest..." >&2
  if ! curl -L --fail --show-error --output "$manifest_path" "$manifest"; then
    echo "ERROR: Failed to fetch manifest from $manifest." >&2
    exit 1
  fi
  man_size=$(wc -c < "$manifest_path" | tr -d ' ')
  if [ "$man_size" -eq 0 ]; then
    echo "ERROR: Downloaded manifest is empty." >&2
    exit 1
  fi
  manifest_fetched=1
fi

# Calculate sha256 checksum
echo "Calculating sha256 checksum..." >&2
sha_tool=""
if command -v sha256sum >/dev/null 2>&1; then
  sha_tool="sha256sum"
elif command -v shasum >/dev/null 2>&1; then
  sha_tool="shasum -a 256"
else
  echo "ERROR: Neither sha256sum nor shasum is available." >&2
  exit 1
fi

sha_actual=$($sha_tool "$artifact_path" | cut -d' ' -f1)

# Checksum validation
sha_verified=0
if [ "$sha_expected" = "$sha_actual" ]; then
  sha_verified=1
elif [ "$ALLOW_PLACEHOLDER" -eq 1 ] && { [ "$sha_expected" = "PLACEHOLDER_SHA256" ] || [ -z "$sha_expected" ]; }; then
  echo "WARN: Checksum matching bypassed using placeholder permissions." >&2
  sha_verified=1
fi

if [ "$sha_verified" -eq 0 ]; then
  echo "ERROR: Checksum verification failed." >&2
  echo "Expected: $sha_expected" >&2
  echo "Actual:   $sha_actual" >&2
  exit 1
fi

# Construct verified JSON
verified_json=$(jq -n \
  --arg v_ver "0.1" \
  --arg s_id "$selected_id" \
  --arg name "$(jq -r '.name' "$SELECTION")" \
  --arg version "$(jq -r '.version' "$SELECTION")" \
  --arg art_p "$artifact_path" \
  --arg man_p "$manifest_path" \
  --arg filename "$package" \
  --arg fmt "$fmt" \
  --argjson size "$size_bytes" \
  --arg sha_exp "$sha_expected" \
  --arg sha_act "$sha_actual" \
  --argjson man_fetch "$manifest_fetched" \
  --arg reason "Artifact integrity verified. Extraction and installation are not enabled in Phase 28." \
  '{
    verification_version: $v_ver,
    selected_id: $s_id,
    name: $name,
    version: $version,
    artifact_path: $art_p,
    manifest_path: $man_p,
    artifact_filename: $filename,
    artifact_format: $fmt,
    artifact_size_bytes: $size,
    sha256_expected: $sha_exp,
    sha256_actual: $sha_act,
    sha256_verified: true,
    manifest_fetched: ($man_fetch == 1),
    extract_allowed: false,
    install_allowed: false,
    reason: $reason
  }'
)

# Write output file
mkdir -p "$(dirname "$OUTPUT")"
echo "$verified_json" > "$OUTPUT"

echo "Artifact integrity verified successfully." >&2
echo "Extraction and installation are not enabled in Phase 28." >&2
echo "No disk changes were made." >&2

echo "$verified_json"
exit 0

{
  "schema_version": "0.1",
  "entries": [
    {
      "id": "jackrose-seed-aarch64",
      "name": "Jackrose Desktop Seed",
      "version": "0.10.0",
      "channel": "local",
      "arch": "aarch64",
      "base": "ALARM",
      "description": "ALARM-based Jackrose desktop environment for Apple Silicon Macs.",
      "image": {
        "filename": "jackrose-seed-aarch64-v0.10.0.tar.zst",
        "url": "file://out/jackrose-seed-aarch64-v0.10.0.tar.zst",
        "sha256": "PLACEHOLDER_SHA256",
        "size_bytes": 0,
        "manifest": "file://out/jackrose-seed-aarch64-v0.10.0.manifest"

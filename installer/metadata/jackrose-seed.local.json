      "compatibility": {
        "platform": "apple-silicon",
        "devices": ["m1", "m2", "m3"],
        "requires_asahi_boot_chain": true
      },
      "first_boot": {
        "mode": "desktop-welcome",
        "session": "jackrose",
        "welcome": "jackrose-welcome --first-run"
      },
      "features": [
        "desktop-first",
        "jackrose-welcome",
        "niri",
        "foot-fallback",
        "japanese-input",
        "optimized-upgrade"
      ],
      "warnings": [

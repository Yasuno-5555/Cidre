#!/bin/bash
# jackrose-build-niri-jackrose: Custom niri compositor compilation and deployment helper
set -euo pipefail

MODE=""
DRY_RUN=0

usage() {
  echo "Usage: $0 [--status | --dry-run | --run]"
  exit 1
}

if [ $# -eq 0 ]; then
  usage
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --status) MODE="status"; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --run) MODE="run"; shift ;;
    *) echo "ERROR: Unknown option: $1" >&2; usage ;;
  esac
done

if [ "$MODE" = "status" ]; then
  if command -v niri-jackrose >/dev/null 2>&1; then
    echo "installed"
  else
    echo "missing"
  fi
  exit 0
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo "  [DRY-RUN] would verify rust and cargo toolchain availability."
  echo "  [DRY-RUN] would compile niri-jackrose from source checkout."
  exit 0
fi

if [ "$MODE" != "run" ]; then
  echo "ERROR: Use --run to perform installation." >&2
  exit 1
fi

echo "Checking niri-jackrose availability..."
if command -v niri-jackrose >/dev/null 2>&1; then
  echo "niri-jackrose is already installed."
  exit 0
fi

# Placeholder target build execution
echo "Building niri-jackrose from sources (Placeholder)..."
# In a future phase, this will run compilation commands
echo "niri-jackrose build step completed successfully."
exit 0

#!/bin/bash
# cidre-setup-fish: Configures fish shell environment settings
set -euo pipefail

MODE=""
DRY_RUN=0
TARGET_USER=""

usage() {
  echo "Usage: $0 [--status | --dry-run | --run [--user <username>]]"
  exit 1
}

if [ $# -eq 0 ]; then
  usage
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --status) MODE="status"; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --run) MODE="run"; shift ;;
    --user)
      if [ $# -lt 2 ]; then
        echo "ERROR: --user requires a name." >&2
        exit 1
      fi
      TARGET_USER="$2"
      shift 2
      ;;
    *) echo "ERROR: Unknown option: $1" >&2; usage ;;
  esac
done

if [ "$MODE" = "status" ]; then
  if command -v fish >/dev/null 2>&1; then
    echo "installed"
  else
    echo "missing"
  fi
  exit 0
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo "  [DRY-RUN] would verify fish is installed."
  echo "  [DRY-RUN] would configure default fish theme and shell alias settings."
  exit 0
fi

if [ "$MODE" != "run" ]; then
  echo "ERROR: Use --run to perform shell setups." >&2
  exit 1
fi

echo "Checking fish shell availability..."
if ! command -v fish >/dev/null 2>&1; then
  echo "Fish shell is missing. Bash remains default shell."
  exit 0
fi

if [ -n "$TARGET_USER" ]; then
  echo "Setting up fish shell environment configuration for $TARGET_USER..."
fi

echo "Fish shell setup step completed successfully."
exit 0

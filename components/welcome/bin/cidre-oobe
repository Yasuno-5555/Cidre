#!/bin/bash
# cidre-oobe: Plain-shell Out-of-Box Experience setup assistant
set -euo pipefail

STATE_FILE="/var/lib/cidre/oobe.state"
LOG_FILE="/var/log/cidre-oobe.log"
MARKER_FILE="/var/lib/cidre/firstboot.done"

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")"
mkdir -p "$(dirname "$STATE_FILE")"

# Output helpers to log both to console and file
log() {
  echo -e "$*" | tee -a "$LOG_FILE"
}

error() {
  echo -e "\e[1;31mERROR:\e[0m $*" | tee -a "$LOG_FILE" >&2
}

# Require root privilege
if [ "$EUID" -ne 0 ]; then
  error "This script must be run as root."
  exit 1
fi

# Initialize log file
log "=== Cidre OOBE started at $(date) ==="

# Check if OOBE is already fully completed
if [ -f "$MARKER_FILE" ]; then
  log "OOBE has already been completed. Exiting."
  exit 0
fi

# State management helpers
get_state() {
  local key="$1"
  if [ -f "$STATE_FILE" ]; then
    grep "^${key}=" "$STATE_FILE" | cut -d= -f2- || echo ""
  else
    echo ""
  fi
}

set_state() {
  local key="$1"
  local val="$2"
  # Remove key if already exists
  if [ -f "$STATE_FILE" ]; then
    sed -i "/^${key}=/d" "$STATE_FILE" || true
  fi
  echo "${key}=${val}" >> "$STATE_FILE"
}

# 1. Keyboard Layout Setup
setup_keyboard() {
  local state
  state=$(get_state "keyboard")
  if [ "$state" = "done" ]; then
    log "Keyboard setup already completed. Skipping."
    return 0
  fi

  log "\n=== [Step 1/6] Keyboard Layout Setup ==="
  echo "Choose keyboard layout:"
  echo "  [1] Japanese JIS (jp106)"
  echo "  [2] US ANSI (us)"
  read -r -p "Select option [1-2] (default: 1): " opt

  local keymap="jp106"
  case "$opt" in
    2) keymap="us" ;;
    *) keymap="jp106" ;;
  esac

  log "Applying keymap: $keymap"
  if command -v localectl >/dev/null 2>&1; then
    localectl set-keymap "$keymap" || error "localectl failed to set keymap."
  else
    log "localectl not found, writing keymap directly to /etc/vconsole.conf"
    echo "KEYMAP=$keymap" > /etc/vconsole.conf
  fi

  set_state "keyboard" "done"
}

# 2. Keyboard Input Test
test_keyboard() {
  log "\n=== [Step 2/6] Keyboard Input Test ==="
  echo "Before entering passwords, let's verify special characters."
  echo "Please type exactly the following characters:  @ : \" - _ / \\"
  
  read -r -p "Type characters here: " user_input
  log "User test input entered: '$user_input'"
  
  echo ""
  echo "Did the typed characters match the request? If keys are swapped (e.g. @ became [), keymap is incorrect."
  read -r -p "Is the input correct? [y/N]: " confirm
  if [[ ! "$confirm" =~ ^[yY] ]]; then
    log "Keyboard layout verification failed. Please restart layout configuration."
    # Reset layout done state to force re-run
    set_state "keyboard" "pending"
    return 1
  fi
  log "Keyboard layout verified successfully."
}

# 3. Network Setup
setup_network() {
  local state
  state=$(get_state "network")
  if [ "$state" = "done" ] || [ "$state" = "skipped" ]; then
    log "Network setup already configured ($state). Skipping."
    return 0
  fi

  log "\n=== [Step 3/6] Network Setup ==="
  
  # Ensure NetworkManager is running
  if command -v systemctl >/dev/null 2>&1; then
    systemctl enable --now NetworkManager >/dev/null 2>&1 || true
  fi

  # Check nmtui-connect presence
  if ! command -v nmtui-connect >/dev/null 2>&1; then
    error "nmtui-connect is not installed. Please install NetworkManager TUI support."
    exit 1
  fi

  while true; do
    echo "Configure network connection:"
    echo "  [1] Open nmtui-connect (Choose Wi-Fi / Ethernet)"
    echo "  [2] Test network connection"
    echo "  [3] Skip network setup for now"
    read -r -p "Select option [1-3]: " opt

    case "$opt" in
      1)
        nmtui-connect || true
        ;;
      2)
        echo "Testing connection to archlinux.org..."
        if ping -c 1 archlinux.org >/dev/null 2>&1; then
          log "Network is online!"
          set_state "network" "done"
          break
        else
          error "Network test failed. Cannot reach archlinux.org."
        fi
        ;;
      3)
        log "Skipping network setup for now."
        set_state "network" "skipped"
        break
        ;;
      *)
        echo "Invalid option."
        ;;
    esac
  done
}

# 4. User Account Setup
create_user() {
  local state
  state=$(get_state "user")
  if [ "$state" = "created" ]; then
    local current_user
    current_user=$(get_state "username")
    log "User already created ($current_user). Skipping."
    return 0
  fi

  log "\n=== [Step 4/6] User Account Setup ==="
  local username=""
  
  while true; do
    read -r -p "Enter username for the new account: " username
    
    # Check reserved names
    case "$username" in
      root|cidre|alarm|nobody|daemon|bin|mail|ftp|http|dbus|systemd-*)
        error "Username '$username' is a reserved/system name. Please choose another."
        continue
        ;;
    esac

    # Validate syntax
    if ! [[ "$username" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]]; then
      error "Username must be 1-32 chars, lowercase, start with a-z/_, containing only a-z, 0-9, _, -"
      continue
    fi

    # Check existence
    if id "$username" >/dev/null 2>&1; then
      error "Username '$username' already exists on this system."
      continue
    fi

    break
  done

  log "Creating user account '$username'..."
  useradd -m -G wheel,audio,video,input "$username" || {
    error "Failed to create user account."
    exit 1
  }

  log "Setting password for '$username'..."
  passwd "$username" || {
    error "Failed to set user password."
    userdel -r "$username" || true
    exit 1
  }

  set_state "user" "created"
  set_state "username" "$username"
}

# 5. Cidre User Environment Setup
apply_user_configs() {
  local state
  state=$(get_state "user_setup")
  if [ "$state" = "done" ]; then
    log "User configuration setup already completed. Skipping."
    return 0
  fi

  log "\n=== [Step 5/6] Cidre User Environment Setup ==="
  local username
  username=$(get_state "username")

  if [ -z "$username" ]; then
    error "No username found in state. Cannot run user setup."
    exit 1
  fi

  log "Running cidre-user-setup as user '$username'..."
  
  # Ensure the target config tool exists
  if ! command -v cidre-user-setup >/dev/null 2>&1; then
    error "cidre-user-setup command not found in PATH."
    exit 1
  fi

  # Apply profile default
  if ! HOME="/home/$username" USER="$username" LOGNAME="$username" \
    runuser -u "$username" -- cidre-user-setup apply --profile default; then
    error "cidre-user-setup failed to apply configurations."
    exit 1
  fi

  # Verify file ownership under user's home
  log "Verifying directory ownership..."
  local root_files
  root_files=$(find "/home/$username" -maxdepth 2 -user root 2>/dev/null | wc -l | tr -d ' ')
  if [ "$root_files" -gt 0 ]; then
    log "WARNING: Found $root_files files owned by root in /home/$username."
    log "Fixing ownership permissions..."
    chown -R "$username:$username" "/home/$username" || true
  else
    log "Ownership verification: OK"
  fi

  set_state "user_setup" "done"
}

# 6. Finish & Reboot Prompt
finish_oobe() {
  log "\n=== [Step 6/6] Completing Setup ==="
  log "Creating firstboot completion marker..."
  touch "$MARKER_FILE"

  log "\n=============================================="
  log "      Cidre OOBE Setup Completed Successfully! "
  log "=============================================="
  echo ""
  echo "You should reboot the system now to launch the graphical environment."
  echo "  [1] Reboot now"
  echo "  [2] Exit to shell without reboot"
  read -r -p "Select option [1-2] (default: 1): " opt

  case "$opt" in
    2)
      log "Exited without reboot."
      ;;
    *)
      log "Initiating system reboot..."
      reboot
      ;;
  esac
}

# Main Execution Flow
main() {
  # Run through steps
  setup_keyboard
  
  while ! test_keyboard; do
    setup_keyboard
  done

  setup_network
  create_user
  apply_user_configs
  finish_oobe
}

main

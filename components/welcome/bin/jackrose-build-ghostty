#!/bin/bash
# jackrose-build-ghostty: Ghostty terminal compilation and deployment helper
set -euo pipefail

MODE=""
DRY_RUN=0

usage() {
  echo "Usage: $0 [--status | --dry-run | --run]"
  exit 1
}

if [ $# -eq 0 ]; then
  usage
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --status) MODE="status"; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --run) MODE="run"; shift ;;
    *) echo "ERROR: Unknown option: $1" >&2; usage ;;
  esac
done

if [ "$MODE" = "status" ]; then
  if command -v ghostty >/dev/null 2>&1; then
    echo "installed"
  else
    echo "missing"
  fi
  exit 0
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo "  [DRY-RUN] would verify zig and git toolchain availability."
  echo "  [DRY-RUN] would compile ghostty from sources if missing."
  exit 0
fi

if [ "$MODE" != "run" ]; then
  echo "ERROR: Use --run to perform installation." >&2
  exit 1
fi

echo "Checking Ghostty terminal availability..."
if command -v ghostty >/dev/null 2>&1; then
  echo "Ghostty is already installed."
  exit 0
fi

# Placeholder target build execution
echo "Building Ghostty from sources (Placeholder)..."
# In a future phase, this will run compilation commands
echo "Ghostty build step completed successfully."
exit 0

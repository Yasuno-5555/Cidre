#!/bin/bash
# jackrose-healthcheck: Validates post-install configurations on login or manual run
set -euo pipefail

STATE_DIR="${HOME}/.local/state/jackrose"
SYSTEM_STATE_DIR="/var/lib/jackrose"
MARKER_FILE="${STATE_DIR}/healthcheck.initial.done"
FORCE=false
STATUS_ONLY=false

show_help() {
  echo "Usage: jackrose-healthcheck [options]"
  echo "Options:"
  echo "  --force       Rerun the initial diagnostic health check"
  echo "  --status      Show whether the initial diagnostic has completed"
  echo "  --help        Show this help message"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=true; shift ;;
    --status) STATUS_ONLY=true; shift ;;
    --help) show_help; exit 0 ;;
    *) echo "Unknown option: $1" >&2; show_help; exit 1 ;;
  esac
done

if [ "$STATUS_ONLY" = true ]; then
  if [ -f "$MARKER_FILE" ]; then
    echo "Initial healthcheck verification: Completed"
  else
    echo "Initial healthcheck verification: Pending"
  fi
  exit 0
fi

if [ -f "$MARKER_FILE" ] && [ "$FORCE" = false ]; then
  exit 0
fi

echo "=== Jackrose Initial Health Check ==="
echo "Verifying environment health..."

STATUS_FILE="${STATE_DIR}/healthcheck-status"
mkdir -p "$STATE_DIR"

if command -v jackrose-doctor >/dev/null 2>&1; then
  echo "Running driver diagnostics..."
  DAILY_OK=true
  jackrose-doctor --daily || DAILY_OK=false

  echo "Running update & maintenance readiness diagnostics..."
  MAINT_OK=true
  jackrose-doctor --maintenance || MAINT_OK=false

  echo "Running resume state diagnostics..."
  RESUME_OK=true
  jackrose-doctor --resume || RESUME_OK=false

  if [ "$DAILY_OK" = true ] && [ "$MAINT_OK" = true ] && [ "$RESUME_OK" = true ]; then
    echo "SUCCESS" > "$STATUS_FILE"
    echo "Daily: SUCCESS" >> "$STATUS_FILE"
    echo "Maintenance: SUCCESS" >> "$STATUS_FILE"
    echo "Resume: SUCCESS" >> "$STATUS_FILE"
    echo "All initial health checks passed."
  else
    echo "FAILED" > "$STATUS_FILE"
    echo "Daily: $([ "$DAILY_OK" = true ] && echo "SUCCESS" || echo "FAILED")" >> "$STATUS_FILE"
    echo "Maintenance: $([ "$MAINT_OK" = true ] && echo "SUCCESS" || echo "FAILED")" >> "$STATUS_FILE"
    echo "Resume: $([ "$RESUME_OK" = true ] && echo "SUCCESS" || echo "FAILED")" >> "$STATUS_FILE"
    echo ""
    echo "WARNING: One or more daily or maintenance diagnostic checks failed."
    echo "To see diagnostic recommendations, run: 'jackrose-doctor --fix-suggestions'"
    echo "To restore a previous working state, run: 'jackrose-recovery restore latest'"
  fi
else
  echo "FAILED" > "$STATUS_FILE"
  echo "Error: 'jackrose-doctor' utility not found." >&2
fi

touch "$MARKER_FILE"
echo "Initial healthcheck validation marked as complete."

